    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = LoopSendWorker();

            _ = LoopAddBar();

            _ = LoopAddBubble();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    public async Task CreateWorkers()
    {
        try{

            HelperPerformanceConfig.Log(nameof(HubClient), "CreateWorkers", 0, $"{MainService != null}");

            if (MainWorker == null)
                MainWorker = await workerFactory.CreateAsync();

            if (MainService != null)
                return;

            MainService = await MainWorker.CreateBackgroundServiceAsync<MainHelper>();

            RegisterCandleEvents();
            RegisterBubbleEvents();
            RegisterVolumeEvents();
            RegisterStructureEvents();
            RegisterStructureVolumeEvents();

            await MainService.RunAsync(s => s.InitCandle(ThrottlingCandleMs, TimeFrame, EnableCandleFormer));
            await MainService.RunAsync(s => s.InitBubble(ThrottlingBubbleMs, BubbleThreshold, EnableBubbleFormer));
            await MainService.RunAsync(s => s.InitVolume(ThrottlingVolumeMs, EnableVolumeFormer));
            await MainService.RunAsync(s => s.InitStructure(ThrottlingStructureMs, MinDistanceStructureUpd, EnableStructureFormer));
            await MainService.RunAsync(s => s.InitStructureVolume(ThrottlingStructureVolumeMs, AlphaStructureVolume, EnableStructureVolumeFormer));
            //await MainService.RunAsync(s => s.InitStructureBubble(ThrottlingStructureBubbleMs, EnableStructureBubbleFormer));

            HelperPerformanceConfig.Log(nameof(HubClient), "CreateWorkers", 0, $"{MainService != null}");

        }catch (Exception e)
        {
            HelperPerformanceConfig.Log(nameof(HubClient), "CreateWorkers", 0, $"Error: {e.Message}");
        }
    }

    public async Task CreateHubWorkers()
    {
        try
        {

            HelperPerformanceConfig.Log(nameof(HubClient), "CreateWorkersHub", 0, $"{MainService != null}");

            if (MainHubWorker == null)
                MainHubWorker = await workerFactory.CreateAsync();

            if (HubService != null)
                return;

            HubService = await MainHubWorker.CreateBackgroundServiceAsync<HubClientWorker>();

            await HubService!.RegisterEventListenerAsync(nameof(HubClientWorker.Notify),
                (object? s, IEnumerable<byte[]> datas) =>
                {
                    var sw = Stopwatch.StartNew();

                    if (!EnableTimesAndTrades) return;


                    //debug de velocidade e confirmação de dados
                    _counter += datas.Count();

                    foreach (var data in datas)
                        _ = _channelToDo.Writer.WriteAsync(data);

                    _lastUpdateBarReceived = DateTime.Now;

                    sw.Stop();
                });

            if (HubService != null)
                await HubService.RunAsync(e => e.Init(Navigation.ToAbsoluteUri("/api/datahub").AbsoluteUri, 200, Symbol));


        }
        catch (Exception e)
        {
            HelperPerformanceConfig.Log(nameof(HubClient), "CreateWorkers", 0, $"Error: {e.Message}");
        }
    }

    #region Candle
