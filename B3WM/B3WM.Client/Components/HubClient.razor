            _EnableTimesAndTrades = true; // CandleFormer depende de TimesAndTrades
        }

        if (MainService != null)
        {
            await MainService.RunAsync(s => s.SetEnableCandleFormer(EnableCandleFormer));
            HelperPerformanceConfig.Log(nameof(HubClient), "EnableCandleFormerChanged", 0, $"EnableCandleFormer changed to {value} at {DateTime.Now:HH:mm:ss.fff}");
        }
        //StateHasChanged();
    }

