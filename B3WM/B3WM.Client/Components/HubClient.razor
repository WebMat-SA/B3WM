                var sw = Stopwatch.StartNew();

                data = await AddBarsOnDB(data);

                _ = OnCandleSeriesChange?.Invoke(data);


                sw.Stop();
                HelperPerformanceConfig.Log(nameof(HubClient), "Candle_OnClosedBars",
                    sw.ElapsedMilliseconds,
                    $"Received new closed bars at {DateTime.Now:HH:mm:ss.fff}");
            });

