@using B3WM.Client.Model
@using B3WM.Client.Services
@using B3WM.Shared.Entity
@using B3WM.Shared.Extensions
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text
@using System.Collections.Concurrent
@using System.Diagnostics
@using System.Threading.Channels
@using System.Timers
@inject NavigationManager Navigation
@inject IndexedDbStorageAccessor indexedDbStorage
@inherits Components.PersistentComponentBase
@implements IAsyncDisposable
@using BlazorWorker.WorkerBackgroundService
@using BlazorWorker.BackgroundServiceFactory
@using BlazorWorker.Core
@inject IWorkerFactory workerFactory


@code {

    protected override string PersistenceKey => $"{nameof(HubClient)}_state";
    protected override bool ContinuousSave => true;

    private int _counter { get; set; } = 0;

    public bool openDrawer { get; set; } = false;

    [Parameter]
    public Func<IEnumerable<Bars>, Task> OnCandleSeriesChange { get; set; } = default!;

    [Parameter]
    public Func<IEnumerable<BookItem>, Task> OnBookChange { get; set; } = default!;

    [Parameter]
    public Func<IEnumerable<Ticks2>, Task> OnNewTicks { get; set; } = default!;

    [Parameter]
    public Func<IEnumerable<VolumeLevel>, Task> OnVolumeUpdate { get; set; } = default!;

    [Parameter]
    public int BubbleThreshold { get; set; } = 125;

    [Parameter]
    public Func<Bubble, Task> OnNewBubble { get; set; } = default!;

    [Parameter]
    public Func<Bars, Task> OnCurrentBarChange { get; set; } = default!;

    [Parameter]
    public int TimeFrame { get; set; } = 5;

    private bool _EnableTimesAndTrades = true;
    [Parameter, PersistState]
    public bool EnableTimesAndTrades
    {
        get => _EnableTimesAndTrades;
        set
        {
            if (_EnableTimesAndTrades != value)
            {
                _EnableTimesAndTrades = value;

                if (!_EnableTimesAndTrades){
                    EnableSaveTicksToIndexedDb = false;
                    EnableBubbleFormer = false;
                    EnableCandleFormer = false;
                    EnableVolumeFormer = false;
                }
            }
        }
    }

    [Parameter, PersistState]
    public bool EnableBook { get; set; } = true;

    [Parameter, PersistState]
    public bool EnableTimesAndTradesSimple { get; set; } = true;

    [Parameter, PersistState]
    public bool EnableSaveTicksToIndexedDb { get; set; } = false;



    [PersistState]
    public bool EnableCandleFormer { get; set; }

    public async Task EnableCandleFormerChanged(bool value)
    {
        EnableCandleFormer = value;
        if (EnableCandleFormer)
        {
            _EnableTimesAndTrades = true; // CandleFormer depende de TimesAndTrades
        }

        if (MainService != null)
        {
            await MainService.RunAsync(s => s.SetEnableCandleFormer(EnableCandleFormer));
            HelperPerformanceConfig.Log(nameof(HubClient), "EnableCandleFormerChanged", 0, $"EnableCandleFormer changed to {value} at {DateTime.Now:HH:mm:ss.fff}");
        }
        //StateHasChanged();
    }

    [PersistState]
    public bool EnableVolumeFormer { get; set; }

    public async Task EnableVolumeFormerChanged(bool value)
    {
        EnableVolumeFormer = value;
        if (EnableVolumeFormer)
        {
            _EnableTimesAndTrades = true; // CandleFormer depende de TimesAndTrades
        }

        if (MainService != null)
        {
            await MainService.RunAsync(s => s.SetEnableVolumeFormer(EnableVolumeFormer));
            HelperPerformanceConfig.Log(nameof(HubClient), "EnableVolumeFormer", 0, $"EnableVolumeFormer changed to {value} at {DateTime.Now:HH:mm:ss.fff}");
        }
    }

    [PersistState]
    public bool EnableBubbleFormer { get; set; }

    public async Task EnableBubbleFormerChanged(bool value)
    {
        EnableBubbleFormer = value;
        if (EnableBubbleFormer)
        {
            EnableBubbleFormer = true; // CandleFormer depende de TimesAndTrades
        }
        if (MainService != null)
        {
            await MainService.RunAsync(s => s.SetEnableBubbleFormer(EnableBubbleFormer));
            HelperPerformanceConfig.Log(nameof(HubClient), "EnableBubbleFormer", 0, $"EnableBubbleFormer changed to {value} at {DateTime.Now:HH:mm:ss.fff}");
        }
    }


    public bool IsConnected =>
        hubConnection?.State == HubConnectionState.Connected;

    private IWorker? MainWorker;
    private IWorkerBackgroundService<MainHelper>? MainService { get; set; }

    public int ThrottlingCandleMs = 500;
    public int ThrottlingBubbleMs = 250;
    public int ThrottlingVolumeMs = 250;

    private int _bubbleQueue;
    private int _volumeQueue;
    private int _candleQueue;

    private string? _bubbleTimeQueue;
    private string? _volumeTimeQueue;
    private string? _candleTimeQueue;

    public HubConnection? hubConnection;

    private DateTime? _lastUpdateBarReceived { get; set; }

    public readonly Channel<byte[]> _channelToDo = Channel.CreateBounded<byte[]>(new BoundedChannelOptions(1000){ SingleReader = true, SingleWriter = false});

    protected override async Task OnInitializedAsync()
    {

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/api/datahub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<byte[]>(nameof(IDataHubClient.ReceiveTnT), OnReceiveTNT);
        //hubConnection.On<byte[]>(nameof(IDataHubClient.ReceiveBook), OnReceiveBook);
        //hubConnection.On<byte[]>(nameof(IDataHubClient.ReceiveTnTSimple), OnReceiveTNTSimple);

        await hubConnection.StartAsync();

        await base.OnInitializedAsync();

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender){
            await CreateWorkers();

            _ = RunLoopCache();

        }

        await base.OnAfterRenderAsync(firstRender);
    }

    public async Task CreateWorkers()
    {
        if (MainWorker == null)
            MainWorker = await workerFactory.CreateAsync();

        if (MainService != null)
            return;

        MainService = await MainWorker.CreateBackgroundServiceAsync<MainHelper>();

        RegisterCandleEvents();
        RegisterBubbleEvents();
        RegisterVolumeEvents();

        await MainService.RunAsync(s => s.InitCandle(ThrottlingCandleMs, TimeFrame, EnableCandleFormer));
        await MainService.RunAsync(s => s.InitBubble(ThrottlingBubbleMs, BubbleThreshold, EnableBubbleFormer));
        await MainService.RunAsync(s => s.InitVolume(ThrottlingVolumeMs, EnableVolumeFormer));
    }

    #region Candle
    private void RegisterCandleEvents()
    {
        MainService!.RegisterEventListenerAsync(nameof(MainHelper.Candle_OnClosedBars),
            (object? s, IEnumerable<Bars> data) =>
            {
                var sw = Stopwatch.StartNew();

                _ = OnCandleSeriesChange?.Invoke(data);

                sw.Stop();
                HelperPerformanceConfig.Log(nameof(HubClient), "Candle_OnClosedBars",
                    sw.ElapsedMilliseconds,
                    $"Received new closed bars at {DateTime.Now:HH:mm:ss.fff}");
            });

        MainService.RegisterEventListenerAsync(nameof(MainHelper.Candle_OnQueueCount),
            (object? s, int data) =>
            {
                _candleQueue = data;
            });

        MainService.RegisterEventListenerAsync(nameof(MainHelper.Candle_OnUpdateLastBar),
            (object? s, Bars? data) =>
            {
                var sw = Stopwatch.StartNew();

                _ = OnCurrentBarChange?.Invoke(data);

                sw.Stop();
                // HelperPerformanceConfig.Log(nameof(HubClient), "Candle_OnUpdateLastBar",
                //     sw.ElapsedMilliseconds,
                //     $"Received new current bar at {DateTime.Now:HH:mm:ss.fff}");
            });

        MainService.RegisterEventListenerAsync(nameof(MainHelper.Candle_OnQueueTime),
            (object? s, string data) =>
            {
                _candleTimeQueue = data;
            });
    }
    #endregion

    #region Bubble
    private void RegisterBubbleEvents()
    {
        MainService!.RegisterEventListenerAsync(nameof(MainHelper.Bubble_OnNewBubble),
            (object? s, Bubble data) =>
            {
                var sw = Stopwatch.StartNew();

                _ = OnNewBubble?.Invoke(data);

                sw.Stop();
                HelperPerformanceConfig.Log(nameof(HubClient), "Bubble_OnNewBubble",
                    sw.ElapsedMilliseconds,
                    $"Received new bubble at {DateTime.Now:HH:mm:ss.fff}");
            });

        MainService.RegisterEventListenerAsync(nameof(MainHelper.Bubble_OnQueueCount),
            (object? s, int data) =>
            {
                _bubbleQueue = data;
            });

        MainService.RegisterEventListenerAsync(nameof(MainHelper.Bubble_OnQueueTime),
            (object? s, string data) =>
            {
                _bubbleTimeQueue = data;
            });
    }
    #endregion

    #region Volume
    private void RegisterVolumeEvents()
    {
        MainService!.RegisterEventListenerAsync(nameof(MainHelper.Volume_OnQueueCount),
            (object? s, int data) =>
            {
                _volumeQueue = data;
            });

        MainService.RegisterEventListenerAsync(nameof(MainHelper.Volume_OnVolumeUpdate),
            (object? s, List<VolumeLevel> data) =>
            {
                var sw = Stopwatch.StartNew();

                _ = OnVolumeUpdate?.Invoke(data);

                sw.Stop();
                // HelperPerformanceConfig.Log(nameof(HubClient), "Volume_OnUpdateLastVolume",
                //     sw.ElapsedMilliseconds,
                //     $"Received new current volume at {DateTime.Now:HH:mm:ss.fff}");
            });

        MainService.RegisterEventListenerAsync(nameof(MainHelper.Volume_OnQueueTime),
            (object? s, string data) =>
            {
                _volumeTimeQueue = data;
            });
    }
    #endregion

    private CancellationTokenSource _cts = new();

    private async Task RunLoopCache()
    {
        try
        {
            //HelperPerformanceConfig.Log(nameof(HubClient), "RunLoopCache", 0, $"Starting RunLoopCache at {DateTime.Now:HH:mm:ss.fff}");

            while (await _channelToDo.Reader.WaitToReadAsync(_cts.Token))
            {
                var sw = Stopwatch.StartNew();

                //cria variavel para enviar os dados uma unica vez para o worker, evitando múltiplas chamadas ao método RunAsync e consequentemente melhorando a performance
                string allCompactData = string.Empty;

                while (_channelToDo.Reader.TryRead(out byte[]? _data))
                {
                    if (_data == null) continue;

                    allCompactData += Encoding.UTF8.GetString(_data);
                }

                if (MainService != null)
                {
                    var swTotal = Stopwatch.StartNew();

                    await MainService.RunAsync(s => s.Enqueue(allCompactData));

                    swTotal.Stop();
                    HelperPerformanceConfig.Log(nameof(HubClient), "RunLoop.Work()", swTotal.ElapsedMilliseconds, $"tick at {DateTime.Now:HH:mm:ss.fff}");
                }

                await Task.Delay(10);
                sw.Stop();
                HelperPerformanceConfig.Log(nameof(HubClient), "RunLoopCache", sw.ElapsedMilliseconds, $"Executed work from channel: Reameaning {_channelToDo.Reader.Count}");
            }
        }
        catch (OperationCanceledException e )
        {
            // esperado ao cancelar
            HelperPerformanceConfig.Log(nameof(HubClient), "RunLoopCache", 0, $"Error: {e.Message}");
        }
    }

    private void OnReceiveTNT(byte[] data)
    {
        if (data == null || data.Length == 0) return;

        if (!EnableTimesAndTrades) return;
        

        //debug de velocidade e confirmação de dados
        _counter++;

        _ = _channelToDo.Writer.WriteAsync(data);

        _lastUpdateBarReceived = DateTime.Now;
        
    }

    public async Task<List<VolumeLevel>> GetVolumeSnapshot(DateTime? from, DateTime? to)
    {
        var sw = Stopwatch.StartNew();

        if (MainService == null)
            return new();

        var result = await MainService.RunAsync<List<VolumeLevel>>(s => s.VolumeGetSnapshot(from, to));

        sw.Stop();
        HelperPerformanceConfig.Log(nameof(HubClient), "VolumeGetSnapshot",
            sw.ElapsedMilliseconds,
            $"Received volume snapshot from {from} to {to} at {DateTime.Now:HH:mm:ss.fff}");

        return result ?? new();
    }



    public int GetCacheCount()
    {
        //HelperPerformanceConfig.Log(nameof(HubClient), "GetCacheCount", 0, $"Current cache count: {_channelToDo.Reader.Count} at {DateTime.Now:HH:mm:ss.fff}");
        return _channelToDo.Reader.Count;
    }

    double GetDiffInSeconds(string? time)
    {
        if (_lastUpdateBarReceived == null || string.IsNullOrEmpty(time))
            return double.MaxValue;

        var parsedTime = TimeSpan.Parse(time);

        var combined = _lastUpdateBarReceived.Value.Date + parsedTime;

        return (_lastUpdateBarReceived.Value - combined).TotalSeconds;
    }

    Color GetBadgeColor(string? time)
    {
        var diff = GetDiffInSeconds(time);
        if (diff >= 60)
            return Color.Error;
        else if (diff >= 10)
            return Color.Warning;
        else
            return Color.Success;
    }

    public new async ValueTask DisposeAsync()
    {
        if (MainWorker != null)
            await MainWorker.DisposeAsync();

        if (MainService != null)
            await MainService.DisposeAsync();

        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }

        _channelToDo.Writer.Complete();

        await base.DisposeAsync();
    }
}

