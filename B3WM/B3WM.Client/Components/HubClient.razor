            <MudBadge Color="Color.Info" Overlap=true Bordered=true Content="@($"{_lastUpdateBarReceived?.ToString("HH: mm: ss")} ↓ ")">
                <MudIcon Icon="@Icons.Material.Filled.CandlestickChart" Size="Size.Small" />
            </MudBadge>
        </MudTooltip>
    </div>
    <MudDivider Vertical Class="mx-2" FlexItem="true" DividerType="DividerType.Middle" />
    <div style="margin-right: 68px">
        <MudTooltip Text="@($"Candle (Background)")" Arrow>
            <MudBadge Color="GetBadgeColor(_candleTimeQueue)" Overlap=true Bordered=true Content="@($" {_candleTimeQueue} | {_candleQueue.ToString()}")">
                <MudIcon Icon="@Icons.Material.Filled.CandlestickChart" Size="Size.Small" />
            </MudBadge>
        </MudTooltip>
    </div>
    <div style="margin-right: 68px">
        <MudTooltip Text="@($"Bubble (Background)")" Arrow>
            <MudBadge Color="GetBadgeColor(_bubbleTimeQueue)" Overlap=true Bordered=true Content="@($" {_bubbleTimeQueue} | {_bubbleQueue.ToString()}")">
                <MudIcon Icon="@Icons.Material.Filled.BubbleChart" Size="Size.Small" />
            </MudBadge>
        </MudTooltip>
    </div>
    <div style="margin-right: 68px">
        <MudTooltip Text="@($"Volume (Background)")" Arrow>
            <MudBadge Color="GetBadgeColor(_volumeTimeQueue)" Overlap=true Bordered=true Content="@($" {_volumeTimeQueue} | {_volumeQueue.ToString()}")">
                <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Small" />
            </MudBadge>
        </MudTooltip>
    </div>
    <div style="margin-right: 68px">
        <MudTooltip Text="@($"Structure (Background)")" Arrow>
            <MudBadge Color="GetBadgeColor(_structureTimeQueue)" Overlap=true Bordered=true Content="@($" {_structureTimeQueue} | {_structureQueue.ToString()}")">
                <MudIcon Icon="@Icons.Material.Filled.StackedLineChart" Size="Size.Small" />
            </MudBadge>
        </MudTooltip>
    </div>
    <div style="margin-right: 68px">
        <MudTooltip Text="@($"Volume Structure (Background)")" Arrow>
            <MudBadge Color="GetBadgeColor(_structureVolumeTimeQueue)" Overlap=true Bordered=true Content="@($" {_structureVolumeTimeQueue} | {_structureVolumeQueue.ToString()}")">
                <MudIcon Icon="@Icons.Material.Filled.Polyline" Size="Size.Small" />
            </MudBadge>
        </MudTooltip>
    </div>
    <MudDivider Vertical Class="mx-2" FlexItem="true" DividerType="DividerType.Middle" />
    <MudTooltip Text="Atualizar contadores" Placement="Placement.Start" Arrow>
        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Thermostat" OnClick="StateHasChanged" />
    </MudTooltip>

    <MudDivider Vertical Class="mx-2" FlexItem="true" DividerType="DividerType.Middle" />
    <MudTooltip Text="@($"Play")" Arrow Placement="Placement.Start">
        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.PlayArrow" OnClick="StartSymbol" Disabled="_started" Color="@(_started ? Color.Default : Color.Warning)" />
    </MudTooltip>
</MudStack>

<MudDrawer Class="p-1" Variant="DrawerVariant.Temporary" ClipMode="DrawerClipMode.Docked" Width="22vw" Anchor="Anchor.Right" @bind-Open=openDrawer Style="height: 100vh;">
    <MudStack Justify="Justify.SpaceBetween" Spacing="1">

        <MudPaper Class="p-1" Outlined Elevation="0">
            <MudList T="string" Dense ReadOnly>
                <MudListItem Dense=true Icon="@Icons.Material.Filled.AllOut" Text="Serviços Externos (Tryd)" Expanded=true>
                    <NestedList>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" @bind-Value="EnableTimesAndTrades" ThumbIcon="@(EnableTimesAndTrades == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableTimesAndTrades == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Times and Trades
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Disabled Size="Size.Small" @bind-Value="EnableBook" ThumbIcon="@(EnableBook == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableBook == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Book
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
