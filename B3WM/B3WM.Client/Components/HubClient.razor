    private CancellationTokenSource _cts = new();

    private async Task LoopSendWorker()
    {
        try
        {
            HelperPerformanceConfig.Log(nameof(HubClient), "RunLoopCache", 0, $"Starting RunLoopCache at {DateTime.Now:HH:mm:ss.fff}");

            while (await _channelToDo.Reader.WaitToReadAsync(_cts.Token))
            {
                var sw = Stopwatch.StartNew();

                //cria variavel para enviar os dados uma unica vez para o worker, evitando múltiplas chamadas ao método RunAsync e consequentemente melhorando a performance
                string allCompactData = string.Empty;

                var dequeued = _channelToDo.Reader.Count;

                int count = 0;

                while (_channelToDo.Reader.TryRead(out byte[]? _data) && count<10)
                {
                    if (_data == null) continue;

                    allCompactData += Encoding.UTF8.GetString(_data);
                    count++;
                }

                if (MainService != null)
                {
                    var swTotal = Stopwatch.StartNew();

                    await MainService.RunAsync(s => s.Enqueue(allCompactData));

                    swTotal.Stop();
                    //HelperPerformanceConfig.Log(nameof(HubClient), "RunLoop.SendingToWebWorker()", swTotal.ElapsedMilliseconds, $"tick at {DateTime.Now:HH:mm:ss.fff}");
                }

                //await Task.Delay(10);
                sw.Stop();
                HelperPerformanceConfig.Log(nameof(HubClient), "RunLoopCache", sw.ElapsedMilliseconds, $"Executed work from channel: Dequeued {dequeued}");
            }
        }
        catch (OperationCanceledException e )
        {
            // esperado ao cancelar
            HelperPerformanceConfig.Log(nameof(HubClient), "RunLoopCache", 0, $"Error: {e.Message}");
        }
    }

    private async Task LoopAddBar()
    {
        try
        {
            HelperPerformanceConfig.Log(nameof(HubClient), "LoopAddBar()", 0, $"Initializing");
            while (await _channelBarStorage.Reader.WaitToReadAsync(_cts.Token))
            {
                if (_channelToDo.Reader.Count >= 2)
                {
                    //libera a thread
                    await Task.Delay(5000);
                    continue;
                }

                var sw = Stopwatch.StartNew();

                //cria variavel para enviar os dados uma unica vez para o worker, evitando múltiplas chamadas ao método RunAsync e consequentemente melhorando a performance
                List<BarStorageItem> allBars = new List<BarStorageItem>();

                var dequeued = _channelBarStorage.Reader.Count;

                while (_channelBarStorage.Reader.TryRead(out BarStorageItem? _data))
                {
                    if (_data == null) continue;

                    allBars.Add(_data);
                }

                if (barsQuery != null)
                {
                    var swTotal = Stopwatch.StartNew();

                    //verificar se o update dá add automatico
                    await barsQuery.UpdateRangeAsync(allBars);

                    // await barsQuery.AddOrUpdateRangeAsync(
                    //     allBars,
                    //     x => (x.Symbol, x.TimeFrame, x.Date),
                    //     (exist, incoming) =>
                    //     {
                    //         exist.Open = incoming.Open;
                    //         exist.High = incoming.High;
                    //         exist.Low = incoming.Low;
                    //         exist.Close = incoming.Close;
                    //         exist.Volume = incoming.Volume;

                    //         return exist;
                    //     });

                    swTotal.Stop();
                    HelperPerformanceConfig.Log(nameof(HubClient), "RunLoop.LoopAddBar()", swTotal.ElapsedMilliseconds, $"dequeued {dequeued}");
                }

                sw.Stop();
                HelperPerformanceConfig.Log(nameof(HubClient), "LoopAddBar", sw.ElapsedMilliseconds, $"Executed work from channel: Dequeued {dequeued}");
                //await Task.Delay(5000);
            }
        }
        catch (OperationCanceledException e)
        {
            // esperado ao cancelar
            HelperPerformanceConfig.Log(nameof(HubClient), "LoopAddBar", 0, $"Error: {e.Message}");
        }
    }

    private async Task LoopAddBubble()
    {
        while (true){
            try
            {
                HelperPerformanceConfig.Log(nameof(HubClient), "LoopAddBubble()", 0, $"Initializing");

                while (await _channelBubbleStorage.Reader.WaitToReadAsync(_cts.Token))
                {
                    if (_channelToDo.Reader.Count >= 2)
                    {
                        //libera a thread
                        await Task.Delay(5000);
                        continue;
                    }

                    var sw = Stopwatch.StartNew();

                    //cria variavel para enviar os dados uma unica vez para o worker, evitando múltiplas chamadas ao método RunAsync e consequentemente melhorando a performance
                    List<BubbleStorageItem> allBubbles = new List<BubbleStorageItem>();

                    var dequeued = _channelBubbleStorage.Reader.Count;

                    while (_channelBubbleStorage.Reader.TryRead(out BubbleStorageItem? _data))
                    {
                        if (_data == null) continue;

                        if (string.IsNullOrEmpty(_data.Symbol) ||
                            _data.ActionType == default ||
                            _data.Price == default ||
                            _data.Date == default ||
                            _data.Agent == default)
                        {
                            HelperPerformanceConfig.Log(
                                nameof(HubClient),
                                nameof(LoopAddBubble),
                                0,
                                $"Bubble inválido -> " +
                                $"Symbol:{_data.Symbol ?? "NULL"} | " +
                                $"ActionType:{_data.ActionType} | " +
                                $"Price:{_data.Price} | " +
                                $"Date:{_data.Date:o} | " +
                                $"Agent:{_data.Agent}"
                            );
                        }
                        allBubbles.Add(_data);
                    }

                    if (bubbleQuery != null)
                    {
                        var swTotal = Stopwatch.StartNew();
                        try {

                            await bubbleQuery.UpdateRangeAsync(allBubbles);
                        } 
                        catch (Exception e)
                        {
                            HelperPerformanceConfig.Log(
                                nameof(HubClient),
                                nameof(LoopAddBubble),
                                0, e.Message
                            );
                        }

                        swTotal.Stop();
                        HelperPerformanceConfig.Log(nameof(HubClient), "RunLoop.LoopAddBubble()", swTotal.ElapsedMilliseconds, $"tick at {DateTime.Now:HH:mm:ss.fff}");
                    }

                    sw.Stop();
                    HelperPerformanceConfig.Log(nameof(HubClient), "LoopAddBubble", sw.ElapsedMilliseconds, $"Executed work from channel: Dequeued {dequeued}");
                    //await Task.Delay(5000);
                }
            }
            catch (OperationCanceledException e)
            {
                // esperado ao cancelar
                HelperPerformanceConfig.Log(nameof(HubClient), "LoopAddBubble", 0, $"Error: {e.Message}");
            }
        }
    }

    public int GetCacheCount()
    {
        //HelperPerformanceConfig.Log(nameof(HubClient), "GetCacheCount", 0, $"Current cache count: {_channelToDo.Reader.Count} at {DateTime.Now:HH:mm:ss.fff}");
        return _channelToDo.Reader.Count;
    }

    double GetDiffInSeconds(string? time)
    {
        if (_lastUpdateBarReceived == null || string.IsNullOrEmpty(time))
            return double.MaxValue;

        var parsedTime = TimeSpan.Parse(time);

        var combined = _lastUpdateBarReceived.Value.Date + parsedTime;

        return (_lastUpdateBarReceived.Value - combined).TotalSeconds;
    }

    Color GetBadgeColor(string? time)
    {
        var diff = GetDiffInSeconds(time);
        if (diff >= 60)
            return Color.Error;
        else if (diff >= 10)
            return Color.Warning;
        else
            return Color.Success;
    }

    public new async ValueTask DisposeAsync()
    {
        if (MainService != null)
            await MainService.DisposeAsync();

        if (MainWorker != null)
            await MainWorker.DisposeAsync();

        _channelToDo.Writer.Complete();

        await base.DisposeAsync();
    }

    public async Task<BarStorageItem> AddBarsOnDB(BarStorageItem bar)
    {
        if (FakingData) return bar;

        if (bar == null) return new BarStorageItem();
        var sw = Stopwatch.StartNew();

        //vincula o volume no candle
        bar.VolumeLevel = _lastVolumeLevel?.Volumes;

        await _channelBarStorage.Writer.WriteAsync(bar);


        sw.Stop();
        HelperPerformanceConfig.Log(nameof(Magic), nameof(AddBarsOnDB), sw.ElapsedMilliseconds, $"Added {bar.Date} bars to IndexedDB at {DateTime.Now:HH:mm:ss.fff}");

        return bar;
    }

    public async Task AddBubleOnDB(BubbleStorageItem bubble)
    {
        if (FakingData) return;

        await _channelBubbleStorage.Writer.WriteAsync(bubble);
    }


    public bool _started { get; set; } = false;
    public async Task StartSymbol()
    {
        _started = true;

        if (MainService != null) await MainService.DisposeAsync();
        if (MainWorker != null) await MainWorker.DisposeAsync();
        await CreateWorkers();

        if (HubService != null) await HubService.DisposeAsync();
        if (MainHubWorker != null) await MainHubWorker.DisposeAsync();
        await CreateHubWorkers();
    }
}

