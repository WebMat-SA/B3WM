                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Times and Trades (Simples)
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        
                    </NestedList>
                </MudListItem>
            </MudList>
        </MudPaper>

        <MudPaper Class="p-1" Outlined Elevation="0">
            <MudList T="string" Dense ReadOnly>
                <MudListItem Dense=true Icon="@Icons.Material.Filled.VideoSettings" Text="Serviços Internos" Expanded=true>
                    <NestedList>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" T="bool" Value="EnableCandleFormer" ValueChanged="EnableCandleFormerChanged" ThumbIcon="@(EnableCandleFormer == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableCandleFormer == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Formação de Candles (no trimeframe específico)
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" T="bool" Value="EnableBubbleFormer" ValueChanged="EnableBubbleFormerChanged" ThumbIcon="@(EnableBubbleFormer == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableBubbleFormer == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Formação dos bubbles (>= Amount informado)
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" T="bool" Value="EnableVolumeFormer" ValueChanged="EnableVolumeFormerChanged" ThumbIcon="@(EnableVolumeFormer == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableVolumeFormer == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Formação de Volume Inspector
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" T="bool" Value="EnableStructureFormer" ValueChanged="EnableStructureFormerChanged" ThumbIcon="@(EnableStructureFormer == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableStructureFormer == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Formação de Estruturas por preço
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" T="bool" Value="EnableStructureVolumeFormer" ValueChanged="EnableStructureVolumeFormerChanged" ThumbIcon="@(EnableStructureVolumeFormer == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableStructureVolumeFormer == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Formação de Estruturas por volume
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" Disabled="@(!EnableTimesAndTrades || true)" @bind-Value="EnableSaveTicksToIndexedDb" ThumbIcon="@(EnableSaveTicksToIndexedDb == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableSaveTicksToIndexedDb == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Save Ticks (Local DB)
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                    </NestedList>
                </MudListItem>
            </MudList>
        </MudPaper>

