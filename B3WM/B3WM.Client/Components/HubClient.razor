@using B3WM.Shared.Entity
@using B3WM.Shared.Extensions
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text
@using System.Collections.Concurrent
@using System.Threading.Channels
@using System.Timers
@inject NavigationManager Navigation
@inject IndexedDbStorageAccessor indexedDbStorage
@inherits Components.PersistentComponentBase
@implements IAsyncDisposable

@code {

    protected override string PersistenceKey => $"{nameof(HubClient)}_state";
    protected override bool ContinuousSave => true;

    private HubConnection? hubConnection;

    private int _counter { get; set; } = 0;
    public bool openDrawer { get; set; } = false;

    private BubbleHelper? bubbleHelper;

    private CandleHelper? candleHelper;

    private VolumeHelper? volumeHelper;

    [Parameter]
    public EventCallback<IEnumerable<Bars>> OnCandleSeriesChange { get; set; } = default!;

    [Parameter]
    public EventCallback<IEnumerable<BookItem>> OnBookChange { get; set; } = default!;

    [Parameter]
    public EventCallback<IEnumerable<Ticks2>> OnNewTicks { get; set; } = default!;

    [Parameter]
    public EventCallback<IEnumerable<VolumeLevel>> OnVolumeUpdate { get; set; } = default!;

    [Parameter]
    public int BubbleThreshold { get; set; } = 125;

    [Parameter]
    public EventCallback<Bubble> OnNewBubble { get; set; } = default!;

    [Parameter]
    public EventCallback<Bars> OnCurrentBarChange { get; set; } = default!;

    [Parameter]
    public int TimeFrame { get; set; } = 5;

    private bool _EnableTimesAndTrades = true;
    [Parameter, PersistState]
    public bool EnableTimesAndTrades
    {
        get => _EnableTimesAndTrades;
        set
        {
            if (_EnableTimesAndTrades != value)
            {
                _EnableTimesAndTrades = value;

                if (!_EnableTimesAndTrades){
                    EnableSaveTicksToIndexedDb = false;
                    EnableBubbleFormer = false;
                    EnableCandleFormer = false;
                    EnableVolumeFormer = false;
                }

                StateHasChanged();
            }
        }
    }

    [Parameter, PersistState]
    public bool EnableBook { get; set; } = true;

    [Parameter, PersistState]
    public bool EnableTimesAndTradesSimple { get; set; } = true;

    [Parameter, PersistState]
    public bool EnableSaveTicksToIndexedDb { get; set; } = false;


    private bool _EnableCandleFormer = true;
    [PersistState]
    public bool EnableCandleFormer
    {
        get => _EnableCandleFormer;
        set
        {
            if (_EnableCandleFormer != value)
            {
                _EnableCandleFormer = value;
                if (!_EnableCandleFormer)
                {
                    candleHelper?.Dispose();
                    candleHelper = null;
                }
                else
                {
                    _EnableTimesAndTrades = true; // CandleFormer depende de TimesAndTrades
                }
                StateHasChanged();
            }
        }
    }

    private bool _EnableVolumeFormer = true;
    [PersistState]
    public bool EnableVolumeFormer
    {
        get => _EnableVolumeFormer;
        set
        {
            if (_EnableVolumeFormer != value)
            {
                _EnableVolumeFormer = value;
                if (!_EnableVolumeFormer)
                {
                    volumeHelper?.Dispose();
                    volumeHelper = null;
                }
                else
                {
                    _EnableTimesAndTrades = true; // CandleFormer depende de TimesAndTrades
                }
                StateHasChanged();
            }
        }
    }

    private bool _EnableBubbleFormer = true;
    [PersistState]
    public bool EnableBubbleFormer
    {
        get => _EnableBubbleFormer;
        set
        {
            if (_EnableBubbleFormer != value)
            {
                _EnableBubbleFormer = value;
                if (!_EnableBubbleFormer)
                {
                    bubbleHelper?.Dispose();
                    bubbleHelper = null;
                }
                else
                {
                    _EnableTimesAndTrades = true; // CandleFormer depende de TimesAndTrades
                }
                StateHasChanged();
            }
        }
    }


    public bool IsConnected =>
        hubConnection?.State == HubConnectionState.Connected;

    private PeriodicTimer? _timer;

    // Throttle: evita atualizar UI e publicar barra/volume mais que o necessário
    private const int UiRefreshIntervalMs = 1000;
    private const int CurrentBarPublishIntervalMs = 250;
    private const int VolumePublishIntervalMs = 600;
    private DateTime _lastUiRefreshUtc = DateTime.MinValue;
    private (int version, DateTime atUtc) _currentBarThrottle = (-1, DateTime.MinValue);
    private (int version, DateTime atUtc) _volumeThrottle = (-1, DateTime.MinValue);
    private Bars? _currentBarPending;
    private bool _currentBarPublishing;
    private List<VolumeLevel>? _volumePending;
    private bool _volumePublishing;

    private readonly Channel<List<Ticks2>> _ticksSaveChannel = Channel.CreateUnbounded<List<Ticks2>>(new UnboundedChannelOptions { SingleReader = true, SingleWriter = false });
    private CancellationTokenSource? _ticksSaveCts;

    private static bool ShouldPublish(int currentVersion, (int version, DateTime atUtc) throttle, int intervalMs)
    {
        if (currentVersion == throttle.version) return false;
        var now = DateTime.UtcNow;
        return throttle.atUtc == DateTime.MinValue || (now - throttle.atUtc).TotalMilliseconds >= intervalMs;
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/api/datahub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<byte[]>(nameof(IDataHubClient.ReceiveTnT), OnReceiveTNT);
        //hubConnection.On<byte[]>(nameof(IDataHubClient.ReceiveBook), OnReceiveBook);
        //hubConnection.On<byte[]>(nameof(IDataHubClient.ReceiveTnTSimple), OnReceiveTNTSimple);

        await hubConnection.StartAsync();

        _ticksSaveCts = new CancellationTokenSource();
        _ = RunTicksSaveLoopAsync(_ticksSaveCts.Token);
    }

    protected override void OnInitialized()
    {
        _timer = new PeriodicTimer(TimeSpan.FromMilliseconds(100));
        _ = RunLoop();
    }

    private async Task RunLoop()
    {
        while (await _timer!.WaitForNextTickAsync())
        {
            if (candleHelper is not null && OnCurrentBarChange.HasDelegate)
            {
                var version = candleHelper.GetCurrentBarVersion();
                if (ShouldPublish(version, _currentBarThrottle, CurrentBarPublishIntervalMs))
                {
                    var snapshot = candleHelper.GetCurrentBarSnapshot();
                    if (snapshot != null)
                    {
                        _currentBarThrottle = (version, DateTime.UtcNow);
                        _currentBarPending = snapshot;
                        _ = TryPublishCurrentBarAsync();
                    }
                }
            }

            if (volumeHelper is not null && OnVolumeUpdate.HasDelegate)
            {
                var version = volumeHelper.GetVolumeVersion();
                if (ShouldPublish(version, _volumeThrottle, VolumePublishIntervalMs))
                {
                    _volumeThrottle = (version, DateTime.UtcNow);
                    _volumePending = volumeHelper.GetSnapshot();
                    _ = TryPublishVolumeAsync();
                }
            }
        }
    }

    private async Task TryPublishCurrentBarAsync()
    {
        if (_currentBarPublishing) return;
        _currentBarPublishing = true;
        try
        {
            while (_currentBarPending is { } snapshot)
            {
                _currentBarPending = null;
                await OnCurrentBarChange.InvokeAsync(snapshot);
            }
        }
        finally { _currentBarPublishing = false; }
    }

    private async Task TryPublishVolumeAsync()
    {
        if (_volumePublishing) return;
        _volumePublishing = true;
        try
        {
            while (_volumePending is { } snapshot)
            {
                _volumePending = null;
                await OnVolumeUpdate.InvokeAsync(snapshot);
            }
        }
        finally { _volumePublishing = false; }
    }

    private async void OnReceiveBook(byte[] data)
    {
        if (!EnableBook) return;

        //debug de velocidade e confirmação de dados
        _counter++;

        if (OnBookChange.HasDelegate) await OnBookChange.InvokeAsync(new DataHelper(data).Book());

        RequestUiRefreshThrottled();

    }

    private void OnReceiveTNT(byte[] data)
    {
        if (!EnableTimesAndTrades) return;

        //debug de velocidade e confirmação de dados
        _counter++;

        // Avoid re-rendering for every packet; this path can be called many times per second.
        RequestUiRefreshThrottled();

        // Parse único: todos os helpers e subscribers recebem a mesma lista
        var ticks = new DataHelper(data).TimesAndTrades().ToList();
        if (ticks.Count == 0) return;

        // Notify subscribers about the new tick in the same order we dequeue it
        if (OnNewTicks.HasDelegate)
            OnNewTicks.InvokeAsync(ticks);

        if (EnableSaveTicksToIndexedDb)
            _ticksSaveChannel.Writer.TryWrite(ticks);

        _ = Enqueue(ticks);
    }

    private void OnReceiveTNTSimple(byte[] data)
    {
        if (!EnableTimesAndTradesSimple) return;

        //debug de velocidade e confirmação de dados
        _counter++;

        RequestUiRefreshThrottled();
    }

    private void RequestUiRefreshThrottled()
    {
        var now = DateTime.UtcNow;
        if (_lastUiRefreshUtc != DateTime.MinValue &&
            (now - _lastUiRefreshUtc).TotalMilliseconds < UiRefreshIntervalMs)
            return;

        _lastUiRefreshUtc = now;
        _ = InvokeAsync(StateHasChanged);
    }

    private Task Enqueue(IReadOnlyList<Ticks2> ticks)
    {
        if (ticks == null || ticks.Count == 0) return Task.CompletedTask;

        if (EnableBubbleFormer)
        {
            if (bubbleHelper is null)
                bubbleHelper = new BubbleHelper(NewBubble, BubbleThreshold);

            _ = bubbleHelper.Enqueue(ticks);
        }

        if (EnableCandleFormer)
        {
            if (candleHelper is null)
            {
                candleHelper = new CandleHelper(NewBars, TimeFrame);
                _currentBarThrottle = (-1, DateTime.MinValue);
            }

            _ = candleHelper.Enqueue(ticks);
        }

        if (EnableVolumeFormer)
        {
            if (volumeHelper is null)
            {
                volumeHelper = new VolumeHelper();
                _volumeThrottle = (-1, DateTime.MinValue);
            }

            _ = volumeHelper.Enqueue(ticks);
        }

        return Task.CompletedTask;
    }

    public void NewBubble(Bubble data)
    {
        if (OnNewBubble.HasDelegate) 
            OnNewBubble.InvokeAsync(data);
    }

    public void NewBars(IEnumerable<Bars> bars)
    {
        if (bars == null || !OnCandleSeriesChange.HasDelegate) return;
        var list = bars.ToList();
        if (list.Count == 0) return;
        OnCandleSeriesChange.InvokeAsync(list);
    }

    private async Task RunTicksSaveLoopAsync(CancellationToken ct)
    {
        const int maxBatchSize = 400;
        var batch = new List<Ticks2>();
        try
        {
            while (!ct.IsCancellationRequested)
            {
                try
                {
                    batch.Clear();
                    await foreach (var list in _ticksSaveChannel.Reader.ReadAllAsync(ct))
                    {
                        batch.AddRange(list);
                        while (batch.Count < maxBatchSize && _ticksSaveChannel.Reader.TryRead(out var next))
                            batch.AddRange(next);
                        break;
                    }
                    if (batch.Count > 0)
                        await indexedDbStorage.PutTicksBatchAsync(batch);
                }
                catch (OperationCanceledException) { break; }
                catch (Exception) { /* evita derrubar o loop */ }
            }
        }
        catch (OperationCanceledException) { }
    }

    public async new ValueTask DisposeAsync()
    {
        _ticksSaveCts?.Cancel();
        _ticksSaveChannel.Writer.Complete();
        await base.DisposeAsync();

        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
        candleHelper?.Dispose();
        bubbleHelper?.Dispose();
        volumeHelper?.Dispose();
    }

    public void ResetHelpers()
    {
        bubbleHelper?.Dispose();
        bubbleHelper = null;
        candleHelper?.Dispose();
        candleHelper = null;
        //volumeHelper?.Dispose();
        //volumeHelper = null;
    }
}

<MudStack Row AlignItems="AlignItems.Center">
    <MudTooltip Text="@($"{hubConnection?.State.ToString()} : {_counter}")" Placement="Placement.Left">
        <MudBadge Color=Color.Info Overlap=true Bordered=true Content="@_counter" OnClick="() => _counter = 0">
            <MudIconButton Icon="@Icons.Material.Filled.Wifi" Color="IsConnected? Color.Success: Color.Error" OnClick="() => openDrawer = !openDrawer" />
        </MudBadge>
    </MudTooltip>

</MudStack>

<MudDrawer Class="p-1" Variant="DrawerVariant.Temporary" ClipMode="DrawerClipMode.Docked" Width="22vw" Anchor="Anchor.Right" @bind-Open=openDrawer Style="height: 100vh;">
    <MudStack Justify="Justify.SpaceBetween" Spacing="1">

        <MudPaper Class="p-1" Outlined Elevation="0">
            <MudList T="string" Dense ReadOnly>
                <MudListItem Dense=true Icon="@Icons.Material.Filled.AllOut" Text="Serviços Externos (Tryd)" Expanded=true>
                    <NestedList>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" @bind-Value="EnableTimesAndTrades" ThumbIcon="@(EnableTimesAndTrades == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableTimesAndTrades == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Times and Trades
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" @bind-Value="EnableBook" ThumbIcon="@(EnableBook == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableBook == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Book
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" @bind-Value="EnableTimesAndTradesSimple" ThumbIcon="@(EnableTimesAndTradesSimple == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableTimesAndTradesSimple == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Times and Trades (Simples)
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        
                    </NestedList>
                </MudListItem>
            </MudList>
        </MudPaper>

        <MudPaper Class="p-1" Outlined Elevation="0">
            <MudList T="string" Dense ReadOnly>
                <MudListItem Dense=true Icon="@Icons.Material.Filled.VideoSettings" Text="Serviços Internos" Expanded=true>
                    <NestedList>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" @bind-Value="EnableCandleFormer" ThumbIcon="@(EnableCandleFormer == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableCandleFormer == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Formação de Candles (no trimeframe específico)
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" @bind-Value="EnableBubbleFormer" ThumbIcon="@(EnableBubbleFormer == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableBubbleFormer == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Formação dos bubbles (>= Amount informado)
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" @bind-Value="EnableVolumeFormer" ThumbIcon="@(EnableVolumeFormer == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableVolumeFormer == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Formação de Volume Inspector
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSwitch Size="Size.Small" Disabled="@(!EnableTimesAndTrades)" @bind-Value="EnableSaveTicksToIndexedDb" ThumbIcon="@(EnableSaveTicksToIndexedDb == true ? Icons.Material.Filled.Done : Icons.Material.Filled.Close)" ThumbIconColor="@(EnableSaveTicksToIndexedDb == true ? Color.Success : Color.Error)">
                                <MudText Typo="Typo.caption" Class="ml-4">
                                    Save Ticks (Local DB)
                                </MudText>
                            </MudSwitch>
                        </MudListItem>
                    </NestedList>
                </MudListItem>
            </MudList>
        </MudPaper>

        <MudPaper Class="p-1" Outlined Elevation="0">
            <MudList T="string" Dense ReadOnly>
                <MudListItem Dense=true Icon="@Icons.Material.Filled.Wifi" Expanded=true>
                    
                    <AvatarContent>
                        <MudTooltip Text="@hubConnection?.State.ToString()">
                            <MudIcon Size="Size.Small" Icon="@Icons.Material.Filled.Wifi" Color="IsConnected? Color.Success: Color.Error" />
                        </MudTooltip>
                    </AvatarContent>
                    <ChildContent>
                        <MudText Typo="Typo.caption">Status</MudText>
                    </ChildContent>
                    <NestedList>
                        <MudListItem Dense="true">
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Dados recebidos:</MudText>
                                <MudText Typo="Typo.caption" @onclick="() => _counter = 0">@_counter</MudText>
                            </MudStack>
                        </MudListItem>
                    </NestedList>
                </MudListItem>
            </MudList>
        </MudPaper>
    </MudStack>
    
</MudDrawer>