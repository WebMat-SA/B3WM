@using B3WM.Shared.Entity
@using Microsoft.AspNetCore.SignalR.Client
@using System.Threading.Channels
@inject NavigationManager Navigation
@implements IAsyncDisposable

@code {
    [Parameter]
    public bool EnableTimesAndTrades { get; set; }

    [Parameter]
    public int _counter { get; set; } = 0;

    [Parameter]
    public EventCallback<int> _counterChanged { get; set; }

    public HubConnection? hubConnection;

    public readonly Channel<Ticks2[]> _channelTicks = Channel.CreateUnbounded<Ticks2[]>(new UnboundedChannelOptions { SingleReader = true, SingleWriter = false });

    private DateTime? _lastUpdateBarReceived { get; set; }

    protected override async Task OnInitializedAsync()
    {

        InitHub();

        await base.OnInitializedAsync();

    }

    private async void InitHub()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/api/datahub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<byte[]>(nameof(IDataHubClient.ReceiveTnT), OnReceiveTNT);
        //hubConnection.On<byte[]>(nameof(IDataHubClient.ReceiveBook), OnReceiveBook);
        //hubConnection.On<byte[]>(nameof(IDataHubClient.ReceiveTnTSimple), OnReceiveTNTSimple);

        await hubConnection.StartAsync();
    }

    private async void OnReceiveBook(byte[] data)
    {
        //if (!EnableBook) return;

        //debug de velocidade e confirmação de dados
        //_counter++;

        //if (OnBookChange.HasDelegate) await OnBookChange.InvokeAsync(new DataHelper(data).Book());

    }

    private void OnReceiveTNT(byte[] data)
    {
        if (!EnableTimesAndTrades) return;

        //debug de velocidade e confirmação de dados
        _counter++;

        _counterChanged.InvokeAsync(_counter);

        // Parse único: todos os helpers e subscribers recebem a mesma lista
        var ticks = new DataHelper(data).TimesAndTrades().ToArray();
        if (ticks.Length == 0) return;

        // Notify subscribers about the new tick in the same order we dequeue it
        // if (OnNewTicks.HasDelegate)
        //     OnNewTicks.InvokeAsync(ticks);

        // if (EnableSaveTicksToIndexedDb)
        //     _ticksSaveChannel.Writer.TryWrite(ticks);

        _channelTicks.Writer.TryWrite(ticks);

        _lastUpdateBarReceived = ticks.Last().Time;
        StateHasChanged();
    }

    private void OnReceiveTNTSimple(byte[] data)
    {
        //if (!EnableTimesAndTradesSimple) return;

        //debug de velocidade e confirmação de dados
        //_counter++;

    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }

        _channelTicks.Writer.Complete();
    }
}
<div style="margin-right: 65px">
    <MudTooltip Text="@($"Last Received: {_lastUpdateBarReceived?.ToString("HH:mm:ss")}")" Placement="Placement.Left">
        <MudBadge Color="Color.Info" Overlap=true Bordered=true Content="@($"{_lastUpdateBarReceived?.ToString("HH: mm: ss")} ↓ ")">
            <MudIcon Icon="@Icons.Material.Filled.CandlestickChart" Size="Size.Small" />
        </MudBadge>
    </MudTooltip>
</div>