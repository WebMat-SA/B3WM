@using System.Text.Json;
@using B3WM.Shared.Interfaces
@using B3WM.Shared.Models
@using Microsoft.AspNetCore.SignalR.Client;
@inject NavigationManager Navigation

@code {
    public HubConnection? hubConnection;

    [CascadingParameter] public required string Symbol { get; set; }

    [Parameter] public int? Timeframe { get; set; }

    [Parameter]
    public Func<BarStorageItem, Task> OnCloseBar { get; set; } = default!;

    [Parameter]
    public Func<BubbleStorageItem, Task> OnNewBubble { get; set; } = default!;

    [Parameter]
    public Func<VolumeLevelStorageItem, Task> OnVolumeUpdate { get; set; } = default!;

    [Parameter]
    public Func<BarStorageItem, Task> OnCurrentBar { get; set; } = default!;

    [Parameter]
    public Func<StructureStorageItem, Task> OnNewStructure { get; set; } = default!;

    [Parameter]
    public Func<AdjustmentForecastItem, Task> OnForecastUpdate { get; set; } = default!;

    [Parameter]
    public Func<IndicatorValue, Task> OnIndicatorValue { get; set; } = default!;

    [Parameter]
    public bool ShowButtons { get; set; } = false;

    #region Not Done yet
    // [Parameter]
    // public Func<StructureStorageItem, Task> OnNewStructure { get; set; } = default!;

    // [Parameter]
    // public Func<StructureVolumeStorageItem, Task> OnNewStructureVolume { get; set; } = default!;
    #endregion

    public bool _started { get; set; } = false;

    public async Task StartConnection()
    {
        _started = true;
        try
        {
            hubConnection = new HubConnectionBuilder()
                           .WithUrl(Navigation.ToAbsoluteUri("/api/datahub").AbsoluteUri)
                           .WithAutomaticReconnect()
                           .Build();

            hubConnection.Reconnected += async connectionId =>
            {
                if (!string.IsNullOrEmpty(Symbol))
                    await hubConnection.SendAsync("JoinGroup", Symbol);

                await InvokeAsync(StateHasChanged);
            };

            hubConnection.Reconnecting += error =>
            {
                Console.WriteLine($"SignalR reconnecting: {error?.Message}");
                return Task.CompletedTask;
            };

            hubConnection.Closed += async error =>
            {
                Console.WriteLine($"SignalR closed: {error?.Message}");

                await Task.Delay(3000);

                try
                {
                    await StartConnection();
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"SignalR restart failed: {ex.Message}");
                }
            };

            hubConnection.On<BarStorageItem>(nameof(IDataHubClient.ReceiveOnCloseBar), OnCloseBar);
            hubConnection.On<BubbleStorageItem>(nameof(IDataHubClient.ReceiveOnBubble), OnNewBubble);
            hubConnection.On<StructureStorageItem>(nameof(IDataHubClient.ReceiveOnStructure), OnNewStructure);
            hubConnection.On<AdjustmentForecastItem>(nameof(IDataHubClient.ReceiveOnForecast), OnForecastUpdate);
            hubConnection.On<ThrottlingData>(nameof(IDataHubClient.ReceiveThrottlingData), OnThrottlingData);
            hubConnection.On<IndicatorValue>(nameof(IDataHubClient.ReceiveOnIndicatorValue), OnIndicatorValue);

            await hubConnection.StartAsync();

            if (!string.IsNullOrEmpty(Symbol)) await hubConnection.SendAsync("JoinGroup", Symbol);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting connection: {ex.Message}");
        }
    }

    public async Task StopConnection()
    {
        _started = false;

        if (hubConnection is not null)
        {
            await hubConnection.StopAsync();
            await hubConnection.DisposeAsync();
            hubConnection = null;
        }
    }

    public async Task OnThrottlingData(ThrottlingData data)
    {
        try
        {
            var sw = System.Diagnostics.Stopwatch.StartNew();
            BarStorageItem? currentBar = null;
            VolumeLevelStorageItem? currentVolume = null;

            //colocar aqui filtro de timeframe - TODO
            if (Timeframe != null) currentBar = data.Candle.FirstOrDefault(c => c.TimeFrame == Timeframe);
            currentVolume = data.Volume;

            if (currentBar != null && OnCurrentBar != null) await OnCurrentBar.Invoke(currentBar);
            if (currentVolume != null && OnVolumeUpdate != null) await OnVolumeUpdate.Invoke(currentVolume);

            if (data.Forecast != null && OnForecastUpdate != null)
                await OnForecastUpdate.Invoke(data.Forecast);

            sw.Stop();
            //Console.WriteLine($"Throttling data processed in {sw.ElapsedMilliseconds} ms");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error parsing throttling data: {ex.Message}");
        }
    }
}

@if(ShowButtons)
{
    @if (!_started)
    {
        <MudTooltip Text="@($"Play")" Arrow Placement="Placement.Start">
            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.PlayArrow" OnClick="StartConnection" Disabled="_started" Color="@(_started ? Color.Default : Color.Warning)" />
        </MudTooltip>
    }
    else
    {
        <MudTooltip Text="@($"Connected")" Arrow Placement="Placement.Start">
            <MudIconButton Icon="@Icons.Material.Filled.Wifi" Color="@(hubConnection?.State == HubConnectionState.Connected ? Color.Success : Color.Dark)" Size="Size.Small" OnClick="StopConnection" />
        </MudTooltip>
    }
}