@using System.Globalization
@using System.Net.Http.Json
@using B3WM.Shared.Extensions
@using B3WM.Shared.Interfaces
@using B3WM.Shared.Models
@inject HttpClient Http
@inherits Components.PersistentComponentBase

@code {
    protected override string PersistenceKey => $"{nameof(MapFlowStrategyDrawer)}_{Symbol}_state";

    [CascadingParameter]
    public string Symbol { get; set; } = "";

    [Parameter]
    public bool Open { get; set; }

    private List<IndicatorInfo> _indicators = new();
    private Dictionary<string, Dictionary<string, double>> _pendingChanges = new();
    private Dictionary<string, string> _indicatorColors = new();
    private Dictionary<string, bool> _indicatorVisible = new();

    [PersistState]
    public string ColorsJson
    {
        get => System.Text.Json.JsonSerializer.Serialize(_indicatorColors);
        set
        {
            try { _indicatorColors = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(value ?? "{}") ?? new(); }
            catch { _indicatorColors = new(); }
        }
    }

    [PersistState]
    public string VisibleJson
    {
        get => System.Text.Json.JsonSerializer.Serialize(_indicatorVisible);
        set
        {
            try { _indicatorVisible = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, bool>>(value ?? "{}") ?? new(); }
            catch { _indicatorVisible = new(); }
        }
    }

    private Dictionary<string, double> _lastValues = new();

    public void UpdateValue(IndicatorValue data)
    {
        var key = $"{data.IndicatorName}.{data.Key}";
        _lastValues[key] = data.Value;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadIndicatorsAsync();
    }

    public async Task RefreshAsync()
    {
        await LoadIndicatorsAsync();
    }

    private async Task LoadIndicatorsAsync()
    {
        try
        {
            var list = await Http.GetFromJsonAsync<List<IndicatorInfo>>("/api/indicator/list");
            if (list != null)
            {
                _indicators = list;
                foreach (var ind in _indicators)
                {
                    if (!_pendingChanges.ContainsKey(ind.Name))
                        _pendingChanges[ind.Name] = new(ind.Parameters);
                }
            }
        }
        catch
        {
        }
    }

    private async Task ApplyConfigAsync(string name)
    {
        if (!_pendingChanges.TryGetValue(name, out var parans)) return;
        var ind = _indicators.FirstOrDefault(i => i.Name == name);
        if (ind == null) return;

        try
        {
            await Http.PostAsJsonAsync("/api/indicator/config", new
            {
                Name = name,
                Enabled = ind.Enabled,
                Parameters = parans
            });
        }
        catch
        {
        }
    }

    private string GetColor(string key)
    {
        return _indicatorColors.TryGetValue(key, out var c) ? c : "";
    }

    private void SetColor(string key, string color)
    {
        _indicatorColors[key] = color;
        MarkDirty();
    }

    private bool GetVisible(string key)
    {
        return _indicatorVisible.TryGetValue(key, out var v) ? v : true;
    }

    private void SetVisible(string key, bool visible)
    {
        _indicatorVisible[key] = visible;
        MarkDirty();
    }

    public class IndicatorInfo
    {
        public string Name { get; set; } = "";
        public bool Enabled { get; set; }
        public int NeedsBarCount { get; set; }
        public Dictionary<string, double> Parameters { get; set; } = new();
    }
}

<MudDrawer Open="Open" Height="86vh" Width="400px" Anchor="MudBlazor.Anchor.Start" Variant="@DrawerVariant.Persistent">
    <MudPaper Class="pa-2" Outlined Elevation="0">
        <MudText Typo="Typo.subtitle2" Class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Size="Size.Small" Class="mr-1" />
            Indicadores
        </MudText>
    </MudPaper>

    @if (_indicators.Count == 0)
    {
        <MudPaper Class="pa-2 mt-1" Outlined Elevation="0">
            <MudText Typo="Typo.caption">Nenhum indicador disponível</MudText>
        </MudPaper>
    }

    @foreach (var ind in _indicators)
    {
        var hasChanges = _pendingChanges.TryGetValue(ind.Name, out var pendingParams)
            && pendingParams.Any(p => !ind.Parameters.TryGetValue(p.Key, out var v) || Math.Abs(v - p.Value) > 0.001);

        <MudPaper Class="pa-2 mt-1" Outlined Elevation="0">
            <MudStack Spacing="1">
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudSwitch @bind-Value="ind.Enabled" Size="Size.Small" Color="MudBlazor.Color.Primary" />
                        <MudText Typo="Typo.body2" Class="font-weight-bold">@ind.Name</MudText>
                    </MudStack>
                    <MudTooltip Text="Aplicar alterações">
                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Check"
                                       Color="@(hasChanges ? MudBlazor.Color.Success : MudBlazor.Color.Default)"
                                       Disabled="@(!hasChanges)"
                                       OnClick="@(() => ApplyConfigAsync(ind.Name))" />
                    </MudTooltip>
                </MudStack>

                <MudText Typo="Typo.caption" Class="text-medium">Período mínimo: @ind.NeedsBarCount candles</MudText>

                @if (_pendingChanges.TryGetValue(ind.Name, out var parans))
                {
                    @foreach (var (paramName, paramValue) in parans)
                    {
                        var pName = paramName;
                        var pValue = paramValue;
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.caption" Class="flex-1">@pName</MudText>
                            <MudNumericField @bind-Value="pValue"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Immediate="true"
                                             Step="@(pName == "Period" ? 1 : 0.5)"
                                             Min="@(pName == "Period" ? 2 : 0.1)"
                                             Max="@(pName == "Period" ? 200 : 10)"
                                             Class="flex-1" />
                        </MudStack>
                    }
                }

                @* Colors and visibility *@
                @{
                    var indicatorKeys = new[] { "Upper", "Middle", "Lower" };
                }
                @foreach (var key in indicatorKeys)
                {
                    var fullKey = $"{ind.Name}.{key}";
                    var keyColor = GetColor(fullKey);
                    var keyVisible = GetVisible(fullKey);
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.caption" Style="width: 60px">@key</MudText>
                        <MudTextField @bind-Value="keyColor"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      Placeholder="#rrggbb"
                                      Class="flex-1" />
                        <MudSwitch @bind-Value="keyVisible" Size="Size.Small" Color="MudBlazor.Color.Primary" />
                    </MudStack>
                }

                @* Latest values *@
                @if (_lastValues.Any(kv => kv.Key.StartsWith(ind.Name)))
                {
                    <MudDivider />
                    <MudText Typo="Typo.caption" Class="text-medium">Últimos valores:</MudText>
                    @foreach (var kv in _lastValues.Where(k => k.Key.StartsWith(ind.Name)))
                    {
                        <MudText Typo="Typo.caption" Style="padding-left: 8px">
                            @kv.Key.Substring(ind.Name.Length + 1): @kv.Value.ToString("F2", CultureInfo.InvariantCulture)
                        </MudText>
                    }
                }
            </MudStack>
        </MudPaper>
    }
</MudDrawer>
