@using System.Globalization
@using System.Net.Http.Json
@using B3WM.Shared.Models
@using B3WM.Shared.Models.Backtest
@using Vizor.ECharts
@inject NavigationManager Navigation
@inject HttpClient Http

@page "/backtest"

<MudTextField @bind-Value="config.Symbol" Label="Simbolo" Variant="Variant.Outlined" Dense="true" />
<MudSelect @bind-Value="config.TimeFrame" Label="TimeFrame" Variant="Variant.Outlined" Dense="true">
    <MudSelectItem Value="@("1")">1 min</MudSelectItem>
    <MudSelectItem Value="@("5")">5 min</MudSelectItem>
    <MudSelectItem Value="@("15")">15 min</MudSelectItem>
    <MudSelectItem Value="@("30")">30 min</MudSelectItem>
    <MudSelectItem Value="@("60")">60 min</MudSelectItem>
</MudSelect>
<MudSelect @bind-Value="config.StrategyName" Label="Estrategia" Variant="Variant.Outlined" Dense="true">
    <MudSelectItem Value="@StrategyType.Breakout">Breakout</MudSelectItem>
    <MudSelectItem Value="@StrategyType.SmartBreakout">SmartBreakout</MudSelectItem>
</MudSelect>
<MudDatePicker @bind-Date="startDate" Label="Data Inicio" Variant="Variant.Outlined" Dense="true" />
<MudDatePicker @bind-Date="endDate" Label="Data Fim" Variant="Variant.Outlined" Dense="true" />

<MudNumericField @bind-Value="config.StopLossPoints" Label="Stop Loss (pts)" Variant="Variant.Outlined" Dense="true" />
<MudNumericField @bind-Value="config.TakeProfitPoints" Label="Take Profit (pts)" Variant="Variant.Outlined" Dense="true" />
<MudNumericField @bind-Value="config.Quantity" Label="Quantidade" Variant="Variant.Outlined" Dense="true" />
<MudNumericField @bind-Value="config.LookbackPeriod" Label="Lookback" Variant="Variant.Outlined" Dense="true" />
<MudNumericField @bind-Value="config.SlippagePoints" Label="Slippage (pts)" Variant="Variant.Outlined" Dense="true" />
<MudNumericField @bind-Value="config.CommissionPerSide" Label="Corretagem (R$/lado)" Variant="Variant.Outlined" Dense="true" />

<MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="RunBacktest" Disabled="isRunning">
    @if (isRunning) { <MudProgressCircular Indeterminate Size="Size.Small" Class="mr-2" /> }
    Executar Backtest
</MudButton>

@if (errorMessage != null)
{
    <MudAlert Severity="MudBlazor.Severity.Error">@errorMessage</MudAlert>
}

@if (result != null)
{
    <MudText Typo="MudBlazor.Typo.h5">Resultados - @result.StrategyName</MudText>

    <MudPaper Class="pa-4 ma-2">
        <MudGrid>
            <MudItem xs="6" sm="4" md="2">
                <MudText Typo="MudBlazor.Typo.subtitle2">Win Rate</MudText>
                <MudText Typo="MudBlazor.Typo.h6" Color="@(result.WinRate >= 0.5 ? MudBlazor.Color.Success : MudBlazor.Color.Error)">
                    @(result.WinRate.ToString("P1", CultureInfo.InvariantCulture))
                </MudText>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudText Typo="MudBlazor.Typo.subtitle2">Net P&L (R$)</MudText>
                <MudText Typo="MudBlazor.Typo.h6" Color="@(result.NetProfit >= 0 ? MudBlazor.Color.Success : MudBlazor.Color.Error)">
                    @result.NetProfit.ToString("N2", CultureInfo.InvariantCulture)
                </MudText>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudText Typo="MudBlazor.Typo.subtitle2">Profit Factor</MudText>
                <MudText Typo="MudBlazor.Typo.h6">@result.ProfitFactor.ToString("N2", CultureInfo.InvariantCulture)</MudText>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudText Typo="MudBlazor.Typo.subtitle2">Total Trades</MudText>
                <MudText Typo="MudBlazor.Typo.h6">@result.TotalTrades</MudText>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudText Typo="MudBlazor.Typo.subtitle2">Max Drawdown</MudText>
                <MudText Typo="MudBlazor.Typo.h6" Color="MudBlazor.Color.Warning">
                    @result.MaxDrawdown.ToString("N2", CultureInfo.InvariantCulture)
                </MudText>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudText Typo="MudBlazor.Typo.subtitle2">Total Commission</MudText>
                <MudText Typo="MudBlazor.Typo.h6">@result.TotalCommission.ToString("N2", CultureInfo.InvariantCulture)</MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <div style="height:600px; width:100%;">
        <Vizor.ECharts.EChart @ref="EChart"
        Renderer="Vizor.ECharts.ChartRenderer.Canvas"
        Options="ChartOptions"
        Width="auto"
        Height="100%" />
    </div>

    <MudText Typo="MudBlazor.Typo.h6" Class="mt-4">Trades</MudText>
    <MudTable Items="@result.Trades" Dense="true" Hover="true" Striped="true" Elevation="1">
        <ColGroup>
            <col style="width: 40px;" />
            <col style="width: 80px;" />
            <col style="width: 50px;" />
            <col style="width: 90px;" />
            <col style="width: 90px;" />
            <col style="width: 100px;" />
            <col style="width: 70px;" />
            <col style="width: 90px;" />
        </ColGroup>
        <HeaderContent>
            <MudTh>#</MudTh>
            <MudTh>Entrada</MudTh>
            <MudTh>Side</MudTh>
            <MudTh>Entry Price</MudTh>
            <MudTh>Exit Price</MudTh>
            <MudTh>Motivo</MudTh>
            <MudTh>Pontos</MudTh>
            <MudTh>P&L (R$)</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="#">@(result.Trades.IndexOf(context) + 1)</MudTd>
            <MudTd DataLabel="Entrada">@context.EntryDate.ToString("dd/MM HH:mm")</MudTd>
            <MudTd DataLabel="Side">
                <MudChip T="string" Size="MudBlazor.Size.Small" Color="@(context.Side == OrderSide.Buy ? MudBlazor.Color.Success : MudBlazor.Color.Error)">
                    @(context.Side == OrderSide.Buy ? "BUY" : "SELL")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Entry">@context.EntryPrice.ToString("N2", CultureInfo.InvariantCulture)</MudTd>
            <MudTd DataLabel="Exit">@context.ExitPrice.ToString("N2", CultureInfo.InvariantCulture)</MudTd>
            <MudTd DataLabel="Motivo">
                <MudChip T="string" Size="MudBlazor.Size.Small" Color="@(GetExitColor(context.ExitReason))">
                    @GetExitLabel(context.ExitReason)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Pontos" Style="@(context.Points >= 0 ? "color: #4caf50;" : "color: #f44336;")">
                @(context.Points >= 0 ? "+" : "")@context.Points.ToString("N2", CultureInfo.InvariantCulture)
            </MudTd>
            <MudTd DataLabel="P&L" Style="@(context.ProfitLoss >= 0 ? "color: #4caf50;" : "color: #f44336;")">
                @(context.ProfitLoss >= 0 ? "+" : "")@context.ProfitLoss.ToString("N2", CultureInfo.InvariantCulture)
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private BacktestConfig config = new()
    {
        Symbol = "WINFUT",
        TimeFrame = 5,
        StrategyName = StrategyType.SmartBreakout,
        StartDate = DateTime.Today.AddDays(-5),
        EndDate = DateTime.Today,
        StopLossPoints = 200,
        TakeProfitPoints = 400,
        Quantity = 1,
        LookbackPeriod = 20,
        SlippagePoints = 0,
        CommissionPerSide = 0.90
    };

    private DateTime? startDate
    {
        get => config.StartDate;
        set { if (value.HasValue) config.StartDate = value.Value; }
    }

    private DateTime? endDate
    {
        get => config.EndDate;
        set { if (value.HasValue) config.EndDate = value.Value; }
    }

    private BacktestResult? result;
    private List<BarStorageItem> bars = new();
    private Vizor.ECharts.EChart? EChart;
    private Vizor.ECharts.ChartOptions ChartOptions = new();
    private bool isRunning;
    private string? errorMessage;

    private async Task RunBacktest()
    {
        isRunning = true;
        errorMessage = null;
        result = null;

        try
        {
            var barsTask = Http.GetFromJsonAsync<List<BarStorageItem>>(
                Navigation.ToAbsoluteUri($"/api/data/getbarrange/{config.Symbol}/{config.StartDate:yyyy-MM-dd}/{config.EndDate:yyyy-MM-dd}/{config.TimeFrame}").AbsoluteUri);

            var response = await Http.PostAsJsonAsync(
                Navigation.ToAbsoluteUri("/api/backtest/run").AbsoluteUri, config);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Erro API: {response.StatusCode}";
                return;
            }

            result = await response.Content.ReadFromJsonAsync<BacktestResult>();
            bars = await barsTask ?? new();

            BuildChart();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isRunning = false;
        }
    }

    private void BuildChart()
    {
        if (bars.Count == 0 || result == null) return;

        var inv = CultureInfo.InvariantCulture;
        var categoryData = bars.Select(b => b.Date.ToString("dd/MM HH:mm")).ToList();
        var values = bars.Select(b => new object[] { b.Open, b.Close, b.Low, b.High }).ToList();

        var minPrice = bars.Min(b => b.Low);
        var maxPrice = bars.Max(b => b.High);
        var priceRange = maxPrice - minPrice;
        if (priceRange <= 0) priceRange = 1;
        var padding = priceRange * 0.1;

        var buyEntryData = result.Trades
            .Where(t => t.Side == OrderSide.Buy)
            .Select(t => new object[] { t.EntryDate.ToString("dd/MM HH:mm"), t.EntryPrice })
            .ToList();

        var sellEntryData = result.Trades
            .Where(t => t.Side == OrderSide.Sell)
            .Select(t => new object[] { t.EntryDate.ToString("dd/MM HH:mm"), t.EntryPrice })
            .ToList();

        var winExitData = result.Trades
            .Where(t => t.ProfitLoss > 0)
            .Select(t => new object[] { t.ExitDate.ToString("dd/MM HH:mm"), t.ExitPrice, GetExitLabel(t.ExitReason) })
            .ToList();

        var lossExitData = result.Trades
            .Where(t => t.ProfitLoss <= 0)
            .Select(t => new object[] { t.ExitDate.ToString("dd/MM HH:mm"), t.ExitPrice, GetExitLabel(t.ExitReason) })
            .ToList();

        var seriesList = new List<ISeries>();

        seriesList.Add(new CandlestickSeries
        {
            Name = "Candle",
            Data = values,
            Z = 2,
            ItemStyle = new ItemStyle { Color = "#ffffff", Color0 = "#000000", BorderColor = "#ffffff", BorderColor0 = "#ffffff" }
        });

        if (buyEntryData.Count > 0)
        {
            seriesList.Add(new ScatterSeries
            {
                Name = "Buy Entry",
                Data = buyEntryData,
                Symbol = "diamond",
                SymbolSize = 14,
                Z = 5,
                ItemStyle = new ItemStyle { Color = "#4caf50", BorderColor = "#ffffff", BorderWidth = 2 }
            });
        }

        if (sellEntryData.Count > 0)
        {
            seriesList.Add(new ScatterSeries
            {
                Name = "Sell Entry",
                Data = sellEntryData,
                Symbol = "diamond",
                SymbolSize = 14,
                Z = 5,
                ItemStyle = new ItemStyle { Color = "#f44336", BorderColor = "#ffffff", BorderWidth = 2 }
            });
        }

        if (winExitData.Count > 0)
        {
            seriesList.Add(new ScatterSeries
            {
                Name = "Win Exit",
                Data = winExitData,
                Symbol = "circle",
                SymbolSize = 10,
                Z = 5,
                ItemStyle = new ItemStyle { Color = "#4caf50", BorderColor = "#ffffff", BorderWidth = 2 }
            });
        }

        if (lossExitData.Count > 0)
        {
            seriesList.Add(new ScatterSeries
            {
                Name = "Loss Exit",
                Data = lossExitData,
                Symbol = "circle",
                SymbolSize = 10,
                Z = 5,
                ItemStyle = new ItemStyle { Color = "#f44336", BorderColor = "#ffffff", BorderWidth = 2 }
            });
        }

        ChartOptions = new Vizor.ECharts.ChartOptions
        {
            Grid = new Vizor.ECharts.Grid { Left = "60", Right = "20", Bottom = "30", Top = "10", ContainLabel = true },
            Tooltip = new Tooltip
            {
                Trigger = TooltipTrigger.Axis,
                Formatter = new JavascriptFunction(
                    "function(params) {" +
                    "var html = '<b>' + params[0].name + '</b><br/>';" +
                    "params.forEach(function(p) {" +
                    "if (p.seriesName.indexOf('Candle') >= 0 && p.data) {" +
                    "html += 'O: ' + p.data[1] + ' C: ' + p.data[2] + ' L: ' + p.data[3] + ' H: ' + p.data[4] + '<br/>';" +
                    "} else {" +
                    "html += p.seriesName + ' @ ' + p.data[1] + '<br/>';" +
                    "}});" +
                    "return html;}")
            },
            XAxisList = new List<XAxis>
            {
                new XAxis { Type = AxisType.Category, Data = categoryData, BoundaryGap = true,
                    AxisPointer = new AxisPointer { Show = true } }
            },
            YAxisList = new List<YAxis>
            {
                new YAxis { Type = AxisType.Value, Scale = true, Min = minPrice - padding, Max = maxPrice + padding,
                    AxisPointer = new AxisPointer { Show = true },
                    SplitLine = new SplitLine { Show = true, LineStyle = new LineStyle { Color = "rgba(128,128,128,0.05)" } } }
            },
            DataZoom = new List<IDataZoom>
            {
                new InsideDataZoom { XAxisIndex = new[] { 0.0 } },
                new SliderDataZoom { XAxisIndex = new[] { 0.0 }, Bottom = "0" }
            },
            Series = seriesList
        };
    }

    private static MudBlazor.Color GetExitColor(ExitReason reason) => reason switch
    {
        ExitReason.StopLoss => MudBlazor.Color.Error,
        ExitReason.TakeProfit => MudBlazor.Color.Success,
        ExitReason.StrategySignal => MudBlazor.Color.Info,
        ExitReason.EndOfData => MudBlazor.Color.Warning,
        _ => MudBlazor.Color.Default
    };

    private static string GetExitLabel(ExitReason reason) => reason switch
    {
        ExitReason.StopLoss => "Stop",
        ExitReason.TakeProfit => "Gain",
        ExitReason.StrategySignal => "Estrategia",
        ExitReason.EndOfData => "Fim",
        _ => reason.ToString()
    };
}
