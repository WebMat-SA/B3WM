    // =========================
    // GERAR GRÁFICO
    // =========================
    private async Task GenerateChart()
    {
        if (EChart is null)
            return;

        var categoryData = new List<string>();
        var values = new List<object[]>();

        foreach (var row in RawData)
        {
            categoryData.Add(row[0].ToString()!);
            values.Add(new object[]
            {
                row[1], // open
                row[2], // close
                row[3], // low
                row[4]  // high
            });
        }

        ChartOptions.Tooltip = new Tooltip
        {
            Trigger = TooltipTrigger.Axis,
            AxisPointer = new AxisPointer
            {
                Type = AxisPointerType.Cross
            }
        };

        // Update legend to include both scatter series
        ChartOptions.Legend = new Legend
        {
            Data = new List<string> { "Candle", "Aggressive Short", "Aggressive Long" },
            Top = "20"
        };

        ChartOptions.XAxis = new XAxis
        {
            Type = AxisType.Category,
            Data = categoryData,
            BoundaryGap = false,
            Min = "dataMin",
            Max = "dataMax"
        };

        ChartOptions.YAxis = new YAxis
        {
            Scale = true,
            SplitArea = new SplitArea
            {
                Show = true
            }
        };

        // ⚠️ IDataZoom (não DataZoom)
        ChartOptions.DataZoom = new List<IDataZoom>
        {
            new InsideDataZoom
            {
                Start = 50,
                End = 100
            },
            new SliderDataZoom
            {
                Top = "90%",
                Start = 50,
                End = 100
            }
        };

        // Prepare bubble scatter data split in half
        var bubbleData = RawDataBubble;
        var mid = bubbleData.Count / 2;
        var dataRed = bubbleData.Take(mid).ToList();
        var dataBlue = bubbleData.Skip(mid).ToList();

        var symbolSizeFunction = new NumberArrayOrFunction(
            new JavascriptFunction(
            @"function (value) {
                        return value[2] * 2;
                    }")
        );

        ChartOptions.Series = new List<ISeries>
        {
            new CandlestickSeries
            {
                Name = "日K",
                Data = values,
                ItemStyle = new ItemStyle
                {
                    Color = "#ffffff",
                    Color0 = "#000000",
                    BorderColor = "#000000",
                    BorderColor0 = "#ffffff"
                }
            },

            new ScatterSeries
            {
                Name = "Aggressive Red",
                Data = dataRed,
                SymbolSize = symbolSizeFunction,
                ItemStyle = new ItemStyle
                {
                    Color = "#ff0000",
                    Opacity = 0.3,
                    BorderColor = "#ff0000",
                    BorderWidth = 1,
                }
            },

            new ScatterSeries
            {
                Name = "Aggressive Blue",
                Data = dataBlue,
                SymbolSize = symbolSizeFunction,
                ItemStyle = new ItemStyle
                {
                    Color = "#0000ff",
                    Opacity = 0.3,
                    BorderColor = "#0000ff",
                    BorderWidth = 1,

                }
            }
        };

        await EChart.UpdateAsync();
    }
