@page "/graph2"

@using Vizor.ECharts
@using System.Linq

<MudButton Variant="Variant.Filled" OnClick="GenerateChart">
    Gerar gráfico
</MudButton>

<Vizor.ECharts.EChart @ref="EChart"
                      Renderer="ChartRenderer.Canvas"
                      Options="ChartOptions"
                      Width="auto"
                      Height="600px" />

@code {
    private EChart? EChart;

    private Vizor.ECharts.ChartOptions ChartOptions = new Vizor.ECharts.ChartOptions
    {
        DarkMode = true
    };

    private List<object[]> RawData = new();
    private List<object[]> RawDataBubble = new();

    protected override void OnInitialized()
    {
        // ======= GERAR DADOS FAKES =======
        var random = new Random();
        DateTime start = new DateTime(2023, 1, 1);

        for (int i = 0; i < 50; i++)
        {
            var open = random.Next(2000, 2500);
            var close = open + random.Next(-50, 50);
            var low = Math.Min(open, close) - random.Next(10, 30);
            var high = Math.Max(open, close) + random.Next(10, 30);
            RawData.Add(new object[] { start.AddDays(i).ToString("yyyy/MM/dd"), open, close, low, high });

            var volume = random.Next(1, 100);
            RawDataBubble.Add(new object[] { start.AddDays(i).ToString("yyyy/MM/dd"), close, volume });
        }
    }

    private async Task GenerateChart()
    {
        if (EChart is null)
            return;

        // ======= CATEGORIA E VALORES CANDLE =======
        var categoryData = RawData.Select(r => r[0].ToString()!).ToList();
        var candleValues = RawData.Select(r => new object[] { r[1], r[2], r[3], r[4] }).ToList();

        // ======= GRID =======
        ChartOptions.Grid = new Vizor.ECharts.Grid
        {
            Left = "10%",
            Right = "20%", // espaço para volume
            Top = "10",
            Bottom = "15",
            ContainLabel = true
        };

        // ======= XAxis =======
        ChartOptions.XAxisList = new List<XAxis>
        {
            new XAxis
            {
                Type = AxisType.Category,
                Data = categoryData,
                BoundaryGap = false,
                GridIndex = 0
            },
            new XAxis
            {
                Type = AxisType.Value,
                GridIndex = 1,
                Position = TopOrBottom.Top,
                SplitLine = new SplitLine { Show = false }
            }
        };

        // ======= YAxis =======
        ChartOptions.YAxisList = new List<YAxis>
        {
            new YAxis
            {
                Scale = true,
                GridIndex = 0,
                SplitArea = new SplitArea { Show = true }
            },
            new YAxis
            {
                Scale = true,
                GridIndex = 1,
                Position = LeftOrRight.Right,
                AxisLabel = new AxisLabel { Show = false },
                SplitLine = new SplitLine { Show = false }
            }
        };

        // ======= Tooltip =======
        ChartOptions.Tooltip = new Tooltip
        {
            Trigger = TooltipTrigger.Axis,
            AxisPointer = new AxisPointer { Type = AxisPointerType.Cross }
        };

        // ======= DataZoom =======
        ChartOptions.DataZoom = new List<IDataZoom>
        {
            new InsideDataZoom { Start = 50, End = 100 },
            new SliderDataZoom { Top = "90%", Start = 50, End = 100 }
        };

        // ======= Agrupar volume por preço =======
        var volumeByPrice = RawDataBubble
            .GroupBy(x => Convert.ToDecimal(x[1])) // price
            .Select(g => new { Price = g.Key, Volume = g.Sum(v => Convert.ToDecimal(v[2])) })
            .OrderBy(x => x.Price)
            .ToList();

        var volumeSeriesData = volumeByPrice.Select(x => new object[] { x.Volume, x.Price }).ToList();

        // ======= Symbol Size Function para Bubbles =======
        var symbolSizeFunction = new NumberArrayOrFunction(
            new JavascriptFunction(@"function (value) { return value[2] * 2; }")
        );

        // ======= SERIES =======
        ChartOptions.Series = new List<ISeries>
        {
            // Candle
            new CandlestickSeries
            {
                Name = "Candle",
                Data = candleValues,
                ItemStyle = new ItemStyle
                {
                    Color = "#ffffff",
                    Color0 = "#000000",
                    BorderColor = "#000000",
                    BorderColor0 = "#ffffff"
                }
            },

            // Scatter Bubbles
            new ScatterSeries
            {
                Name = "Bubbles",
                Data = RawDataBubble,
                SymbolSize = symbolSizeFunction,
                ItemStyle = new ItemStyle
                {
                    Color = "#ff0000",
                    Opacity = 0.3,
                    BorderColor = "#ff0000",
                    BorderWidth = 1
                }
            },

            // Volume por preço (horizontal)
            new BarSeries
            {
                Name = "Volume by Price",
                XAxisIndex = 1,
                YAxisIndex = 1,
                Data = volumeSeriesData,
                BarWidth = "80%",
                ItemStyle = new ItemStyle
                {
                    Color = "#888888"
                }
            }
        };

        await EChart.UpdateAsync();
    }
}
