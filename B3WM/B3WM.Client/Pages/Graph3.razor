@page "/graph3"
@using Vizor.ECharts
@using System.Linq

<MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="GenerateChart" Class="mb-4">
    Gerar Gráfico Pro (Custom Render)
</MudButton>

<div style="background-color: #1a1a1a; padding: 20px; border-radius: 8px;">
    <Vizor.ECharts.EChart @ref="EChart"
                          Renderer="ChartRenderer.Canvas"
                          Options="ChartOptions"
                          Width="auto"
                          Height="600px" />
</div>

@code {
    private EChart? EChart;
    private Vizor.ECharts.ChartOptions ChartOptions = new();

    private List<object[]> RawData = new();
    private List<VolumeLevel> VolumeLevels = new();
    private int PriceStep = 10; // A altura de cada faixa de volume (ex: agrupado de 10 em 10 reais)

    protected override void OnInitialized()
    {
        var random = new Random();
        DateTime start = new DateTime(2023, 1, 1);

        // 1. Mock Candles
        for (int i = 0; i < 60; i++)
        {
            var open = random.Next(2000, 2500);
            var close = open + random.Next(-50, 50);
            var low = Math.Min(open, close) - random.Next(10, 30);
            var high = Math.Max(open, close) + random.Next(10, 30);
            RawData.Add(new object[] { start.AddDays(i).ToString("yyyy/MM/dd"), open, close, low, high });
        }

        // 2. Mock Volume (Agrupado por PriceStep)
        // Importante: O Price deve ser o centro da barra ou a base, manteremos consistência.
        for (int p = 1950; p <= 2550; p += PriceStep)
        {
            VolumeLevels.Add(new VolumeLevel
            {
                Price = p, // Centro da faixa
                Total = random.Next(100, 1000)
            });
        }
    }

    private async Task GenerateChart()
    {
        if (EChart is null) return;

        // --- CÁLCULO DE LIMITES PARA SINCRONIA PERFEITA ---
        var allPrices = RawData.SelectMany(r => new[] { (double)(int)r[3], (double)(int)r[4] })
                               .Concat(VolumeLevels.Select(v => v.Price))
                               .ToList();

        double minPrice = allPrices.Min();
        double maxPrice = allPrices.Max();

        // Padding de 5% para o gráfico não bater no teto/chão
        double padding = (maxPrice - minPrice) * 0.05;
        minPrice -= padding;
        maxPrice += padding;

        var maxVolume = VolumeLevels.Max(v => v.Total);
        // --------------------------------------------------

        ChartOptions.DarkMode = true;
        ChartOptions.BackgroundColor = "transparent";

        // Único Grid
        ChartOptions.Grid = new Grid
        {
            Left = "5%",
            Right = "15%", // Espaço para as barras virem da direita
            Bottom = "15%",
            ContainLabel = true
        };

        // EIXOS X
        ChartOptions.XAxisList = new List<XAxis>
        {
            // X[0]: Tempo (Candles)
            new XAxis { Type = AxisType.Category, Data = RawData.Select(r => r[0].ToString()).ToList(), BoundaryGap = true },

            // X[1]: Volume (Invisível)
            new XAxis
            {
                Type = AxisType.Value,
                Show = false,
                Min = 0,
                Max = maxVolume * 3, // *3 para a barra ocupar no máximo 1/3 da tela
                Inverse = true // IMPORTANTE: Faz o eixo começar na direita (0 na direita)
            }
        };

        // EIXOS Y (DEVEM SER IDÊNTICOS EM MIN/MAX)
        ChartOptions.YAxisList = new List<YAxis>
        {
            // Y[0]: Preço (Esquerda)
            new YAxis
            {
                Type = AxisType.Value,
                Scale = true,
                Min = minPrice,
                Max = maxPrice
            },

            // Y[1]: Preço (Direita - Usado pelo Custom Series)
            new YAxis
            {
                Type = AxisType.Value,
                Position = LeftOrRight.Right,
                Min = minPrice, // Sincronia: Mesmo min
                Max = maxPrice, // Sincronia: Mesmo max
                AxisLabel = new AxisLabel { Color = "#aaa", FontSize = 10 },
                SplitLine = new SplitLine { Show = false } // Remove linhas duplicadas
            }
        };

        ChartOptions.Series = new List<ISeries>
        {
            // 1. Candles
            new CandlestickSeries
            {
                Name = "Preço",
                Data = RawData.Select(r => new object[] { r[1], r[2], r[3], r[4] }).ToList(),
                ItemStyle = new ItemStyle { Color = "#00fa9a", Color0 = "#ff4500" }
            },

            // 2. Volume Profile (CUSTOM SERIES)
            new CustomSeries
            {
                Name = "Volume Profile",
                XAxisIndex = 1, // Usa eixo X invertido (Value)
                YAxisIndex = 1, // Usa eixo Y da direita (Value)

                // Dados: [Volume, Preço, AlturaDaFaixa]
                Data = VolumeLevels.Select(v => new object[] { v.Total, v.Price, PriceStep }).ToList(),

                // A MÁGICA ACONTECE AQUI:
                RenderItem = new JavascriptFunction(@"
                    function (params, api) {
                        // 1. Pegar dados
                        var volumeVal = api.value(0);
                        var priceVal = api.value(1);
                        var stepVal = api.value(2); // O tamanho da faixa (10 reais)

                        // 2. Converter Volume (X) e Preço (Y) para Pixels
                        // coord([0, price]) = Ponto na parede direita (pois eixo X é Inverse=true)
                        var start = api.coord([0, priceVal]);

                        // coord([volume, price]) = Ponto onde a barra termina (para a esquerda)
                        var end = api.coord([volumeVal, priceVal]);

                        // 3. Calcular a altura da barra em Pixels
                        // api.size([0, stepVal]) retorna [larguraPx, alturaPx] correspondente a 'stepVal' unidades no eixo Y
                        var size = api.size([0, stepVal]);
                        var barHeight = size[1];

                        // 4. Desenhar o Retângulo
                        return {
                            type: 'rect',
                            shape: {
                                x: end[0],              // Começa na ponta esquerda (menor pixel X)
                                y: start[1] - barHeight / 2, // Centraliza no Y do preço
                                width: start[0] - end[0],    // A largura é a distância entre 0 e Volume
                                height: barHeight       // Altura dinâmica baseada no zoom!
                            },
                            style: api.style()
                        };
                    }
                "),
                ItemStyle = new ItemStyle {
                    Color = "rgba(0, 150, 255, 0.3)", // Azul transparente
                    BorderColor = "rgba(0, 150, 255, 0.8)",
                    BorderWidth = 1
                },
                Z = 0 // Fica atrás dos candles
            }
        };

        await EChart.UpdateAsync();
    }

    public class VolumeLevel
    {
        public double Price { get; set; }
        public int Total { get; set; }
    }
}