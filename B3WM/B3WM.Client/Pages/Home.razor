@using BlazorWorker.BackgroundServiceFactory
@using BlazorWorker.Core 
@using BlazorWorker.WorkerBackgroundService 
@using Microsoft.AspNetCore.SignalR.Client
@using System.Diagnostics
@inject NavigationManager Navigation
@inject IWorkerFactory workerFactory

@page "/"

<MudButton OnClick="Init">Start Hub</MudButton>

@text

@code{


    public string text { get; set; } = string.Empty;

    private IWorker? MainWorker;
    private IWorkerBackgroundService<HubClientWorker>? MainService { get; set; }

    protected override async Task OnInitializedAsync()
    {


        if (MainWorker == null)
            MainWorker = await workerFactory.CreateAsync();

    }

    public async void Init()
    {
        if (MainService != null)
            await MainService.RunAsync(e => e.Init(Navigation.ToAbsoluteUri("/api/datahub").AbsoluteUri, 500));

        Console.WriteLine("Initi worker");
    }

    

}