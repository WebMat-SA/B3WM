@page "/imports"
@using B3WM.Client.Model
@using BlazorWorker.Core
@inject IWorkerFactory workerFactory

<MudGrid>
    <MudItem md="12">
        <MudStack Row Wrap="Wrap.Wrap" Spacing="8" AlignItems="AlignItems.Center" Justify="Justify.Center">
            <MudText Typo="Typo.h6">Arquivos </MudText>
            <MudFileUpload @ref="_fileUploadMultiple"
               T="IReadOnlyList<IBrowserFile>"
               Files="_browserFiles"
               FilesChanged="OnFilesChanged"
               Accept=".csv"
               AppendMultipleFiles
               SelectedTemplate="@(files => builder => { })" />

        </MudStack>
    </MudItem>

    <MudItem xs="12">
        <MudDataGrid MultiSelection=true EditMode="DataGridEditMode.Cell" T="ImportNode" Items=_files
                     Filterable="true" QuickFilter="@_quickFilter" Elevation="0" @bind-SelectedItems="_selectedDataImports" ReadOnly="false"
                     Dense="true">
            <ToolBarContent>
                    @* <MudText Typo="Typo.h6">Arquivos</MudText> *@
                    <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                        AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    <MudSpacer /> 
                    <MudSpacer /> 
                    <MudSpacer /> 
            </ToolBarContent>

            <Columns>
                <SelectColumn T="ImportNode" DisabledFunc="x=>x.Processed || x.Processing" />
                <PropertyColumn Property="x => x.File.Name" Title="Nome" Editable="false" InitialDirection="SortDirection.Ascending">
                    <CellTemplate>
                        <MudStack Row Justify="Justify.SpaceBetween" Spacing="0">
                            @if (context.Item.Processing)
                            {
                                <MudProgressCircular Indeterminate Size="Size.Small"></MudProgressCircular>
                            }
                            @context.Item.File?.Name
                            @if (context.Item.Processed)
                            {
                                <MudTooltip Text="Processado com sucesso">
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" />
                                </MudTooltip>
                            }
                        </MudStack>
                    </CellTemplate>
                </PropertyColumn>
                <PropertyColumn Property="x => x.MbSize" Title="Tamanho" Editable="false" InitialDirection="SortDirection.Ascending">
                    <CellTemplate>
                        @context.Item.MbSize Mb
                    </CellTemplate>
                </PropertyColumn>
                <PropertyColumn Property="x => x.Symbol" Title="Papel" Editable="true">
                    <EditTemplate>
                        <MudTextField @bind-Value="context.Item.Symbol" @onclick:stopPropagation="true" Disabled="context.Item.Processing || context.Item.Processed" />
                    </EditTemplate>
                </PropertyColumn>
                <PropertyColumn Property="x => x.Date" Title="Data de referência" Editable="true">
                    <EditTemplate>
                        <MudDatePicker @bind-Date="context.Item.Date" @onclick:stopPropagation="true" ShowToolbar="false" Elevation="0" Disabled="context.Item.Processing || context.Item.Processed" />
                    </EditTemplate>
                </PropertyColumn>

                <TemplateColumn>
                    <EditTemplate>
                        <MudStack Row Spacing="1" Justify="Justify.Center">
                            <MudTooltip Text="Remover item da lista">
                                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" Disabled="@(context.Item.Processing)" OnClick="@(() => RemoveFileAsync(context.Item))" />
                            </MudTooltip>
                            <MudTooltip Text="Processar item">
                                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Hexagon" Disabled="@(context.Item.Processing || context.Item.Processed)" OnClick="@(() => ProcessItemAsync(context.Item))" />
                            </MudTooltip>
                            <MudTooltip Text="Enviar para o grafico">
                                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.AutoGraph" Disabled="@(!context.Item.Processed && !context.Item.Processing)" OnClick="@(() => SendToGraphItemAsync(context.Item))" />
                            </MudTooltip>
                            <MudTooltip Text="Debug (Console)">
                                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Construction" Disabled="@(!context.Item.Processed && !context.Item.Processing)" OnClick="@(() => context.Item.PrintDebug())" />
                            </MudTooltip>
                        </MudStack>
                    </EditTemplate>
                </TemplateColumn>
            </Columns>

            <PagerContent>

                <MudStack Row Justify="Justify.FlexEnd" Spacing="2" Class="pa-2 w-100">

                    @* <MudText Typo="Typo.body2">
                        Selecionados: <b>@(_selectedDataImports?.Count ?? 0)</b>
                    </MudText> *@


                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Disabled="@(!(_selectedDataImports?.Any(q=> !q.Processing) ?? false))"
                               StartIcon="@Icons.Material.Filled.Delete"
                               OnClick="RemoveAllFileAsync" Style="min-width: 150px;">

                        Remover
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@(!(_selectedDataImports?.Any(q=>!q.Processed && !q.Processing) ?? false))"
                               StartIcon="@Icons.Material.Filled.Hexagon"
                               OnClick="ProcessAllFileAsync" Style="min-width: 150px;">

                        Processar
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@((_selectedDataImports?.Any(q=>!q.Processed && !q.Processing) ?? true))"
                               StartIcon="@Icons.Material.Filled.Hexagon"
                               OnClick="SendToGraphAllAsync" Style="min-width: 150px;">

                        Grafico
                    </MudButton>

                </MudStack>

            </PagerContent>
            
        </MudDataGrid>
    </MudItem>
</MudGrid>
@code
{
    [CascadingParameter]
    public string Symbol { get; set; }

    [Parameter, EditorRequired]
    public int TimeFrame { get; set; }

    [Parameter, EditorRequired]
    public int ThresholdBubble { get; set; }

    [Parameter]
    public Func<IEnumerable<BarStorageItem>, Task> NotifyNewBars { get; set; } = default!;

    // quick filter - filter globally across multiple columns with the same input
    private Func<ImportNode, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.File != null && x.File.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    };

    private string _searchString;

    public List<ImportNode> _files { get; set; } = new();
    private IReadOnlyList<IBrowserFile> _browserFiles = [];
    private MudFileUpload<IReadOnlyList<IBrowserFile>> _fileUploadMultiple = default!;
    private HashSet<ImportNode>? _selectedDataImports { get; set; }

    private void SyncFiles()
    {
        // arquivos ainda presentes no upload
        var currentFiles = _browserFiles.ToHashSet();

        // remove itens cujo arquivo não existe mais
        _files.RemoveAll(x => !currentFiles.Contains(x.File));

        // adiciona novos arquivos que ainda não existem
        foreach (var file in _browserFiles)
        {
            if (!_files.Any(x => x.File == file))
            {
                _files.Add(new ImportNode(
                    file,
                    ImportNode.TryExtractDateFromFileName(file.Name),
                    ImportNode.TryExtractSymbolFromFileName(file.Name, Symbol),
                    workerFactory));
            }
        }
    }

    private Task OnFilesChanged(IReadOnlyList<IBrowserFile>? files)
    {
        if (files == null || files.Count == 0)
            return Task.CompletedTask;

        _browserFiles = files;

        SyncFiles();

        return Task.CompletedTask;
    }

    private async Task ProcessAllFileAsync()
    {
        if (_selectedDataImports == null) return;

        foreach (var item in _selectedDataImports)
        {
            _ = ProcessItemAsync(item);
        }
    }

    private async Task ProcessItemAsync(ImportNode item)
    {
        item.Processing = true;

        //aguarda o processamento
        await item.Process(TimeFrame, ThresholdBubble);

        item.Processing = false;
        item.Processed = true;

        if (_selectedDataImports?.Contains(item) == true)
        {
            _selectedDataImports = new HashSet<ImportNode>(
                _selectedDataImports.Where(x => x != item)
            );
        }
        StateHasChanged();
    }

    private async Task RemoveAllFileAsync()
    {
        if (_selectedDataImports is null || _selectedDataImports.Count == 0)
            return;

        var items = _selectedDataImports.ToList();

        // Remove do componente upload
        foreach (var item in items)
            await _fileUploadMultiple.RemoveFileAsync(item.File);

        // Atualiza fonte de dados
        _browserFiles = _browserFiles
            .Where(f => !items.Any(i => i.File == f))
            .ToList();

        _selectedDataImports.Clear();

        SyncFiles();
    }

    private async Task RemoveFileAsync(ImportNode item)
    {
        await _fileUploadMultiple.RemoveFileAsync(item.File);

        // Atualiza fonte
        _browserFiles = _browserFiles
            .Where(f => f != item.File)
            .ToList();

        SyncFiles();
    }

    private async Task SendToGraphAllAsync()
    {
        if (_selectedDataImports == null) return;

        foreach (var item in _selectedDataImports)
        {
            _ = SendToGraphItemAsync(item);
        }
    }

    private async Task SendToGraphItemAsync(ImportNode item)
    {
        if (NotifyNewBars != null) await NotifyNewBars.Invoke(item.Bars.ToList());
    }
}