    private static Shared.Models.BarStorageItem CloneBar(Shared.Models.BarStorageItem bar)
    {
        return new Shared.Models.BarStorageItem
        {
            Date = bar.Date,
            Open = bar.Open,
            High = bar.High,
            Low = bar.Low,
            Close = bar.Close,
            Volume = bar.Volume,
            VolumeLevel = bar.VolumeLevel
        };
    }

    public Task NewBar(Shared.Models.BarStorageItem bar)
    {
        var count = BarStorageItem.Count;
        var isFullRange = count > 0 && _dateRange.End >= count;

        var sw = Stopwatch.StartNew();

        if (bar == null || bar.Date == default) return Task.CompletedTask;

        var existing = BarStorageItem.FirstOrDefault(b => b.Date == bar.Date);
        if (existing != null)
        {
            existing.Open = bar.Open;
            existing.High = bar.High;
            existing.Low = bar.Low;
            existing.Close = bar.Close;
            existing.Volume = bar.Volume;
            _barsDataVersion++;
        }
        else
        {
            // Cópia defensiva: armazenar nossa própria instância para não depender da referência do callback.
            BarStorageItem.Add(CloneBar(bar));
            _barsDataVersion++;
        }


        if (isFullRange)
        {
            _dateRange = new MudExRange<int>(_dateRange.Start, BarStorageItem.Count);
            ApplyVolumeFilter(_dateRange);
        }
        sw.Stop();
        HelperPerformanceConfig.Log(nameof(MapFlow), "NewBar total", sw.ElapsedMilliseconds);
        return Task.CompletedTask;
    }

    public Task NewCurrentBar(Shared.Models.BarStorageItem bar)
    {
        var sw = Stopwatch.StartNew();

        CurrentBar = bar;
        _currentBarVersion++;

        //_cachecount = HubClient?.GetCacheCount();

        if (_cachecount >= 2)
        {
            //notifica somente o filho, para não dar gargalo de renderizar o gráfico (que é mais pesado) a cada atualização de barra, já que o gráfico só precisa ser atualizado quando as barras históricas mudam ou quando o usuário interage com o filtro de volume.
            //if (MapFlowBar != null) await MapFlowBar.NotifyChanges();

            HelperPerformanceConfig.Log(nameof(MapFlow), "NewCurrentBar skipped UI update", sw.ElapsedMilliseconds, $"HubClient.ChannelTOdo: {_cachecount}");
            return Task.CompletedTask;
        }

        if (EChart != null)
        {
            _ = GenerateChart();
        }


        sw.Stop();
        HelperPerformanceConfig.Log(nameof(MapFlow), "NewCurrentBar total", sw.ElapsedMilliseconds);


        return Task.CompletedTask;
    }

    public Task NewBubble(Shared.Models.BubbleStorageItem data)
    {
        var sw = Stopwatch.StartNew();
        if (_allBubbleAgents.Add((Ticks2.Agents)data.Agent) && !SelectedAgents.Contains((Ticks2.Agents)data.Agent))
            SelectedAgents.Add((Ticks2.Agents)data.Agent);
        Bubbles.Add(data);
        _bubbleDataVersion++;
        MapFlowBubbleDrawer?.ForceUpdate();
        sw.Stop();
        //HelperPerformanceConfig.Log(nameof(MapFlow),"NewBubble total", sw.ElapsedMilliseconds);

        return Task.CompletedTask;
        //await InvokeAsync(StateHasChanged);
    }

    public Task VolumeUpdate(Shared.Models.VolumeLevelStorageItem volumes)
    {
        try{

            var sw = Stopwatch.StartNew();
            VolumeLevels = volumes.Volumes as List<VolumeLevel> ?? volumes.Volumes.ToList();
            _volumeDataVersion++;

            var count = BarStorageItem.Count;
            var isFullRange = count > 0 && _dateRange.End >= count;

            if (isFullRange && ProfileAutoByPriceStructure)
            {
                var startBar = BarStorageItem.ElementAtOrDefault(Math.Max(0, _dateRange.Start - 1));
                _filteredVolumeLevels = Shared.Models.VolumeLevelStorageItem.Operation(volumes.Volumes ?? new(), startBar.VolumeLevel ?? new(), "Diff").OrderBy(q => q.Price).ToList();
                _volumeFilterActive = true;
                _filteredVolumeDataVersion++;
            }

            sw.Stop();
        }
        catch(Exception e)
        {
            Console.WriteLine("VolumeUpdate Error" + e.Message);
        }

        return Task.CompletedTask;
    }

    public Task NewStructure(Shared.Models.StructureStorageItem structure)
    {
        //se opção de calcular pontos de filtro estiver ativa, calcular quais são os start e end do applyvolume filter.
        if (ProfileAutoByPriceStructure)
            UpdateFilterVolumeByPriceStructure(structure);

        StructureStorageItem.Add(structure);
        _structureDataVersion++; // mark structures changed
        return Task.CompletedTask;
    }

    public Task NewStructureVolume(Shared.Models.StructureVolumeStorageItem structure)
