    private string IndexEndToDateStringBars(IRange<int> range)
    {
        string format = BarStorageItem.ElementAtOrDefault(range.End)?.Date.Date == BarStorageItem.ElementAtOrDefault(range.Start)?.Date.Date ? "HH:mm" : "dd/MM HH:mm";

        return $" {BarStorageItem.ElementAtOrDefault(range.End)?.Date.ToString(format)}";
    }
    private string IndexStartToDateStringBars(IRange<int> range)
    {
        string format = BarStorageItem.ElementAtOrDefault(range.End)?.Date.Date == BarStorageItem.ElementAtOrDefault(range.Start)?.Date.Date ? "HH:mm" : "dd/MM HH:mm";
        return $"{BarStorageItem.ElementAtOrDefault(range.Start)?.Date.ToString(format)}";
    }
    private void ApplyVolumeFilter(IRange<int> newRange)
    {
        ///refazer aqui...
        _dateRange = newRange;

        var count = BarStorageItem.Count;
        if (count == 0) return;

        // Range contempla todas as barras = sem filtro: manter gráfico atual (volume já condizente com todo o período).
        var isFullRange = newRange.Start == 0 && newRange.End >= count ;
        if (isFullRange)
        {
            _volumeFilterActive = false;
            _filteredVolumeLevels = null;
        }
        else
        {
            var bars = BarStorageItem.OrderBy(q => q.Date).ToList();

            var startBar = bars.ElementAtOrDefault(Math.Max(0,newRange.Start - 1));
            var endBar = bars.ElementAtOrDefault(newRange.End);
            // if (startBar != null && endBar != null && HubClient != null)
            // {
            //     //_filteredVolumeLevels = VolumeLevelStorageItem.FromTo(bars, startBar.Date, endBar.Date);
            //     _filteredVolumeLevels = Client.Model.VolumeLevelStorageItem.Operation(endBar.VolumeLevel ?? new(), startBar.VolumeLevel ?? new(), "Diff").OrderBy(q => q.Price).ToList();
            //     _volumeFilterActive = true;
            //     _filteredVolumeDataVersion++;
            // }
        }

        StateHasChanged();
    }

    public void UpdateFilterVolumeByPriceStructure(Shared.Models.StructureStorageItem structure)
    {
        var lastStructure = StructureStorageItem.LastOrDefault();
        if (lastStructure != null || structure != null)
        {
            ApplyVolumeFilter(new MudExRange<int>(0, Math.Max(0, BarStorageItem.Count)));
            return;
        }
    }

    private async void BubbleSizeRangeChange(IRange<int> range)
    {
        if (range.Start > ThresholdBubble)
            range = new MudExRange<int>(ThresholdBubble, range.End);
        else if (range.End < ThresholdBubble)
            range = new MudExRange<int>(range.Start, ThresholdBubble);

        __bubbleSizeRange_Max = range.End;
        __bubbleSizeRange_Min = range.Start;

        _bubbleSizeRange = new MudExRange<int>(range.Start, range.End);
    }

    private async void SymbolChange(string value)
    {
        Symbol = value;
        await base.ForceReload();
        StateHasChanged();
    }
