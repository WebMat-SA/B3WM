                                            <MudCheckBox Dense Value="@(SelectedAgents.Count == AllBubbleAgents.Count)" ValueChanged=" async (bool c) => await SelectAllAgents()">
                                            <MudText Typo="Typo.caption">
                                                Selecionar Todos
                                            </MudText>
                                        </MudCheckBox>     
                                    </MudListItem>

                                    <MudDivider />
                                    @foreach (Ticks2.Agents? agent in AllBubbleAgents.OrderBy(q => q.Description()))
                                    {
                                        if (agent is null) continue;

                                        <MudListItem Dense="true">

                                            <MudCheckBox Dense Value="@SelectedAgents.Contains(agent)" ValueChanged="(bool c) => ToggleAgent(agent)">
                                                <MudText Typo="Typo.caption">
                                                    @agent.Description() (@((int)agent))
                                                </MudText>
                                            </MudCheckBox>
                                        </MudListItem>
                                    }
                                </MudList>
                            </NestedList>
                        </MudListItem>
                    </NestedList>
                </MudListItem>
            </MudList>
        </MudPaper>


    </MudDrawer>
    <div style="width:auto; height:86vh;  overflow:hidden;">
        <Vizor.ECharts.EChart @ref="EChart"
                              Renderer="Vizor.ECharts.ChartRenderer.Canvas"
                              Options="ChartOptions"
                              Width="auto"
                              Height="800px"
                              @key="@($"chart_{Symbol}")" />
    </div>
</MudDrawerContainer>   
<Import ThresholdBubble="ThresholdBubble" TimeFrame="TimeFrame" NotifyNewBars="NewBar" NotifyNewBubbles="NewBubble" ></Import>