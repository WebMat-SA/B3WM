@using B3WM.Client.Components
@using B3WM.Shared.Entity
@using B3WM.Shared.Extensions
@using System.Linq
@using System.Diagnostics
@using MudBlazor.Extensions.Helper
@using Nextended.Core.Contracts
@using Vizor.ECharts
@inherits Components.PersistentComponentBase
@page "/map-flow"

@code {
    protected override string PersistenceKey => $"{nameof(MapFlow)}_state";
    protected override bool ContinuousSave => true;

    [PersistState]
    public int TimeFrame { get; set; } = 2;
    [PersistState]
    public int ThresholdBubble { get; set; } = 300;
    [PersistState]
    public double BubbleSize { get; set; } = 0.015;
    [PersistState]
    public double BubbleOpacity { get; set; } = 0.3;
    [PersistState]
    public bool BubbleVisible { get; set; } = true;

    [PersistState]
    public double ProfileSizeH { get; set; } = 0.015;
    [PersistState]
    public double ProfileSizeV { get; set; } = 0.015;
    [PersistState]
    public double ProfileOpacity { get; set; } = 0.3;
    [PersistState]
    public bool ProfileVisible { get; set; } = true;

    [PersistState]
    public double DeltaSizeH { get; set; } = 0.015;
    [PersistState]
    public double DeltaSizeV { get; set; } = 0.015;
    [PersistState]
    public double DeltaOpacity { get; set; } = 0.3;
    [PersistState]
    public bool DeltaVisible { get; set; } = true;

    public bool openDrawer { get; set; } = false;

    private Vizor.ECharts.EChart? EChart;

    private static bool _logPerformance = false;
    private const int PerformanceLogThresholdMs = 20;

    private IRange<int> _dateRange { get; set; } = new MudExRange<int>(0, 0);

    // --- Controle de redraw do gráfico (único ponto: InvalidateChart + throttle) ---
    // Fontes que invalidam: Bars, CurrentBar, Bubbles, VolumeLevels, SelectedAgents (drawer).
    // O que é plotado: candles, volume profile, delta profile, bolhas (agressões).
    private const int ChartRedrawMinIntervalMs = 280;
    private bool _chartNeedsRedraw;
    private bool _chartRedrawScheduled;
    private bool _chartRedrawInProgress;
    private DateTime _chartLastRedrawUtc = DateTime.MinValue;

    private int _bubbleDataVersion;
    private int _lastBubbleDataVersion = -1;
    private List<object[]>? _cachedRedBubbleData;
    private List<object[]>? _cachedBlueBubbleData;

    private (int BarsCount, int CurrentBarVersion, int BarsDataVersion, bool IncludeCurrentBar) _lastBarsCacheKey;
    private (int BarsCount, int CurrentBarVersion, int BarsDataVersion, bool IncludeCurrentBar) _lastBarsSnapshotCacheKey;
    private int _currentBarVersion;
    private int _barsDataVersion;
    private List<Bars>? _cachedBarsSnapshot;
    private List<string>? _cachedCategoryData;
    private List<object[]>? _cachedCandleValues;

    private (double BubbleSize, bool BubbleVisible, double ProfileSizeH, double ProfileSizeV, double ProfileOpacity, bool ProfileVisible, double maxVolume, double DeltaSizeH, double DeltaSizeV, double DeltaOpacity, bool DeltaVisible, double maxDelta) _jsFunctionCacheKey;
    private bool _jsFunctionCacheValid;
    private NumberArrayOrFunction? _cachedSymbolSizeFunction;
    private JavascriptFunction? _cachedVolumeProfileFunction;
    private JavascriptFunction? _cachedDeltaProfileFunction;

    private int _volumeDataVersion;
    private int _lastVolumeDataVersion = -1;

    // Filtro de volume por intervalo de barras: quando ativo, mostramos snapshot filtrado em vez do volume em tempo real.
    private bool _volumeFilterActive;
    private List<VolumeLevel>? _filteredVolumeLevels;
    private int _filteredVolumeDataVersion;
    private double _cachedMaxVolume;
    private double _cachedMaxDelta;
    private double _cachedVolumeMinPrice = double.PositiveInfinity;
    private double _cachedVolumeMaxPrice = double.NegativeInfinity;
    private double _cachedPriceStep = 1.0;
    private List<object[]>? _cachedDeltaProfileData;
    private List<object[]>? _cachedVolumeProfileData;

    // === Envio seletivo de séries (merge mode) ===
    // Controla quais séries realmente mudaram desde o último render.
    // No modo notMerge:false, ECharts mantém as séries não enviadas intactas no canvas.
    private bool _forceFullRedraw = true; // true no primeiro render e após mudança de TimeFrame
    private (int BarsCount, int CurrentBarVersion, int BarsDataVersion, bool IncludeCurrentBar) _lastRenderedCandleKey = default;
    private int _lastRenderedVolumeVersion = -1;
    private int _lastRenderedBubbleVersion = -1;
    private (double BubbleSize, bool BubbleVisible, double ProfileSizeH, double ProfileSizeV, double ProfileOpacity, bool ProfileVisible, double maxVolume, double DeltaSizeH, double DeltaSizeV, double DeltaOpacity, bool DeltaVisible, double maxDelta) _lastRenderedJsKey = default;

    // Objetos de série cacheados (recriados apenas quando dado muda)
    private CandlestickSeries? _cachedCandleSeriesObj;
    private CustomSeries? _cachedDeltaSeriesObj;
    private CustomSeries? _cachedVolumeSeriesObj;
    private ScatterSeries? _cachedRedBubbleSeriesObj;
    private ScatterSeries? _cachedBlueBubbleSeriesObj;

    // Objetos estáticos de eixo (nunca mudam entre renders)
    private readonly AxisLabel _yAxisLabelInt = new AxisLabel { Show = true, Color = "#aaa", Formatter = new JavascriptFunction("function(value) { return Math.round(value); }") };
    private readonly SplitLine _splitLineGuides = new SplitLine { Show = true, LineStyle = new LineStyle { Color = "rgba(128, 128, 128, 0.10)" } };

    private HubClient? HubClient { get; set; }

    private IList<Bars> Bars { get; set; } = new List<Bars>();
    private Bars CurrentBar { get; set; } = new Bars();
    /// <summary>Barras fechadas + barra atual (sem duplicar por Date).</summary>
    private IList<Bars> RawDataBar 
    { 
        get
        {
            var _Bars = Bars.ToList();
            if (CurrentBar.Date != default && !Bars.Any(b => b.Date == CurrentBar.Date))
                _Bars.Add(CurrentBar);
            return _Bars.OrderBy(q => q.Date).ToList();
        }
    }

    private IList<Bubble> Bubbles { get; set; } = new List<Bubble>();
    private IList<Bubble> RawDataBubbleBlue => Bubbles.Where(q=>q.ActionType == Ticks2.ActionType.Buy && SelectedAgents.Contains(q.Agent)).OrderBy(q => q.Time).ToList();
    private IList<Bubble> RawDataBubbleRed => Bubbles.Where(q => q.ActionType == Ticks2.ActionType.Sale && SelectedAgents.Contains(q.Agent)).OrderBy(q => q.Time).ToList();

    private IList<VolumeLevel> VolumeLevels { get; set; } = new List<VolumeLevel>();

    private static void LogPerf(string scope, long elapsedMs, bool always = false)
    {
        if (!_logPerformance) return;
        if (!always && elapsedMs < PerformanceLogThresholdMs) return;
        Console.WriteLine($"[{scope}] {elapsedMs}ms");
    }

    [PersistState]
    private List<Ticks2.Agents?> SelectedAgents { get; set; } = new List<Ticks2.Agents?>();
    private readonly HashSet<Ticks2.Agents?> _allBubbleAgents = new();
    private IList<Ticks2.Agents?> AllBubbleAgents => _allBubbleAgents.ToList();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }

    /// <summary>Marca o gráfico para redesenho. Único ponto de entrada para qualquer fonte (Hub ou UI).</summary>
    private void InvalidateChart()
    {
        _chartNeedsRedraw = true;
        EnsureChartRedrawScheduled();
    }

    private void EnsureChartRedrawScheduled()
    {
        if (_chartRedrawScheduled) return;
        _chartRedrawScheduled = true;
        _ = InvokeAsync(ProcessChartRedrawAsync);
    }

    private async Task ProcessChartRedrawAsync()
    {
        try
        {
            while (_chartNeedsRedraw)
            {
                _chartNeedsRedraw = false;

                var now = DateTime.UtcNow;
                var elapsed = _chartLastRedrawUtc == DateTime.MinValue ? double.PositiveInfinity : (now - _chartLastRedrawUtc).TotalMilliseconds;
                if (elapsed < ChartRedrawMinIntervalMs)
                {
                    _chartNeedsRedraw = true;
                    await Task.Delay((int)(ChartRedrawMinIntervalMs - elapsed));
                    continue;
                }

                if (_chartRedrawInProgress || EChart == null)
                    break;

                _chartRedrawInProgress = true;
                try
                {
                    var sw = Stopwatch.StartNew();
                    await EChart.UpdateAsync(true);
                    sw.Stop();
                    _chartLastRedrawUtc = DateTime.UtcNow;
                    LogPerf("Chart redraw", sw.ElapsedMilliseconds, always: true);
                }
                finally
                {
                    _chartRedrawInProgress = false;
                }

                await Task.Yield();
            }
        }
        finally
        {
            _chartRedrawScheduled = false;
            if (_chartNeedsRedraw)
                EnsureChartRedrawScheduled();
        }
    }

    private static Bars CloneBar(Bars bar)
    {
        return new Bars
        {
            Date = bar.Date,
            Open = bar.Open,
            High = bar.High,
            Low = bar.Low,
            Close = bar.Close,
            Volume = bar.Volume
        };
    }

    public void NewBar(IEnumerable<Bars> bars)
    {
        var count = RawDataBar.Count;

        if (count == 0) return;

        // Range contempla todas as barras = sem filtro: manter gráfico atual (volume já condizente com todo o período).
        var isFullRange = _dateRange.Start == 0 && _dateRange.End >= count - 1;
        Console.WriteLine("[RawDataBar.Count]: " + count + "[IsFullRange]: " + isFullRange);

        if (bars == null) return;
        var sw = Stopwatch.StartNew();
        foreach (var bar in bars)
        {
            if (bar == null || bar.Date == default) continue;
            var existing = Bars.FirstOrDefault(b => b.Date == bar.Date);
            if (existing != null)
            {
                existing.Open = bar.Open;
                existing.High = bar.High;
                existing.Low = bar.Low;
                existing.Close = bar.Close;
                existing.Volume = bar.Volume;
                _barsDataVersion++;
            }
            else
            {
                // Cópia defensiva: armazenar nossa própria instância para não depender da referência do callback.
                Bars.Add(CloneBar(bar));
                _barsDataVersion++;
            }
        }

        if (isFullRange)
        {
            _dateRange = new MudExRange<int>(0, RawDataBar.Count);
        }
        InvalidateChart();
        sw.Stop();
        LogPerf("NewBar total", sw.ElapsedMilliseconds);
    }

    public void NewCurrentBar(Bars bar)
    {
        var sw = Stopwatch.StartNew();
        CurrentBar = bar;
        _currentBarVersion++;
        InvalidateChart();
        sw.Stop();
        LogPerf("NewCurrentBar total", sw.ElapsedMilliseconds);
    }

    public void NewBubble(Bubble data)
    {
        var sw = Stopwatch.StartNew();
        if (_allBubbleAgents.Add(data.Agent) && !SelectedAgents.Contains(data.Agent))
            SelectedAgents.Add(data.Agent);
        Bubbles.Add(data);
        _bubbleDataVersion++;
        InvalidateChart();
        sw.Stop();
        LogPerf("NewBubble total", sw.ElapsedMilliseconds);
    }

    public void VolumeUpdate(IEnumerable<VolumeLevel> volumes)
    {
        try{

            var sw = Stopwatch.StartNew();
            VolumeLevels = volumes as IList<VolumeLevel> ?? volumes.ToList();
            _volumeDataVersion++;
            InvalidateChart();
            sw.Stop();
            LogPerf("VolumeUpdate total", sw.ElapsedMilliseconds);
        }
        catch(Exception e)
        {
            Console.WriteLine("VolumeUpdate Error" + e.Message);
        }
    }

    public void SelectAllAgents()
    {
        var sw = Stopwatch.StartNew();
        if (SelectedAgents.Count == _allBubbleAgents.Count)
            SelectedAgents = new List<Ticks2.Agents?>();
        else
            SelectedAgents = AllBubbleAgents.ToList();
        _bubbleDataVersion++;
        InvalidateChart();
        sw.Stop();
        LogPerf("SelectAllAgents total", sw.ElapsedMilliseconds);
    }

    private void ToggleAgent(Ticks2.Agents? agent)
    {
        var sw = Stopwatch.StartNew();
        var list = SelectedAgents.ToList();
        if (list.Contains(agent))
            list.Remove(agent);
        else
            list.Add(agent);
        SelectedAgents = list;
        _bubbleDataVersion++;
        StateHasChanged();
        InvalidateChart();
        sw.Stop();
        LogPerf("ToggleAgent total", sw.ElapsedMilliseconds);
    }

    private void TimeFrameChanged(int value)
    {
        TimeFrame = value;
        //preciso zerar os hubclients helpers e limpar os dados atuais para evitar que barras antigas sejam interpretadas como novas (ex.: barras de 1min virando 2min e gerando muitos updates).

        Bubbles = new List<Bubble>();
        Bars = new List<Bars>();
        CurrentBar = new Bars();

        //VolumeLevels = new List<VolumeLevel>();

        HubClient?.ResetHelpers();

        // Força rebuild completo no próximo render: limpou dados, precisa enviar todas as séries.
        _bubbleDataVersion++;
        _forceFullRedraw = true;

        InvalidateChart();
    }

    private string IndexEndToDateStringBars(IRange<int> range)
    {
        return $" {RawDataBar.ElementAtOrDefault(range.End)?.Date:dd/MM HH:mm}";
    }
    private string IndexStartToDateStringBars(IRange<int> range)
    {
        return $"{RawDataBar.ElementAtOrDefault(range.Start)?.Date:dd/MM HH:mm}";
    }
    private void ApplyVolumeFilter(IRange<int> newRange)
    {
        _dateRange = newRange;

        var count = RawDataBar.Count;
        if (count == 0) return;

        // Range contempla todas as barras = sem filtro: manter gráfico atual (volume já condizente com todo o período).
        var isFullRange = newRange.Start == 0 && newRange.End >= count - 1;
        if (isFullRange)
        {
            _volumeFilterActive = false;
            _filteredVolumeLevels = null;
        }
        else
        {
            var startBar = RawDataBar.ElementAtOrDefault(newRange.Start);
            var endBar = RawDataBar.ElementAtOrDefault(newRange.End);
            if (startBar != null && endBar != null && HubClient != null)
            {
                _filteredVolumeLevels = HubClient.GetVolumeSnapshot(startBar.Date, endBar.Date) ?? new List<VolumeLevel>();
                _volumeFilterActive = true;
                _filteredVolumeDataVersion++;
            }
        }

        InvalidateChart();
    }

    private Vizor.ECharts.ChartOptions ChartOptions = new()
