    private int _lastRenderedBubbleVersion = -1;
    private (double BubbleSize, bool BubbleVisible, double ProfileSizeH, double ProfileSizeV, double ProfileOpacity, bool ProfileVisible, double maxVolume, double DeltaSizeH, double DeltaSizeV, double DeltaOpacity, bool DeltaVisible, double maxDelta) _lastRenderedJsKey = default;


    private int _lastBubbleDataVersion = -1;
    private List<object[]>? _cachedRedBubbleData;
    private List<object[]>? _cachedBlueBubbleData;

    private (int BarsCount, int CurrentBarVersion, int BarsDataVersion, bool IncludeCurrentBar) _lastBarsCacheKey;
    private (int BarsCount, int CurrentBarVersion, int BarsDataVersion, bool IncludeCurrentBar) _lastBarsSnapshotCacheKey;

    private List<Bars>? _cachedBarsSnapshot;
    private List<string>? _cachedCategoryData;
    private List<object[]>? _cachedCandleValues;


    private int _lastVolumeDataVersion = -1;

    private static Bars CloneBar(Bars bar)
    {
        return new Bars
        {
            Date = bar.Date,
            Open = bar.Open,
            High = bar.High,
            Low = bar.Low,
            Close = bar.Close,
            Volume = bar.Volume
        };
    }

    public async Task NewBar(IEnumerable<Bars> bars)
    {
        var count = Bars.Count;
        var isFullRange = count > 0 && _dateRange.End >= count - 1;

        var sw = Stopwatch.StartNew();
        foreach (var bar in bars)
        {
            if (bar == null || bar.Date == default) continue;
            var existing = Bars.FirstOrDefault(b => b.Date == bar.Date);
            if (existing != null)
            {
                existing.Open = bar.Open;
                existing.High = bar.High;
                existing.Low = bar.Low;
                existing.Close = bar.Close;
                existing.Volume = bar.Volume;
                _barsDataVersion++;
            }
            else
            {
                // Cópia defensiva: armazenar nossa própria instância para năo depender da referęncia do callback.
                Bars.Add(CloneBar(bar));
                _barsDataVersion++;
            }
        }

        if (isFullRange)
        {
            _dateRange = new MudExRange<int>(_dateRange.Start, Bars.Count);
            await ApplyVolumeFilter(_dateRange);
        }
        sw.Stop();
        HelperPerformanceConfig.Log(nameof(MapFlow), "NewBar total", sw.ElapsedMilliseconds);

    }

    public async Task NewCurrentBar(Bars bar)
    {
        var sw = Stopwatch.StartNew();

        CurrentBar = bar;
        _currentBarVersion++;

        _cachecount = HubClient?.GetCacheCount();

        if (_cachecount >= 2)
        {
            //notifica somente o filho, para năo dar gargalo de renderizar o gráfico (que é mais pesado) a cada atualizaçăo de barra, já que o gráfico só precisa ser atualizado quando as barras históricas mudam ou quando o usuário interage com o filtro de volume.
            //if (MapFlowBar != null) await MapFlowBar.NotifyChanges();

            HelperPerformanceConfig.Log(nameof(MapFlow), "NewCurrentBar skipped UI update", sw.ElapsedMilliseconds);
            return; 
        }

        if (EChart != null)
        {
            _ = GenerateChart();
        }


        sw.Stop();
        HelperPerformanceConfig.Log(nameof(MapFlow), "NewCurrentBar total", sw.ElapsedMilliseconds);


        //return Task.CompletedTask;
    }

    public Task NewBubble(Bubble data)
    {
        var sw = Stopwatch.StartNew();
        if (_allBubbleAgents.Add(data.Agent) && !SelectedAgents.Contains(data.Agent))
            SelectedAgents.Add(data.Agent);
        Bubbles.Add(data);
        _bubbleDataVersion++;
        sw.Stop();
        //HelperPerformanceConfig.Log(nameof(MapFlow),"NewBubble total", sw.ElapsedMilliseconds);

        return Task.CompletedTask;
        //await InvokeAsync(StateHasChanged);
    }

    public Task VolumeUpdate(IEnumerable<VolumeLevel> volumes)
    {
        try{

            var sw = Stopwatch.StartNew();
            VolumeLevels = volumes as List<VolumeLevel> ?? volumes.ToList();
            _volumeDataVersion++;
            sw.Stop();
        }
        catch(Exception e)
        {
            Console.WriteLine("VolumeUpdate Error" + e.Message);
        }

        return Task.CompletedTask;
    }

    public async Task SelectAllAgents()
    {
        var sw = Stopwatch.StartNew();
        if (SelectedAgents.Count == _allBubbleAgents.Count)
            SelectedAgents = new List<Ticks2.Agents?>();
        else
            SelectedAgents = AllBubbleAgents.ToList();
        _bubbleDataVersion++;
        sw.Stop();
        HelperPerformanceConfig.Log(nameof(MapFlow),"SelectAllAgents total", sw.ElapsedMilliseconds);

        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleAgent(Ticks2.Agents? agent)
    {
        var sw = Stopwatch.StartNew();
        var list = SelectedAgents.ToList();
        if (list.Contains(agent))
            list.Remove(agent);
        else
            list.Add(agent);
        SelectedAgents = list;
        _bubbleDataVersion++;

        sw.Stop();
        HelperPerformanceConfig.Log(nameof(MapFlow),"ToggleAgent total", sw.ElapsedMilliseconds);
    }

    private void TimeFrameChanged(int value)
    {
        TimeFrame = value;

        Bars = new List<Bars>();
        CurrentBar = new Bars();

        //HubClient?.RemountCandles(TimeFrame);
    }

    private void ThresholdBubbleChanged(int value)
    {
        ThresholdBubble = value;
        Bubbles = new List<Bubble>();
        _bubbleDataVersion++;
        _allBubbleAgents.Clear();

        //HubClient?.RemountBubbles(ThresholdBubble);
    }

    private string IndexEndToDateStringBars(IRange<int> range)
    {
        return $" {Bars.ElementAtOrDefault(range.End)?.Date:dd/MM HH:mm}";
    }
    private string IndexStartToDateStringBars(IRange<int> range)
    {
        return $"{Bars.ElementAtOrDefault(range.Start)?.Date:dd/MM HH:mm}";
    }
    private async Task ApplyVolumeFilter(IRange<int> newRange)
    {
        _dateRange = newRange;

        var count = Bars.Count;
        if (count == 0) return;

        // Range contempla todas as barras = sem filtro: manter gráfico atual (volume já condizente com todo o período).
        var isFullRange = newRange.Start == 0 && newRange.End >= count - 1;
        if (isFullRange)
        {
            _volumeFilterActive = false;
            _filteredVolumeLevels = null;
        }
        else
        {
            var startBar = Bars.ElementAtOrDefault(newRange.Start);
            var endBar = Bars.ElementAtOrDefault(newRange.End);
            if (startBar != null && endBar != null && HubClient != null)
            {
                _filteredVolumeLevels = await HubClient.GetVolumeSnapshot(startBar.Date, endBar.Date) ?? new List<VolumeLevel>();
                _volumeFilterActive = true;
                _filteredVolumeDataVersion++;
            }
        }
    }

    private async Task GenerateChart()
    {
        if (EChart is null) return ;
        var swTotal = Stopwatch.StartNew();

        _lastCacheCountUpdate = DateTime.Now;

        //var swBars = Stopwatch.StartNew();
        var hasCurrentBarInBars = Bars.Any(b => b.Date == CurrentBar.Date);
        var includeCurrentBar = CurrentBar.Date != default && !hasCurrentBarInBars;
        var barsKey = (Bars.Count, _currentBarVersion, _barsDataVersion, includeCurrentBar);
        List<Bars> bars;
        if (_cachedBarsSnapshot != null && _lastBarsSnapshotCacheKey == barsKey)
        {
            bars = _cachedBarsSnapshot;
        }
        else
        {
            bars = new List<Bars>(Bars.Count);
            foreach (var bar in Bars)
                bars.Add(bar);

            if (includeCurrentBar)
                bars.Add(CurrentBar);

            bars = bars.GroupBy(b => b.Date).Select(g => g.First()).OrderBy(b => b.Date).ToList();
            _cachedBarsSnapshot = bars;
            _lastBarsSnapshotCacheKey = barsKey;
        }
        //swBars.Stop();
        //HelperPerformanceConfig.Log(nameof(MapFlowGraph), "GenerateChart RawDataBar", swBars.ElapsedMilliseconds);

        if (bars.Count == 0) return ;

        var swLimites = Stopwatch.StartNew();
        double barsMin = double.PositiveInfinity;
        double barsMax = double.NegativeInfinity;
        foreach (var b in bars)
        {
            var low = (double)b.Low;
            var high = (double)b.High;
            if (low < barsMin) barsMin = low;
            if (high > barsMax) barsMax = high;
        }

        // Fonte efetiva: sem filtro = VolumeLevels (tempo real); com filtro = snapshot do intervalo do slider.
        IList<VolumeLevel> effectiveLevels = _volumeFilterActive && _filteredVolumeLevels != null
            ? _filteredVolumeLevels
            : VolumeLevels;
        var effectiveVolumeVersion = _volumeFilterActive ? _filteredVolumeDataVersion : _volumeDataVersion;

        // Atualizar cache de volume/delta quando a versăo mudar ou quando há dados e o cache está vazio (ex.: primeira carga).
        var volumeNeedsRefresh = _lastVolumeDataVersion != effectiveVolumeVersion
            || (effectiveLevels.Count > 0 && (_cachedVolumeProfileData == null || _cachedVolumeProfileData.Count == 0));
        if (volumeNeedsRefresh)
        {
            _cachedMaxVolume = 0;
            _cachedMaxDelta = 0;
            _cachedVolumeMinPrice = double.PositiveInfinity;
            _cachedVolumeMaxPrice = double.NegativeInfinity;
            _cachedPriceStep = 1.0;

            if (effectiveLevels.Count >= 2)
                _cachedPriceStep = Math.Abs(effectiveLevels[1].Price - effectiveLevels[0].Price);

            var deltaProfileCache = new List<object[]>(effectiveLevels.Count);
            var volumeProfileCache = new List<object[]>(effectiveLevels.Count);
            foreach (var v in effectiveLevels)
            {
                var total = (double)v.Total;
                var absDelta = Math.Abs((double)v.Delta);
                var price = (double)v.Price;
                if (total > _cachedMaxVolume) _cachedMaxVolume = total;
                if (absDelta > _cachedMaxDelta) _cachedMaxDelta = absDelta;
                if (price < _cachedVolumeMinPrice) _cachedVolumeMinPrice = price;
                if (price > _cachedVolumeMaxPrice) _cachedVolumeMaxPrice = price;

                deltaProfileCache.Add(new object[] { absDelta, v.Price, _cachedPriceStep, v.Delta });
                volumeProfileCache.Add(new object[] { v.Total, v.Price, _cachedPriceStep });
            }

            _cachedDeltaProfileData = deltaProfileCache;
            _cachedVolumeProfileData = volumeProfileCache;
            _lastVolumeDataVersion = effectiveVolumeVersion;
        }

        double actualMin = barsMin;
        double actualMax = barsMax;
        if (!double.IsPositiveInfinity(_cachedVolumeMinPrice) && _cachedVolumeMinPrice < actualMin)
            actualMin = _cachedVolumeMinPrice;
        if (!double.IsNegativeInfinity(_cachedVolumeMaxPrice) && _cachedVolumeMaxPrice > actualMax)
            actualMax = _cachedVolumeMaxPrice;

        if (double.IsInfinity(actualMin) || double.IsInfinity(actualMax)) return ;
        double range = actualMax - actualMin;
        if (range <= 0) range = Math.Max(1.0, Math.Abs(actualMax) * 0.01);

        double paddingFactor = 0.25;
        double minPrice = actualMin - (range * paddingFactor);
        double maxPrice = actualMax + (range * paddingFactor);
        swLimites.Stop();
        //LogPerf("GenerateChart Limites", swLimites.ElapsedMilliseconds);

        var swDados = Stopwatch.StartNew();
        var maxVolume = _cachedMaxVolume;
        var maxDelta = _cachedMaxDelta;
        List<string> categoryData;
        List<object[]> values;
        if (_cachedCategoryData != null && _lastBarsCacheKey == barsKey)
        {
            categoryData = _cachedCategoryData;
            values = _cachedCandleValues!;
        }
        else
        {
            categoryData = new List<string>(bars.Count);
            values = new List<object[]>(bars.Count);
            foreach (var row in bars)
            {
                categoryData.Add(row.Date.ToString("dd/MM HH:mm"));
                values.Add(new object[] { row.Open, row.Close, row.Low, row.High });
            }
            _lastBarsCacheKey = barsKey;
            _cachedCategoryData = categoryData;
            _cachedCandleValues = values;
        }
        swDados.Stop();
        //LogPerf("GenerateChart Dados eixo", swDados.ElapsedMilliseconds);

        var swEixos = Stopwatch.StartNew();
        ChartOptions.XAxisList = new List<XAxis>
        {
            new XAxis
            {
                Type = AxisType.Category,
                Data = categoryData, BoundaryGap = true,
                Max = categoryData.Count > 0 ? (int)(categoryData.Count / 0.75) : 100 ,
                AxisPointer = new AxisPointer { Show = true},
            }, // X[0]

            new XAxis // X[1]: Volume Total (Direita - Invertido)
            {
                Type = AxisType.Value, Show = false, Inverse = true, Min = 0,
                Max = maxVolume > 0 ? maxVolume * 4 : 10000,
                AxisPointer = new AxisPointer { Show = false },
            },

            new XAxis // X[2]: Delta (Esquerda - Normal)
            {
                Type = AxisType.Value, Show = false, Inverse = false, Min = 0,
                Max = maxDelta > 0 ? maxDelta * 4 : 10000, // Escala proporcional ao delta
                AxisPointer = new AxisPointer { Show = false },
            }
        };

        // 3. EIXOS Y (labels apenas inteiros; linhas de guia com opacidade reduzida)
        // _yAxisLabelInt e _splitLineGuides săo campos readonly — năo recriados a cada render.
        ChartOptions.YAxisList = new List<YAxis>
        {
            new YAxis { Type = AxisType.Value, Scale = true, Min = minPrice, Max = maxPrice, Silent = true, AxisPointer = new AxisPointer { Show = true }, AxisLabel = _yAxisLabelInt, SplitLine = _splitLineGuides },
            new YAxis { Type = AxisType.Value, Position = LeftOrRight.Right, Min = minPrice, Max = maxPrice, AxisLabel = _yAxisLabelInt, SplitLine = _splitLineGuides }
        };
        swEixos.Stop();
        //LogPerf("GenerateChart Eixos", swEixos.ElapsedMilliseconds);

        var swJs = Stopwatch.StartNew();
        var jsKey = (BubbleSize, BubbleVisible, ProfileSizeH, ProfileSizeV, ProfileOpacity, ProfileVisible, maxVolume, DeltaSizeH, DeltaSizeV, DeltaOpacity, DeltaVisible, maxDelta);
        NumberArrayOrFunction symbolSizeFunction;
        JavascriptFunction volumeProfileFunction;
        JavascriptFunction deltaprofileFunction;
        if (_jsFunctionCacheValid && _jsFunctionCacheKey == jsKey)
        {
            symbolSizeFunction = _cachedSymbolSizeFunction!;
            volumeProfileFunction = _cachedVolumeProfileFunction!;
            deltaprofileFunction = _cachedDeltaProfileFunction!;
        }
        else
        {
            var inv = System.Globalization.CultureInfo.InvariantCulture;
            symbolSizeFunction = new NumberArrayOrFunction(new JavascriptFunction($@"function (v) {{ return v[2] * {BubbleSize.ToString(inv)} * {(BubbleVisible ? 1 : 0)}; }}"));
            volumeProfileFunction = new JavascriptFunction(@"
                    function (params, api) {
                        var volumeVal = api.value(0);
                        var priceVal = api.value(1);
                        var stepVal = api.value(2);

                        var start = api.coord([0, priceVal]);
                        var end = api.coord([volumeVal* " + ProfileSizeH.ToString(inv) + @", priceVal]);

                        var size = api.size([0, stepVal]);
                        var barHeight = size[1] * " + ProfileSizeV.ToString(inv) + @";

                        var isPoc = Math.abs(volumeVal - " + maxVolume.ToString(inv) + @") < 0.5;

                        return {
                            type: 'rect',
                            shape: {
                                x: end[0],
                                y: start[1] - barHeight / 2,
                                width: start[0] - end[0],
                                height: barHeight
                            },
                            style: api.style({
                                fill: isPoc ? 'rgba(255, 100, 0, " + (ProfileOpacity * (ProfileVisible ? 1 : 0)).ToString(inv) + @")' : 'rgba(100, 150, 250, " + (ProfileOpacity * (ProfileVisible ? 1 : 0)).ToString(inv) + @")',
                                stroke: 'rgba(100, 150, 250, " + ((ProfileOpacity * (ProfileVisible ? 1 : 0)) - 0.2).ToString(inv) + @")'
                            })
                        };
                    }
                ");
            deltaprofileFunction = new JavascriptFunction(@"
                    function (params, api) {
                        var deltaAbs = api.value(0);
                        var priceVal = api.value(1);
                        var stepVal = api.value(2);
                        var rawDelta = api.value(3);

                        var start = api.coord([0, priceVal]);
                        var end = api.coord([deltaAbs, priceVal]);

                        var size = api.size([0, stepVal]);
                        var barHeight = size[1] * " + DeltaSizeV.ToString(inv) + @";

                        return {
                            type: 'rect',
                            shape: {
                                x: start[0],
                                y: start[1] - barHeight / 2,
                                width: (end[0] - start[0]) * " + DeltaSizeH.ToString(inv) + @",
                                height: barHeight
                            },
                            style: api.style({
                                fill: rawDelta >= 0 ? 'rgba(50, 50, 255, " + (DeltaOpacity * (DeltaVisible ? 1 : 0)).ToString(inv) + @")' : 'rgba(255, 50, 50, " + (DeltaOpacity * (DeltaVisible ? 1 : 0)).ToString(inv) + @")',
                                stroke: rawDelta >= 0 ? 'rgba(50, 50, 255, " + ((DeltaOpacity * (DeltaVisible ? 1 : 0)) - 0.2).ToString(inv) + @")' : 'rgba(255, 50, 50, " + ((DeltaOpacity * (DeltaVisible ? 1 : 0)) - 0.2).ToString(inv) + @")'
                            })
                        };
                    }
                ");
            _jsFunctionCacheKey = jsKey;
            _cachedSymbolSizeFunction = symbolSizeFunction;
            _cachedVolumeProfileFunction = volumeProfileFunction;
            _cachedDeltaProfileFunction = deltaprofileFunction;
            _jsFunctionCacheValid = true;
        }
        swJs.Stop();
        //LogPerf("GenerateChart Funcoes JS", swJs.ElapsedMilliseconds);

        var swBubbles = Stopwatch.StartNew();
        if (_lastBubbleDataVersion != _bubbleDataVersion)
        {
            var selectedAgents = new HashSet<Ticks2.Agents?>(SelectedAgents);
            var redList = new List<(DateTime Time, object[] Data)>();
            var blueList = new List<(DateTime Time, object[] Data)>();
            foreach (var e in Bubbles)
            {
                if (!selectedAgents.Contains(e.Agent)) continue;
                var arr = new object[] {
                    e.Time.GetCandleStart(TimeFrame).ToString("dd/MM HH:mm"),
                    e.Price,
                    e.Amount,
                    e.Agent?.Description() ?? "Desconhecido"
            };
                if (e.ActionType == Ticks2.ActionType.Sale)
                    redList.Add((e.Time, arr));
                else if (e.ActionType == Ticks2.ActionType.Buy)
                    blueList.Add((e.Time, arr));
            }
            redList.Sort((a, b) => a.Time.CompareTo(b.Time));
            blueList.Sort((a, b) => a.Time.CompareTo(b.Time));
            _cachedRedBubbleData = redList.ConvertAll(x => x.Data);
            _cachedBlueBubbleData = blueList.ConvertAll(x => x.Data);
            _lastBubbleDataVersion = _bubbleDataVersion;
        }
        var redBubbleData = _cachedRedBubbleData ?? new List<object[]>();
        var blueBubbleData = _cachedBlueBubbleData ?? new List<object[]>();
        swBubbles.Stop();
        //LogPerf("GenerateChart Bubbles", swBubbles.ElapsedMilliseconds);

        //var swSeries = Stopwatch.StartNew();
        var deltaProfileData = _cachedDeltaProfileData ?? new List<object[]>();
        var volumeProfileData = _cachedVolumeProfileData ?? new List<object[]>();

        // --- Detecçăo de mudanças por tipo de série ---
        // No modo notMerge:false (merge), o ECharts mantém no canvas as séries que NĂO forem enviadas.
        // Só enviamos uma série quando o dado dela realmente mudou desde o último render.
        bool jsFunctionChanged = _lastRenderedJsKey != jsKey;
        if (jsFunctionChanged) _lastRenderedJsKey = jsKey;

        bool candleDataChanged = _forceFullRedraw || _lastRenderedCandleKey != barsKey;
        bool volumeDataChanged = _forceFullRedraw || _lastRenderedVolumeVersion != effectiveVolumeVersion || jsFunctionChanged;
        bool bubbleDataChanged = _forceFullRedraw || _lastRenderedBubbleVersion != _bubbleDataVersion || jsFunctionChanged;

        // Rebuild de objetos de série apenas quando necessário
        if (candleDataChanged)
        {
            _cachedCandleSeriesObj = new CandlestickSeries
            {
                Name = "Candle",
                Data = values,
                Z = 2,
                Clip = false, // Evita que o candle inteiro suma ao dar zoom quando as bordas (high/low) saem da área visível
                ItemStyle = new ItemStyle { Color = "#ffffff", Color0 = "#000000", BorderColor = "#ffffff", BorderColor0 = "#ffffff" }
            };
            _lastRenderedCandleKey = barsKey;
        }

        if (bubbleDataChanged)
        {
            _cachedRedBubbleSeriesObj = new ScatterSeries { Name = "Aggressive Red", Data = redBubbleData, SymbolSize = symbolSizeFunction, Z = 3, ItemStyle = new ItemStyle { Color = ColorSeller, Opacity = BubbleOpacity, BorderColor = ColorSeller, BorderWidth = 1 } };
            _cachedBlueBubbleSeriesObj = new ScatterSeries { Name = "Aggressive Blue", Data = blueBubbleData, SymbolSize = symbolSizeFunction, Z = 3, ItemStyle = new ItemStyle { Color = ColorBuyer, Opacity = BubbleOpacity, BorderColor = ColorBuyer, BorderWidth = 1 } };
            _lastRenderedBubbleVersion = _bubbleDataVersion;
        }

        if (volumeDataChanged)
        {
            _cachedDeltaSeriesObj = new CustomSeries { Name = "Delta Profile", XAxisIndex = 2, YAxisIndex = 1, Z = 0, Data = deltaProfileData, RenderItem = deltaprofileFunction };
            _cachedVolumeSeriesObj = new CustomSeries { Name = "Volume Profile", XAxisIndex = 1, YAxisIndex = 1, Z = 0, Data = volumeProfileData, RenderItem = volumeProfileFunction };
            _lastRenderedVolumeVersion = effectiveVolumeVersion;
        }

        // === Envio seletivo por comprimento de array ===
        // Ordem: [0]Candle  [1]RedBubble  [2]BlueBubble  [3]DeltaProfile  [4]VolumeProfile
        //
        // ECharts merge mode (notMerge padrăo = false) atualiza APENAS os índices
        // fornecidos e deixa os demais intactos NO CANVAS, sem re-renderizar.
        //
        // Casos:
        //   só candle mudou          ? envia [candle]           (índices 1-4 intactos ? Delta/Volume NĂO re-renderizados)
        //   candle + bubbles         ? envia [candle,red,blue]  (índices 3-4 intactos ? Delta/Volume NĂO re-renderizados)
        //   volume mudou (qualquer)  ? envia todos os 5         (update completo, evento raro)
        var seriesList = new List<ISeries>(5);
        seriesList.Add(_cachedCandleSeriesObj ?? new CandlestickSeries { Name = "Candle" }); // [0]

        if (bubbleDataChanged)
        {
            seriesList.Add(_cachedRedBubbleSeriesObj ?? new ScatterSeries { Name = "Aggressive Red" }); // [1]
            seriesList.Add(_cachedBlueBubbleSeriesObj ?? new ScatterSeries { Name = "Aggressive Blue" }); // [2]
        }

        if (volumeDataChanged)
        {
            seriesList.Add(_cachedDeltaSeriesObj ?? new CustomSeries { Name = "Delta Profile" }); // [3]
            seriesList.Add(_cachedVolumeSeriesObj ?? new CustomSeries { Name = "Volume Profile" }); // [4]
        }

        ChartOptions.Series = seriesList;
        _forceFullRedraw = false;

        //swSeries.Stop();
        swTotal.Stop();
        //HelperPerformanceConfig.Log(nameof(MapFlowGraph),"GenerateChart Series", swSeries.ElapsedMilliseconds);
        //HelperPerformanceConfig.Log(nameof(MapFlow), "GenerateChart total", swTotal.ElapsedMilliseconds);

        await EChart.UpdateAsync(false);
    }
}

@* --- INTERFACE --- *@
<MudStack AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="px-5 pt-3" Row Style="position: relative;">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
        <MudTooltip Text="Configuraçőes">
            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Settings" OnClick="() => { openDrawer = !openDrawer; }" />
        </MudTooltip>
        <MudTooltip Text="Carregar barras, bubbles e volume do banco local">
            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Downloading" OnClick="() => { }" Disabled />
        </MudTooltip>
    </MudStack>
    <B3WM.Client.Components.HubClient @ref=HubClient
        OnCandleSeriesChange="NewBar" 
        OnCurrentBarChange="NewCurrentBar"
        OnVolumeUpdate="VolumeUpdate" 
        OnNewBubble="NewBubble"
        TimeFrame="TimeFrame"
        BubbleThreshold="ThresholdBubble"
        CacheCount="_cachecount"
        LastCacheCount="_lastCacheCountUpdate" />
    @*<MudOverlay Visible="_isLoadingFromIndexedDb" ZIndex="10" Class="d-flex align-center justify-center" DarkBackground=true Absolute=true>
        <MudStack Row Spacing="3" Class="px-3 py-2" AlignItems="AlignItems.Center" Style="background-color:darkorange;">
            <MudProgressCircular Size="Size.Small" Indeterminate="@(_loadingProgress == 0)" Value="@_loadingProgress" />
            @if (!string.IsNullOrEmpty(_loadingStatus))
            {
                <MudText Typo="Typo.body2" Class="text-center">@_loadingStatus</MudText>
            }
        </MudStack>
    </MudOverlay>*@
</MudStack>


<MudDrawerContainer Class="mud-height-full" Style="height: 100%">
    <MudDrawer Open="openDrawer" Width="400px" Anchor="MudBlazor.Anchor.Start" Variant="@DrawerVariant.Persistent" Class="p-1">
        @* TIMEFRAME *@
        <MudPaper Class="p-1" Outlined Elevation="0">
            <MudList T="string" Dense>
                <MudListItem Dense=true Icon="@Icons.Material.Filled.Timelapse" Text="TimeFrame (Min)" Expanded=false>
                    <NestedList>
                        <MudListItem Dense="true">
                            <MudToggleGroup T=int Value=TimeFrame ValueChanged="TimeFrameChanged" Delimiters Size="Size.Small" Outlined>
                                <MudToggleItem Value="1">1</MudToggleItem>
                                <MudToggleItem Value="2">2</MudToggleItem>
                                <MudToggleItem Value="5">5</MudToggleItem>
                                <MudToggleItem Value="15">15</MudToggleItem>
                                <MudToggleItem Value="30">30</MudToggleItem>
                                <MudToggleItem Value="60">60</MudToggleItem>
                            </MudToggleGroup>
                        </MudListItem>
                    </NestedList>
                </MudListItem>
            </MudList>
        </MudPaper>

        @* VOLUMES (DELTAS E PROFILE) *@
        <MudPaper Class="p-1 mt-1" Outlined Elevation="0">
            <MudList T="string" Dense>
                <MudListItem Dense=true Icon="@Icons.Material.Filled.BarChart" Text="Volumes" Expanded=true>
                    <NestedList>
                        <MudListItem Dense="true">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Range</MudText>
                                <MudText Typo="Typo.caption">@($"{IndexStartToDateStringBars(_dateRange)} ? {IndexEndToDateStringBars(_dateRange)}")</MudText>
                            </MudStack>
                            <MudExRangeSlider T="int"
                                              Value="_dateRange"
                                              ValueChanged="ApplyVolumeFilter"
                                              AllowWholeRangeDrag
                                              Size="Size.Small"
                                              SizeRange="@(new MudExRange<int>(0, Math.Max(0, Bars.Count - 1)))"
                                              ToEndStringFunc="IndexEndToDateStringBars"
                                              ToStartStringFunc="IndexStartToDateStringBars"
                                              Class="pr-5 mr-5" Disabled="@(Bars.Count <= 2)" />
                        </MudListItem>

                        @* Deltas *@
                        <MudListItem Dense=true Icon="@Icons.Material.Filled.AlignHorizontalLeft" Text="Deltas" Expanded=false>
                            <NestedList>
                                <MudListItem Dense="true" OnClick="() => DeltaVisible = !DeltaVisible">
                                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">Show on Chart</MudText>
                                        <MudSwitch @bind-Value="DeltaVisible" Color="MudBlazor.Color.Primary" Size="Size.Small"></MudSwitch>
                                    </MudStack>
                                </MudListItem>
                                <MudListItem Dense="true">
                                    <MudSlider Size="Size.Small" @bind-Value="@DeltaSizeH" Step="0.005" Min=0.0 Max=3 T=@double Variant="Variant.Filled">
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">Size (Horizontal)</MudText>
                                            <MudText Typo="Typo.caption">@DeltaSizeH.ToString("0.000")</MudText>
                                        </MudStack>
                                    </MudSlider>
                                </MudListItem>

                                <MudListItem Dense="true">
                                    <MudSlider Size="Size.Small" @bind-Value="@DeltaSizeV" Step="0.01" Min=0.0 Max=10.00 T=@double Variant="Variant.Filled">
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">Size (Vertical)</MudText>
                                            <MudText Typo="Typo.caption">@DeltaSizeV.ToString("0.000")</MudText>
                                        </MudStack>
                                    </MudSlider>
                                </MudListItem>

                                <MudListItem Dense="true">
                                    <MudSlider Size="Size.Small" @bind-Value="@DeltaOpacity" Step="0.0025" Min=0.0 Max=1.0 T=@double Variant="Variant.Filled">
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">Opacity</MudText>
                                            <MudText Typo="Typo.caption">@DeltaOpacity.ToString("P2")</MudText>
                                        </MudStack>
                                    </MudSlider>
                                </MudListItem>
                            </NestedList>
                        </MudListItem>
                        <MudListItem Dense=true Icon="@Icons.Material.Filled.AlignHorizontalRight" Text="Profile" Expanded=false>
                            <NestedList>
                                <MudListItem Dense="true" OnClick="() => ProfileVisible = !ProfileVisible">
                                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">Show on Chart</MudText>
                                        <MudSwitch @bind-Value="ProfileVisible" Color="MudBlazor.Color.Primary" Size="Size.Small"></MudSwitch>
                                    </MudStack>
                                </MudListItem>
                                <MudListItem Dense="true">
                                    <MudSlider Size="Size.Small" @bind-Value="@ProfileSizeH" Step="0.005" Min=0.0 Max=3 T=@double Variant="Variant.Filled">
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">Size (Horizontal)</MudText>
                                            <MudText Typo="Typo.caption">@ProfileSizeH.ToString("0.000")</MudText>
                                        </MudStack>
                                    </MudSlider>
                                </MudListItem>

                                <MudListItem Dense="true">
                                    <MudSlider Size="Size.Small" @bind-Value="@ProfileSizeV" Step="0.01" Min=0.0 Max=10.00 T=@double Variant="Variant.Filled">
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">Size (Vertical)</MudText>
                                            <MudText Typo="Typo.caption">@ProfileSizeV.ToString("0.000")</MudText>
                                        </MudStack>
                                    </MudSlider>
                                </MudListItem>

                                <MudListItem Dense="true">
                                    <MudSlider Size="Size.Small" @bind-Value="@ProfileOpacity" Step="0.0025" Min=0.0 Max=1.0 T=@double Variant="Variant.Filled">
                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">Opacity</MudText>
                                            <MudText Typo="Typo.caption">@ProfileOpacity.ToString("P2")</MudText>
                                        </MudStack>
                                    </MudSlider>
                                </MudListItem>
                            </NestedList>
                        </MudListItem>
                    </NestedList>
                </MudListItem>
            </MudList>

        </MudPaper>

        @* BUBBLES E AGENTS *@
        <MudPaper Class="p-1 mt-1" Outlined Elevation="0">
            <MudList T="string" Dense>
                <MudListItem Dense=true Icon="@Icons.Material.Filled.BubbleChart" Text="Bubbles" Expanded=true>
                    <NestedList>
                        <MudListItem Dense="true" OnClick="() => BubbleVisible = !BubbleVisible">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Show on Chart</MudText>
                                <MudSwitch @bind-Value="BubbleVisible" Color="MudBlazor.Color.Primary" Size="Size.Small"></MudSwitch>
                            </MudStack>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSlider Size="Size.Small" Value="@ThresholdBubble" ValueChanged="ThresholdBubbleChanged" Step="25" Min=0 Max=5000 T=@int Variant="Variant.Filled">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Amount</MudText>
                                    <MudText Typo="Typo.caption">@ThresholdBubble.ToString()</MudText>
                                </MudStack>
                            </MudSlider>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSlider Size="Size.Small" @bind-Value="@BubbleSize" Step="0.0025" Min=0.0 Max=1.0 T=@double Variant="Variant.Filled">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Size</MudText>
                                    <MudText Typo="Typo.caption">@BubbleSize.ToString("0.000")</MudText>
                                </MudStack>
                            </MudSlider>
                        </MudListItem>
                        <MudListItem Dense="true">
                            <MudSlider Size="Size.Small" @bind-Value="@BubbleOpacity" Step="0.0025" Min=0.0 Max=1.0 T=@double Variant="Variant.Filled">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Opacity</MudText>
                                    <MudText Typo="Typo.caption">@BubbleOpacity.ToString("P2")</MudText>
                                </MudStack>
                            </MudSlider>
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.Palette" Text="Colors" Expanded=false>
                            <NestedList>
                                <MudListItem Dense="true">
                                    <MudStack Row Spacing="2" Justify="Justify.SpaceEvenly" AlignItems="AlignItems.Center">
                                        <MudColorPicker 
                                            Label="Buy" 
                                            ColorPickerView="ColorPickerView.Spectrum"
                                            ShowModeSwitch=false
                                            ShowSliders=true
                                            ShowAlpha=false
                                            @bind-Text="ColorBuyer"/>
                                        <div style="width:32px; height:32px; background-color: @(ColorBuyer);" class="mr-2"></div>
                                    </MudStack>
                                </MudListItem>

                                <MudListItem Dense="true">
                                    <MudStack Row Spacing="2" Justify="Justify.SpaceEvenly" AlignItems="AlignItems.Center">
                                        <MudColorPicker Label="Sell"
                                            ColorPickerView="ColorPickerView.Spectrum"
                                            ShowModeSwitch=false
                                            ShowSliders=true
                                            ShowAlpha=false
                                            @bind-Text="ColorSeller" />
                                        <div style="width:32px; height:32px; background-color: @(ColorSeller);" class="mr-2"></div>
                                    </MudStack>
                                </MudListItem>
                            </NestedList>
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.People" Text="Agents" Expanded=true>
                            <NestedList>
                                <MudList Dense T="Ticks2.Agents?" ReadOnly=true Class="ml-3">
                                    <MudListItem Dense=true >

                                            <MudCheckBox Dense Value="@(SelectedAgents.Count == AllBubbleAgents.Count)" ValueChanged=" async (bool c) => await SelectAllAgents()">
                                            <MudText Typo="Typo.caption">
                                                Selecionar Todos
                                            </MudText>
                                        </MudCheckBox>     
                                    </MudListItem>

                                    <MudDivider />
                                    @foreach (Ticks2.Agents? agent in AllBubbleAgents.OrderBy(q => q.Description()))
                                    {
                                        if (agent is null) continue;

                                        <MudListItem Dense="true">

                                            <MudCheckBox Dense Value="@SelectedAgents.Contains(agent)" ValueChanged="async (bool c) => await ToggleAgent(agent)">
                                                <MudText Typo="Typo.caption">
                                                    @agent.Description() (@((int)agent))
                                                </MudText>
                                            </MudCheckBox>
                                        </MudListItem>
                                    }
                                </MudList>
                            </NestedList>
                        </MudListItem>
                    </NestedList>
                </MudListItem>
            </MudList>
        </MudPaper>


    </MudDrawer>
    <Vizor.ECharts.EChart @ref="EChart"
                          Renderer="Vizor.ECharts.ChartRenderer.Canvas"
                          Options="ChartOptions"
                          Width="auto"
                          Height="800px"
                          />

</MudDrawerContainer>                   