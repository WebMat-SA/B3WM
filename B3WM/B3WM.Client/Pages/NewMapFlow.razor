@code {
    public string Symbol { get; set; } = "WINFUT";

    public int throttlingDelayMs { get; set; } = 500;
    public bool isLoading { get; set; } = false;

    private Vizor.ECharts.EChart? EChart;
    private PeriodicTimer timer;

    public required MapFlowConfigDrawer MapFlowConfigDrawer { get; set; }
    private MainHubClient? HubClient { get; set; }

    private IRange<int> _dateRange { get; set; } = new MudExRange<int>(0, 0);
    public bool openDrawer { get; set; } = false;
    public bool openDrawerBubbleNotify { get; set; } = false;

    private List<BarStorageItem> BarStorageItem { get; set; } = new List<BarStorageItem>();
    private IList<BarStorageItem> BarStorageItemTimeFrameFilter => BarStorageItem.Where(q => q.TimeFrame == MapFlowConfigDrawer?.TimeFrame).ToList();
    private BarStorageItem CurrentBar { get; set; } = new BarStorageItem();

    private List<BubbleStorageItem> Bubbles { get; set; } = new List<BubbleStorageItem>();
    private List<VolumeLevel> VolumeLevels { get; set; } = new List<VolumeLevel>();
    private List<VolumeLevel>? _filteredVolumeLevels { get; set; }
    private bool _volumeFilterActive { get; set; }

    private List<Shared.Models.StructureStorageItem> StructureStorageItemTimeFrameFilter => StructureStorageItem.Where(q => q.TimeFrame == MapFlowConfigDrawer?.TimeFrame).ToList();
    private List<Shared.Models.StructureStorageItem> StructureStorageItem { get; set; } = new List<Shared.Models.StructureStorageItem>();


    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            this.timer = new PeriodicTimer(TimeSpan.FromMilliseconds(throttlingDelayMs));
            _ = Task.Run(ProcessLoop);
        }
        base.OnAfterRender(firstRender);
    }

    private async Task ProcessLoop()
    {
        while (await timer.WaitForNextTickAsync())
        {
            try
            {
                await GenerateChart();
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error in ProcessLoop: " + ex.Message);
            }
            //await Task.Delay(1000); // Aguarda 1 segundo antes de atualizar novamente
        }
    }

    public async Task VolumeUpdate(VolumeLevelStorageItem volumes)
    {
        try
        {

            var sw = Stopwatch.StartNew();
            VolumeLevels = volumes.Volumes as List<VolumeLevel> ?? volumes.Volumes.ToList();

            var count = BarStorageItemTimeFrameFilter.Count;
            var isFullRange = count > 0 && _dateRange.End >= count;

            if (isFullRange && MapFlowConfigDrawer?.ProfileAutoByPriceStructure == true)
            {
                var startBar = BarStorageItemTimeFrameFilter.ElementAtOrDefault(Math.Max(0, _dateRange.Start - 1));
                _filteredVolumeLevels = VolumeLevelStorageItem.Operation(volumes.Volumes ?? new(), startBar.VolumeLevel ?? new(), "Diff").OrderBy(q => q.Price).ToList();
                _volumeFilterActive = true;
            }
            //Console.WriteLine(System.Text.Json.JsonSerializer.Serialize(volumes));

            // rebuild simplified chart when volume data arrives
            //await GenerateChart();

            sw.Stop();
            //Console.WriteLine($"{sw.ElapsedMilliseconds} ms - VolumeUpdate - {DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss:fff")}");
        }
        catch (Exception e)
        {
            Console.WriteLine("VolumeUpdate Error" + e.Message);
        }

        return;
    }

    public async Task NewBubble(BubbleStorageItem data)
    {
        if (MapFlowConfigDrawer == null) return;
        var sw = Stopwatch.StartNew();

        if (MapFlowConfigDrawer._allBubbleAgents.Add((Ticks2.Agents)data.Agent) && !MapFlowConfigDrawer.SelectedAgents.Contains((Ticks2.Agents)data.Agent))
            MapFlowConfigDrawer.SelectedAgents.Add((Ticks2.Agents)data.Agent);
        Bubbles.Add(data);
        // trigger immediate sound/notification in the bubble drawer
        try
        {
            await MapFlowConfigDrawer.MapFlowBubbleDrawer?.NotifyNewBubbleAsync();
        }
        catch
        {
            // ignore errors from JS interop
        }
        // After adding a new bubble, rebuild the simple chart so bubbles are shown


        //await GenerateChart();

        sw.Stop();
        //Console.WriteLine($"{sw.ElapsedMilliseconds} ms - NewBubble");
        return;
    }
    public async Task NewStructure(StructureStorageItem structure)
    {
        StructureStorageItem.Add(structure);
    }
    public async Task NewBar(BarStorageItem bar)
    {
        var count = BarStorageItem.Count;
        var isFullRange = count > 0 && _dateRange.End >= count;

        var sw = Stopwatch.StartNew();

        if (bar == null || bar.Date == default) return;

        var existing = BarStorageItem.FirstOrDefault(b => b.Date == bar.Date && b.TimeFrame == bar.TimeFrame);
        if (existing != null)
        {
            existing.Open = bar.Open;
            existing.High = bar.High;
            existing.Low = bar.Low;
            existing.Close = bar.Close;
            existing.Volume = bar.Volume;
        }
        else
        {
            // Cópia defensiva: armazenar nossa própria instância para não depender da referência do callback.
            BarStorageItem.Add(bar);
        }


        if (isFullRange)
        {
            _dateRange = new MudExRange<int>(_dateRange.Start, BarStorageItemTimeFrameFilter.Count);
            ApplyVolumeFilter(_dateRange);
        }

        //Console.WriteLine(bar);
        // rebuild simplified chart when new bar arrives
        //await GenerateChart();
        sw.Stop();
        //Console.WriteLine($"{sw.ElapsedMilliseconds} ms - NewBar - {DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss:fff")}");
        return;
    }
    public Task NewCurrentBar(BarStorageItem bar)
    {
        var sw = Stopwatch.StartNew();

        CurrentBar = bar;

        if (EChart != null)
        {
            //_ = GenerateChart();
        }


        sw.Stop();
        //Console.WriteLine($"{sw.ElapsedMilliseconds} ms - NewCurrentBar - {DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss:fff")}"); 

        return Task.CompletedTask;
    }

    private async void SymbolChange(string value)
    {
        Symbol = value;
        await MapFlowConfigDrawer?.ForceReload();
        StateHasChanged();
    }

