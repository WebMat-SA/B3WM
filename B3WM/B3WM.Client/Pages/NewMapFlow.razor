        // }
        // else
        // {
        //     var bars = BarStorageItem.OrderBy(q => q.Date).ToList();

        //     var startBar = bars.ElementAtOrDefault(Math.Max(0, newRange.Start - 1));
        //     var endBar = bars.ElementAtOrDefault(newRange.End);
        //     if (startBar != null && endBar != null && HubClient != null)
        //     {
        //         //_filteredVolumeLevels = VolumeLevelStorageItem.FromTo(bars, startBar.Date, endBar.Date);
        //         _filteredVolumeLevels = VolumeLevelStorageItem.Operation(endBar.VolumeLevel ?? new(), startBar.VolumeLevel ?? new(), "Diff").OrderBy(q => q.Price).ToList();
