    private string IndexEndToDateStringBars(IRange<int> range)
    {
        string format = BarStorageItem.ElementAtOrDefault(range.End)?.Date.Date == BarStorageItem.ElementAtOrDefault(range.Start)?.Date.Date ? "HH:mm" : "dd/MM HH:mm";

        return $" {BarStorageItem.ElementAtOrDefault(range.End)?.Date.ToString(format)}";
    }
    private string IndexStartToDateStringBars(IRange<int> range)
    {
        string format = BarStorageItem.ElementAtOrDefault(range.End)?.Date.Date == BarStorageItem.ElementAtOrDefault(range.Start)?.Date.Date ? "HH:mm" : "dd/MM HH:mm";
        return $"{BarStorageItem.ElementAtOrDefault(range.Start)?.Date.ToString(format)}";
    }


