    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _processCts = new CancellationTokenSource();
            _processTask = ProcessLoopAsync();
            _ = WatchdogAsync(_processCts.Token);
        }
        base.OnAfterRender(firstRender);
    }

    private async Task ProcessLoopAsync()
    {
        var token = _processCts!.Token;
        var chartGenTask = Task.CompletedTask;
        while (!token.IsCancellationRequested)
        {
            var loopStart = DateTime.UtcNow;
            try
            {
                // Aguarda o intervalo entre gerações de chart
                await Task.Delay(throttlingDelayMs, token);

                // Gera o chart - se a chamada anterior ainda estiver pendente, pula
                if (chartGenTask.IsCompleted)
                {
                    chartGenTask = InvokeAsync(GenerateChart);
                    await chartGenTask;
                    _lastChartUpdate = DateTime.UtcNow;
                }
                else
                {
                    Console.WriteLine("[CHART] GenerateChart ainda ocupado, pulando tick");
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch (Exception ex)
            {
                Console.WriteLine("[CHART] ProcessLoop error: " + ex.Message);
            }

            // Garante pausa mínima entre chamadas
            var elapsed = DateTime.UtcNow - loopStart;
            if (elapsed.TotalMilliseconds < throttlingDelayMs)
            {
                try { await Task.Delay(throttlingDelayMs - (int)elapsed.TotalMilliseconds, token); }
                catch (OperationCanceledException) { break; }
            }
        }
    }

    private async Task WatchdogAsync(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(5000, token);
                var elapsed = DateTime.UtcNow - _lastChartUpdate;
                if (elapsed.TotalSeconds > 10)
                {
                    Console.WriteLine($"[WATCHDOG] Chart sem update há {elapsed.TotalSeconds:F1}s - executando recovery");

                    // 1. Tenta reiniciar o ProcessLoop se morreu
                    if (_processTask?.IsCompleted == true)
                    {
                        Console.WriteLine("[WATCHDOG] Reiniciando ProcessLoop");
                        _processTask = ProcessLoopAsync();
                    }

                    // 2. Tenta religar SignalR se desconectou
                    if (HubClient is { _started: true })
                    {
                        Console.WriteLine("[WATCHDOG] Reconectando SignalR");
                        _ = HubClient.StartConnection();
                    }
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch (Exception ex)
            {
                Console.WriteLine("Watchdog error: " + ex);
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        _processCts?.Cancel();
        _processCts?.Dispose();
        if (_processTask != null)
        {
            try { await _processTask; } catch { /* ignore */ }
        }
    }

    public async Task VolumeUpdate(VolumeLevelStorageItem volumes)
    {
        try
        {
            var sw = Stopwatch.StartNew();
            VolumeLevels = volumes.Volumes as List<VolumeLevel> ?? volumes.Volumes.ToList();
            _volumeDataVersion++;
            Console.WriteLine($"[DATA] VolumeUpdate: {volumes.Date:HH:mm:ss} levels={volumes.Volumes?.Count ?? 0}");

            var count = BarStorageItemTimeFrameFilter.Count;
            var isFullRange = count > 0 && _dateRange.End >= count;

            // Auto-filter: quando o range está completo e o toggle AutoMode está ativo
            if (isFullRange && MapFlowConfigDrawer?.ProfileAutoByPriceStructure == true)
            {
                var startBar = BarStorageItemTimeFrameFilter.ElementAtOrDefault(Math.Max(0, _dateRange.Start - 1));
                _filteredVolumeLevels = VolumeLevelStorageItem.Operation(volumes.Volumes ?? new(), startBar.VolumeLevel ?? new(), "Diff").OrderBy(q => q.Price).ToList();
                _volumeFilterActive = true;
                _filteredVolumeDataVersion++;
            }
            // Filter ativo manualmente: atualiza o volume filtrado com dados ao vivo
            // Se o snapshot da barra de inicio nao estiver disponivel, preserva o filtro existente
            else if (_volumeFilterActive && _filteredVolumeLevels != null)
            {
                var bars = BarStorageItemTimeFrameFilter.OrderBy(q => q.Date).ToList();
                var startBar = bars.ElementAtOrDefault(Math.Max(0, _dateRange.Start - 1));
                if (startBar != null && startBar.VolumeLevel is { Count: > 0 })
                {
                    _filteredVolumeLevels = VolumeLevelStorageItem.Operation(volumes.Volumes ?? new(), startBar.VolumeLevel, "Diff").OrderBy(q => q.Price).ToList();
                    _filteredVolumeDataVersion++;
                }
            }
            //Console.WriteLine(System.Text.Json.JsonSerializer.Serialize(volumes));

            // rebuild simplified chart when volume data arrives
            //await GenerateChart();

            sw.Stop();
            //Console.WriteLine($"{sw.ElapsedMilliseconds} ms - VolumeUpdate - {DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss:fff")}");
        }
        catch (Exception e)
        {
            Console.WriteLine("VolumeUpdate Error" + e.Message);
        }

        return;
    }

    public async Task NewBubble(BubbleStorageItem data)
    {
        if (MapFlowConfigDrawer == null) return;
        var sw = Stopwatch.StartNew();

        if (MapFlowConfigDrawer._allBubbleAgents.Add((Ticks2.Agents)data.Agent) && !MapFlowConfigDrawer.SelectedAgents.Contains((Ticks2.Agents)data.Agent))
            MapFlowConfigDrawer.SelectedAgents.Add((Ticks2.Agents)data.Agent);
        Bubbles.Add(data);
        if (Bubbles.Count > MaxBubbles)
            Bubbles.RemoveRange(0, Bubbles.Count - MaxBubbles);

        if (data.Date > HubClient._lastBubbleTime)
            HubClient._lastBubbleTime = data.Date;

        // trigger immediate sound/notification in the bubble drawer
        try
        {
            await MapFlowConfigDrawer.MapFlowBubbleDrawer?.NotifyNewBubbleAsync();
        }
        catch
        {
            // ignore errors from JS interop
        }
        // After adding a new bubble, rebuild the simple chart so bubbles are shown


        //await GenerateChart();

        sw.Stop();
        //Console.WriteLine($"{sw.ElapsedMilliseconds} ms - NewBubble");
        return;
    }
    public async Task NewStructure(StructureStorageItem structure)
    {
        if (structure.Symbol != Symbol) return;
        StructureStorageItem.Add(structure);
        if (MapFlowConfigDrawer?.ProfileAutoByPriceStructure == true)
            ApplyVolumeFilter(new MudExRange<int>(0, Math.Max(0, BarStorageItemTimeFrameFilter.Count)));
    }
    public Task NewForecast(AdjustmentForecastItem forecast)
    {
        _currentForecast = forecast;
        _forecastHistory.Add((forecast.Time, forecast.Vwap));
        if (_forecastHistory.Count > MaxForecastHistory)
            _forecastHistory.RemoveRange(0, _forecastHistory.Count - MaxForecastHistory);
        return Task.CompletedTask;
    }
    public async Task NewIndicatorValue(IndicatorValue data)
    {
        var key = $"{data.IndicatorName}.{data.Key}|{data.TimeFrame}";
        if (!_indicatorData.ContainsKey(key))
        {
            _indicatorData[key] = new();
            var baseKey = $"{data.IndicatorName}.{data.Key}";
            if (!_indicatorPlotType.ContainsKey(baseKey))
                _indicatorPlotType[baseKey] = data.PlotType;
        }
        _indicatorData[key].Add((data.Time, data.Value));
        if (_indicatorData[key].Count > 500)
            _indicatorData[key].RemoveRange(0, _indicatorData[key].Count - 500);
        await InvokeAsync(StateHasChanged);
    }
    private void RemoveIndicatorData(string indicatorName)
    {
        var prefix = $"{indicatorName}.";
        var dataKeysToRemove = _indicatorData.Keys.Where(k => k.StartsWith(prefix)).ToList();
        foreach (var k in dataKeysToRemove)
            _indicatorData.Remove(k);
        var plotKeysToRemove = _indicatorPlotType.Keys.Where(k => k.StartsWith(prefix)).ToList();
        foreach (var k in plotKeysToRemove)
            _indicatorPlotType.Remove(k);
    }
    public async Task OnIndicatorToggled(string indicatorName)
    {
        RemoveIndicatorData(indicatorName);
        await InvokeAsync(StateHasChanged);
    }
    private static BarStorageItem CloneBar(BarStorageItem bar)
    {
        return new BarStorageItem
        {
            Date = bar.Date,
            Open = bar.Open,
            High = bar.High,
            Low = bar.Low,
            Close = bar.Close,
            Volume = bar.Volume,
            VolumeLevel = bar.VolumeLevel
        };
    }
    public async Task NewBar(BarStorageItem bar)
    {
        var count = BarStorageItem.Count;
        var isFullRange = count > 0 && _dateRange.End >= count;

        var sw = Stopwatch.StartNew();

        if (bar == null || bar.Date == default) return;

        var existing = BarStorageItem.FirstOrDefault(b => b.Date == bar.Date && b.TimeFrame == bar.TimeFrame);
        if (existing != null)
        {
            existing.Open = bar.Open;
            existing.High = bar.High;
            existing.Low = bar.Low;
            existing.Close = bar.Close;
            existing.Volume = bar.Volume;
            if (bar.VolumeLevel is { Count: > 0 })
                existing.VolumeLevel = bar.VolumeLevel;
        }
        else
        {
            BarStorageItem.Add(CloneBar(bar));
        }

        if (bar.Date > HubClient._lastBarTime)
            HubClient._lastBarTime = bar.Date;


        if (isFullRange)
        {
            _dateRange = new MudExRange<int>(_dateRange.Start, BarStorageItemTimeFrameFilter.Count);
            ApplyVolumeFilter(_dateRange);
        }

        sw.Stop();
        return;
    }
    public Task NewCurrentBar(BarStorageItem bar)
    {
        var sw = Stopwatch.StartNew();
        CurrentBar = bar;
        if (bar.Date > HubClient._lastBarTime)
            HubClient._lastBarTime = bar.Date;
        Console.WriteLine($"[DATA] NewCurrentBar: {bar.Date:HH:mm:ss} C:{bar.Close} V:{bar.Volume}");
        sw.Stop();
        //Console.WriteLine($"{sw.ElapsedMilliseconds} ms - NewCurrentBar");
        return Task.CompletedTask;
    }
    public Task HandleMissedBars(List<BarStorageItem> bars)
    {
        foreach (var bar in bars)
            NewBar(bar);
        return Task.CompletedTask;
    }
    public Task HandleMissedBubbles(List<BubbleStorageItem> bubbles)
    {
        foreach (var b in bubbles)
            NewBubble(b);
        return Task.CompletedTask;
    }

    private async void SymbolChange(string value)
    {
        Symbol = value;
        Navigation.NavigateTo($"/newmapflow/{value.ToLower()}");
        await MapFlowConfigDrawer?.ForceReload();
        StateHasChanged();
    }

    private void ApplyVolumeFilter(IRange<int> newRange)
    {
        _dateRange = newRange;

        var count = BarStorageItemTimeFrameFilter.Count;
        if (count == 0) return;

        var isFullRange = newRange.Start == 0 && newRange.End >= count;
        if (isFullRange)
        {
            _volumeFilterActive = false;
            _filteredVolumeLevels = null;
        }
        else
        {
            var bars = BarStorageItemTimeFrameFilter.OrderBy(q => q.Date).ToList();
            var startBar = bars.ElementAtOrDefault(Math.Max(0, newRange.Start - 1));
            var endBar = bars.ElementAtOrDefault(newRange.End);

            if (startBar != null && endBar != null)
            {
                // Tenta usar VolumeLevel das barras (snapshots cumulativos do disco)
                var startLevels = startBar.VolumeLevel;
                var endLevels = endBar.VolumeLevel;

                if (endLevels is { Count: > 0 } && startLevels is { Count: > 0 })
                {
                    // Ambos os lados têm snapshot cumulativo → diff preciso do range
                    _filteredVolumeLevels = VolumeLevelStorageItem.Operation(endLevels, startLevels, "Diff").OrderBy(q => q.Price).ToList();
                    _volumeFilterActive = true;
                    _filteredVolumeDataVersion++;
                }
                else
                {
                    // Tenta encontrar snapshots alternativos mais próximos quando as barras exatas não têm VolumeLevel
                    BarStorageItem? foundStart = startLevels is { Count: > 0 } ? startBar : null;
                    BarStorageItem? foundEnd = endLevels is { Count: > 0 } ? endBar : null;

                    if (foundStart == null)
                    {
                        for (int i = Math.Max(0, newRange.Start - 1) - 1; i >= 0; i--)
                        {
                            if (bars[i].VolumeLevel is { Count: > 0 })
                            { foundStart = bars[i]; break; }
                        }
                    }

                    if (foundEnd == null && foundStart != null)
                    {
                        for (int i = newRange.End + 1; i < bars.Count; i++)
                        {
                            if (bars[i].VolumeLevel is { Count: > 0 })
                            { foundEnd = bars[i]; break; }
                        }
                    }

                    if (foundStart != null && foundEnd != null)
                    {
                        _filteredVolumeLevels = VolumeLevelStorageItem.Operation(foundEnd.VolumeLevel!, foundStart.VolumeLevel!, "Diff").OrderBy(q => q.Price).ToList();
                        _volumeFilterActive = true;
                        _filteredVolumeDataVersion++;
                    }
                    else if (foundStart != null)
                    {
                        _filteredVolumeLevels = VolumeLevelStorageItem.Operation(VolumeLevels, foundStart.VolumeLevel!, "Diff").OrderBy(q => q.Price).ToList();
                        _volumeFilterActive = true;
                        _filteredVolumeDataVersion++;
                    }
                }
            }
        }

        StateHasChanged();
    }
    private string IndexEndToDateStringBars(IRange<int> range)
    {
        string format = BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.End)?.Date.Date == BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.Start)?.Date.Date ? "HH:mm" : "dd/MM HH:mm";

        return $" {BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.End)?.Date.ToString(format)}";
    }
    private string IndexStartToDateStringBars(IRange<int> range)
    {
        string format = BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.End)?.Date.Date == BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.Start)?.Date.Date ? "HH:mm" : "dd/MM HH:mm";
        return $"{BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.Start)?.Date.ToString(format)}";
    }


