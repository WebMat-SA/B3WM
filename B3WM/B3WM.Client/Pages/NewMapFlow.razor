    private string IndexEndToDateStringBars(IRange<int> range)
    {
        string format = BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.End)?.Date.Date == BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.Start)?.Date.Date ? "HH:mm" : "dd/MM HH:mm";

        return $" {BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.End)?.Date.ToString(format)}";
    }
    private string IndexStartToDateStringBars(IRange<int> range)
    {
        string format = BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.End)?.Date.Date == BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.Start)?.Date.Date ? "HH:mm" : "dd/MM HH:mm";
        return $"{BarStorageItemTimeFrameFilter.ElementAtOrDefault(range.Start)?.Date.ToString(format)}";
    }


    // Objetos estáticos de eixo (nunca mudam entre renders)
    private readonly AxisLabel _yAxisLabelInt = new AxisLabel { Show = true, Color = "#aaa", Formatter = new JavascriptFunction("function(value) { return Math.round(value); }") };
    private readonly SplitLine _splitLineGuides = new SplitLine { Show = true, LineStyle = new LineStyle { Color = "rgba(128, 128, 128, 0.02)" } };

    private Vizor.ECharts.ChartOptions ChartOptions = new() {
        Grid = new Vizor.ECharts.Grid
        {
            Left = "10",
            Right = "10",
            Bottom = "15%",
            Top = "10",
            ContainLabel = true
        },
        // Ajuste do DataZoom para não afetar o eixo de volume (XAxisIndex 1)
        DataZoom = new List<Vizor.ECharts.IDataZoom>
        {
            // --- ZOOM HORIZONTAL (Tempo) ---
            new Vizor.ECharts.InsideDataZoom { XAxisIndex = new [] { 0.0 } },
            //new Vizor.ECharts.SliderDataZoom { XAxisIndex = new[] { 0.0 }, Top = "92%" },

            // --- ZOOM VERTICAL (Preço) ---
            // Inside permite usar o Scroll do mouse sobre o gráfico para dar zoom no preço
            new Vizor.ECharts.InsideDataZoom { YAxisIndex = new[] { 0.0, 1.0 } },
            // Slider adiciona aquela barra lateral para controle preciso (opcional)
            //new Vizor.ECharts.SliderDataZoom { YAxisIndex = new[] { 0.0, 1.0 }, Left = "1%" }
        },

        Tooltip = new Tooltip
        {
            // Mudamos para Item para que ele Priorize o objeto sob o mouse,
            // mas ainda consiga mostrar informações do eixo se configurado.
            Trigger = TooltipTrigger.Item,
            AxisPointer = new AxisPointer
            {
                Type = AxisPointerType.Cross,
                Label = new Label
                {
                    Show = true,
                    Formatter = new JavascriptFunction("function(params) { var v = params.value != null ? params.value : params.axisValue; return typeof v === 'number' ? Math.round(v) : v; }")
                }
            },
            Formatter = new JavascriptFunction(@"
                function (params) {
                    if (!params) return '';

                    // 1. LÓGICA PARA BOLHAS (Aggressive)
                    if (params.seriesName && params.seriesName.includes('Aggressive')) {
                        var time = params.data[0];
                        var price = params.data[1];
                        var amount = params.data[2];
                        var agent = params.data[3];
                        var color = params.seriesName.includes('Blue') ? '#4488ff' : '#ff4444';

                        return `<div style='border-bottom: 1px solid #ccc; margin-bottom: 5px;'>
                                    <b style='color:${color}'>${agent}</b>
                                </div>
                                Qtd: <b>${amount}</b><br/>
                                Preço: <b>${price}</b><br/>
                                Hora: ${time}`;
                    }

                    // 2. LÓGICA PARA CANDLES (d = [Open, Close, Low, High] - índice 0,1,2,3)
                    if (params.seriesName === 'Candle') {
                        var d = params.data;
                        var color = d[2] >= d[1] ? '#00fa9a' : '#ff4500';

                        return `<b>${params.name}</b><br/>
                                Abertura: ${d[1]}<br/>
                                Fechamento: ${d[2]}<br/>
                                Mínima: ${d[3]}<br/>
                                Máxima: ${d[4]}<br/>
                                Amplitude: ${d[4]-d[3]}`;
                    }

                    return '';
                }
            ")
        }
    };
    private async Task GenerateChart()
    {
        if (EChart is null) return;
        var swTotal = Stopwatch.StartNew();

        var inv = System.Globalization.CultureInfo.InvariantCulture;
        double _cachedPriceStep = 0.5;

        #region Candles and graph setup

        //var swBars = Stopwatch.StartNew();
        var hasCurrentBarInBars = CurrentBar != null && BarStorageItemTimeFrameFilter.Any(b => b.Date == CurrentBar.Date);
        var includeCurrentBar = !hasCurrentBarInBars && CurrentBar != null && CurrentBar.Date != default;

        List<BarStorageItem> bars;

        bars = new List<BarStorageItem>(BarStorageItemTimeFrameFilter.Count);
        foreach (var bar in BarStorageItemTimeFrameFilter/* .Where(q => q.Date.TimeOfDay >= _startTime && q.Date.TimeOfDay <= _endTime) */)
            bars.Add(bar);

        if (includeCurrentBar && CurrentBar != null)
            bars.Add(CurrentBar);

        bars = bars.GroupBy(b => b.Date).Select(g => g.First()).OrderBy(b => b.Date).ToList();

        if (bars.Count == 0) return;

        double barsMin = double.PositiveInfinity;
        double barsMax = double.NegativeInfinity;
        foreach (var b in bars)
        {
            var low = (double)b.Low;
            var high = (double)b.High;
            if (low < barsMin) barsMin = low;
            if (high > barsMax) barsMax = high;
        }

        double actualMin = barsMin;
        double actualMax = barsMax;

        double range = actualMax - actualMin;
        if (range <= 0) range = Math.Max(1.0, Math.Abs(actualMax) * 0.01);

        double paddingFactor = 0.25;
        double minPrice = actualMin - (range * paddingFactor);
        double maxPrice = actualMax + (range * paddingFactor);

        List<string> categoryData;
        List<object[]> values;

        categoryData = new List<string>(bars.Count);
        values = new List<object[]>(bars.Count);
        foreach (var row in bars)
        {
            categoryData.Add(row.Date.ToString("dd/MM HH:mm"));
            values.Add(new object[] { row.Open, row.Close, row.Low, row.High });
        }

        var _cachedCandleSeriesObj = new CandlestickSeries
            {
                Name = "Candle",
                Data = values,
                Z = 2,
                Clip = false, // Evita que o candle inteiro suma ao dar zoom quando as bordas (high/low) saem da área visível
                ItemStyle = new ItemStyle { Color = "#ffffff", Color0 = "#000000", BorderColor = "#ffffff", BorderColor0 = "#ffffff" }
            };

        var lastPrice = includeCurrentBar && CurrentBar != null ? CurrentBar.Close : bars.Last().Close;

        var markLineEntries = new List<object>(){
            new {
                // yAxis positions the horizontal line at the given value
                yAxis = lastPrice,
                // disable animation for the static guide
                animation = true,
                // also explicitly ensure per-item symbol fields are none/zero (defensive)
                symbol = new[] { "none" },
                symbolSize = new[] { 0 },
                // per-line label configuration
                // configure label to be vertically centered on the axis column
                label = new {
                    show = true,
                    position = "end",
                    distance = 0,
                    // use ECharts accepted values: 'middle' vertically
                    verticalAlign = "middle",
                    align = "left",
                    // white text on red background
                    color = "#444444",
                    backgroundColor = "#aaaaaa",
                    padding = new[] { 2, 6, 2, 6 },
                    borderRadius = 4,
                    // formatter can be a JS function; use the wrapper type to emit raw JS
                    formatter = new JavascriptFunction($"function() {{ return '{lastPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)}'; }}")
                },
                // per-line style (override top-level if needed)
                lineStyle = new {
                    type = "dashed",
                    color = "#aaaaaa",
                    width = 1
                }
            }
        };

        // vertical separators between different days
        for (int i = 1; i < bars.Count; i++)
        {
            if (bars[i].Date.Date != bars[i - 1].Date.Date)
            {
                // use xAxis category value to position vertical separator at the bar index
                markLineEntries.Add(new
                {
                    xAxis = i - 1,
                    animation = false,
                    symbol = new[] { "none" },
                    symbolSize = new[] { 0 },
                    label = new { show = false },
                    lineStyle = new
                    {
                        type = "solid",
                        color = "rgba(200,200,200,0.15)",
                        width = 1
                    }
                });
            }
        }

        _cachedCandleSeriesObj.MarkLine = new MarkLine
            {
                Silent = true,
            // ensure endpoints do not render symbols at the MarkLine level
                Symbol = null,
                SymbolSize = 0,
            // Data can be an array of objects understood by ECharts. We provide a simple anonymous object
            // with yAxis value and a nested label and lineStyle for that single line.
                Data = markLineEntries.ToArray()
            };

        #endregion

        #region Bubbles

        var redList = new List<(DateTime Time, object[] Data)>();
        var blueList = new List<(DateTime Time, object[] Data)>();


        var symbolSizeFunction = new NumberArrayOrFunction(new JavascriptFunction($@"
                function (v) {{
                    var min = {MapFlowConfigDrawer._bubbleSizeRange.Start.ToString(inv)};
                    var max = {MapFlowConfigDrawer._bubbleSizeRange.End.ToString(inv)};
                    var result = v[2];

                    if (result < min){{
                        result = min;
                    }}else if (result > max){{
                        result = max;
                    }}

                    // 'result' already contains the computed numeric size. Return it
                    // directly (or 0 when bubbles are hidden). Removing the invalid
                    // 'format invariant' token which produced a malformed JS snippet.

                    return result * {MapFlowConfigDrawer.BubbleSize.ToString(inv)} * {(MapFlowConfigDrawer.BubbleVisible ? 1 : 0)};
                }}"));
        if (MapFlowConfigDrawer.BubbleVisible) {
        foreach (var e in Bubbles)
        {
            //ignora filtros de agentes e bubbles menores que a threshold setada
            if (!MapFlowConfigDrawer.SelectedAgents.Contains((Ticks2.Agents)e.Agent) || e.Amount < MapFlowConfigDrawer.ThresholdBubble) continue;
            var arr = new object[] {
                    e.Date.GetCandleStart(MapFlowConfigDrawer.TimeFrame).ToString("dd/MM HH:mm"),
                    e.Price,
                    e.Amount,
                    ((Ticks2.Agents?)e.Agent)?.Description() ?? "Desconhecido"
            };
            if (e.ActionType == Ticks2.ActionType.Sale)
                redList.Add((e.Date, arr));
            else if (e.ActionType == Ticks2.ActionType.Buy)
                blueList.Add((e.Date, arr));
        }
        redList.Sort((a, b) => a.Time.CompareTo(b.Time));
        blueList.Sort((a, b) => a.Time.CompareTo(b.Time));

        }
        var _cachedRedBubbleData = redList.ConvertAll(x => x.Data);
        var _cachedBlueBubbleData = blueList.ConvertAll(x => x.Data);


        var _cachedRedBubbleSeriesObj = new ScatterSeries { Name = "Aggressive Red", Data = _cachedRedBubbleData, SymbolSize = symbolSizeFunction, Z = 3, ItemStyle = new ItemStyle { Color = MapFlowConfigDrawer.ColorSeller, Opacity = MapFlowConfigDrawer.BubbleOpacity, BorderColor = MapFlowConfigDrawer.ColorSeller, BorderWidth = 1 } };
        var _cachedBlueBubbleSeriesObj = new ScatterSeries { Name = "Aggressive Blue", Data = _cachedBlueBubbleData, SymbolSize = symbolSizeFunction, Z = 3, ItemStyle = new ItemStyle { Color = MapFlowConfigDrawer.ColorBuyer, Opacity = MapFlowConfigDrawer.BubbleOpacity, BorderColor = MapFlowConfigDrawer.ColorBuyer, BorderWidth = 1 } };


        #endregion

        #region Volume Profile

        // Fonte efetiva: sem filtro = VolumeLevels (tempo real); com filtro = snapshot do intervalo do slider.
        IList<VolumeLevel> effectiveLevels = _volumeFilterActive && _filteredVolumeLevels != null
            ? _filteredVolumeLevels
            : VolumeLevels;

        var maxVolume = double.MinValue;

        var _cachedVolumeProfileData = new List<object[]>();
        if (MapFlowConfigDrawer.ProfileVisible)
        {

            foreach (var v in effectiveLevels)
            {
                var total = (double)v.Total;
                var absDelta = Math.Abs((double)v.Delta);
                var price = (double)v.Price;
                if (total > maxVolume) maxVolume = total;
                // if (absDelta > _cachedMaxDelta) _cachedMaxDelta = absDelta;
                // if (price < _cachedVolumeMinPrice) _cachedVolumeMinPrice = price;
                // if (price > _cachedVolumeMaxPrice) _cachedVolumeMaxPrice = price;

                _cachedVolumeProfileData.Add(new object[] { v.Total, v.Price, _cachedPriceStep });
            }

        }

        var volumeProfileFunction = new JavascriptFunction(@"
                function (params, api) {
                    var volumeVal = api.value(0);
                    var priceVal = api.value(1);
                    var stepVal = api.value(2);

                    var start = api.coord([0, priceVal]);
                    var end = api.coord([volumeVal* " + MapFlowConfigDrawer.ProfileSizeH.ToString(inv) + @", priceVal]);

                    var size = api.size([0, stepVal]);
                    var barHeight = size[1] * " + MapFlowConfigDrawer.ProfileSizeV.ToString(inv) + @";

                    var isPoc = Math.abs(volumeVal - " + maxVolume.ToString(inv) + @") < 0.5;

                    return {
                        type: 'rect',
                        shape: {
                            x: end[0],
                            y: start[1] - barHeight / 2,
                            width: start[0] - end[0],
                            height: barHeight
                        },
                        style: api.style({
                            fill: isPoc ? 'rgba(255, 100, 0, " + (MapFlowConfigDrawer.ProfileOpacity * (MapFlowConfigDrawer.ProfileVisible ? 1 : 0)).ToString(inv) + @")' : 'rgba(100, 150, 250, " + (MapFlowConfigDrawer.ProfileOpacity * (MapFlowConfigDrawer.ProfileVisible ? 1 : 0)).ToString(inv) + @")',
                            stroke: 'rgba(100, 150, 250, " + ((MapFlowConfigDrawer.ProfileOpacity * (MapFlowConfigDrawer.ProfileVisible ? 1 : 0)) - 0.2).ToString(inv) + @")'
                        })
                    };
                }
            ");

        var _cachedVolumeSeriesObj = new CustomSeries { Name = "Volume Profile", XAxisIndex = 1, YAxisIndex = 1, Z = 0, Data = _cachedVolumeProfileData, RenderItem = volumeProfileFunction };
        #endregion

        #region Structure

        var upBorderVals = Enumerable.Repeat((object?)null, categoryData.Count).ToList();
        var downBorderVals = Enumerable.Repeat((object?)null, categoryData.Count).ToList();
        var upBorderAuxVals = Enumerable.Repeat((object?)null, categoryData.Count).ToList();
        var downBorderAuxVals = Enumerable.Repeat((object?)null, categoryData.Count).ToList();

        if (MapFlowConfigDrawer.StructureVisible)
        {
            // Build quick lookup from category string to its index to avoid IndexOf in loop
            var indexLookup = new Dictionary<string, int>(categoryData.Count);
            for (int i = 0; i < categoryData.Count; i++)
                if (categoryData[i] != null && !indexLookup.ContainsKey(categoryData[i]))
                    indexLookup[categoryData[i]] = i;

            // Iterate structures (source of truth) and map into the aligned arrays
            if (StructureStorageItemTimeFrameFilter != null && StructureStorageItemTimeFrameFilter.Count > 0)
            {
                foreach (var s in StructureStorageItemTimeFrameFilter)
                {
                    try
                    {
                        if (s == null) continue;
                        if (!string.Equals(s.Symbol, Symbol)) continue;
                        if (s.TimeFrame != MapFlowConfigDrawer.TimeFrame) continue;

                        var key = s.Date.ToString("dd/MM HH:mm");
                        if (indexLookup.TryGetValue(key, out var idx) && idx >= 0 && idx < upBorderVals.Count)
                        {
                            upBorderVals[idx] = s.UpBorder;
                            downBorderVals[idx] = s.DownBorder;
                            upBorderAuxVals[idx] = s.UpAuxBorder;
                            downBorderAuxVals[idx] = s.DownAuxBorder;
                        }
                    }
                    catch
                    {
                        // ignore malformed entries and keep minimal changes
                    }
                }
            }
        }

        #endregion

        #region Graphic and axes setup
        ChartOptions.Graphic = new List<object?>()
        {
            new
            {
                type = "text",
                left = "center",
                top = "center",
                z= -10,
                silent = true,
                style = new
                {
                    text = Symbol + "\n" + MapFlowConfigDrawer.TimeFrame + "min",
                    //font = "bold 60px",
                    fontSize = 60,
                    fontWeight = "bold",
                    fill = "rgba(200, 200, 200, 0.075)",
                    textAlign = "center",
                }
            },
            new
            {
                type = "text",
                right = "3%",
                bottom = "14%",
                z= -10,
                silent = true,
                style = new
                {
                    text = "🕒 "+CurrentBar.Date.GetRemainingTimeCandle(DateTime.Now, MapFlowConfigDrawer.TimeFrame).ToString(@"mm\:ss"),
                    //font = "bold 14px",
                    fontSize = 14,
                    fontWeight = "bold",
                    fill = "rgba(200, 200, 200, 0.55)",
                    stroke = "rgba(200, 200, 200, 0.75)",
                    textAlign = "center",
                }
            },
        };

        ChartOptions.XAxisList = new List<XAxis>
        {
            new XAxis
            {
                Type = AxisType.Category,
                Data = categoryData, BoundaryGap = true,
                Max = categoryData.Count > 0 ? (int)(categoryData.Count / 0.75) : 100 ,
                AxisPointer = new AxisPointer { Show = true},
            }, // X[0]

            new XAxis // X[1]: Volume Total (Direita - Invertido)
            {
                Type = AxisType.Value, Show = false, Inverse = true, Min = 0,
                Max = maxVolume > 0 ? maxVolume * 4 : 10000,
                AxisPointer = new AxisPointer { Show = false },
            },
        };

        // 3. EIXOS Y (labels apenas inteiros; linhas de guia com opacidade reduzida)
        // _yAxisLabelInt e _splitLineGuides são campos readonly — não recriados a cada render.
        ChartOptions.YAxisList = new List<YAxis>
        {
            new YAxis { Type = AxisType.Value, Scale = true, Min = minPrice, Max = maxPrice, Silent = true, AxisPointer = new AxisPointer { Show = true }, AxisLabel = _yAxisLabelInt, SplitLine = _splitLineGuides },
            new YAxis { Type = AxisType.Value, Position = LeftOrRight.Right, Min = minPrice, Max = maxPrice, AxisLabel = _yAxisLabelInt, SplitLine = _splitLineGuides }
        };
        #endregion

        var seriesList = new List<ISeries>(8);
        seriesList.Add(_cachedCandleSeriesObj); // [0]

        seriesList.Add(_cachedRedBubbleSeriesObj);
        seriesList.Add(_cachedBlueBubbleSeriesObj);

        seriesList.Add(_cachedVolumeSeriesObj);
        
        seriesList.Add(new Vizor.ECharts.LineSeries { Name = "UpBorder", Data = upBorderVals ?? Enumerable.Repeat((object?)null, categoryData.Count).ToList(), Z = 4, ShowSymbol = false, LineStyle = new LineStyle { Type = new LineType(LineTypeStyle.Dotted), Color = "#9696ff", Width = 1, Opacity = MapFlowConfigDrawer.StructureOpacity * (MapFlowConfigDrawer.StructureVisible ? 1 : 0) } });
        seriesList.Add(new Vizor.ECharts.LineSeries { Name = "DownBorder", Data = downBorderVals ?? Enumerable.Repeat((object?)null, categoryData.Count).ToList(), Z = 4, ShowSymbol = false, LineStyle = new LineStyle { Type = new LineType(LineTypeStyle.Dotted), Color = "#ff9696", Width = 1, Opacity = MapFlowConfigDrawer.StructureOpacity * (MapFlowConfigDrawer.StructureVisible ? 1 : 0) } });
        seriesList.Add(new Vizor.ECharts.LineSeries { Name = "UpAuxBorder", Data = upBorderAuxVals, Z = 4, ShowSymbol = false, LineStyle = new LineStyle { Type = new LineType(LineTypeStyle.Dashed), Color = "#5555aa", Width = 1, Opacity = (MapFlowConfigDrawer.StructureOpacity - 0.25 <= 0 ? 0.01 : MapFlowConfigDrawer.StructureOpacity - 0.25) * (MapFlowConfigDrawer.StructureAuxVisible ? 1 : 0) } });
        seriesList.Add(new Vizor.ECharts.LineSeries { Name = "DownAuxBorder", Data = downBorderAuxVals, Z = 4, ShowSymbol = false, LineStyle = new LineStyle { Type = new LineType(LineTypeStyle.Dashed), Color = "#aa5555", Width = 1, Opacity = (MapFlowConfigDrawer.StructureOpacity - 0.25 <= 0 ? 0.01 : MapFlowConfigDrawer.StructureOpacity - 0.25) * (MapFlowConfigDrawer.StructureAuxVisible ? 1 : 0) } });
        

        ChartOptions.Series = seriesList;

        swTotal.Stop();
        //Console.WriteLine($"{swTotal.ElapsedMilliseconds} ms - GenerateChart");

        await EChart.UpdateAsync(false);
    }


    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var todayData = await httpClient.GetFromJsonAsync<List<BarStorageItem>>($"{Navigation.ToAbsoluteUri($"/api/data/getbar/{Symbol}/{DateTime.Today:yyyy-MM-dd}").AbsoluteUri}");
            BarStorageItem = todayData ?? new List<BarStorageItem>();


            var todayBubble = await httpClient.GetFromJsonAsync<List<BubbleStorageItem>>($"{Navigation.ToAbsoluteUri($"/api/data/getbubble/{Symbol}/{DateTime.Today:yyyy-MM-dd}").AbsoluteUri}");
            Bubbles = todayBubble ?? new List<BubbleStorageItem>();

            var lastBar = BarStorageItem.OrderByDescending(q => q.Date).FirstOrDefault();
            if (lastBar != null && lastBar.VolumeLevel != null)
                VolumeLevels = lastBar.VolumeLevel;

            var todayStructure = await httpClient.GetFromJsonAsync<List<StructureStorageItem>>($"{Navigation.ToAbsoluteUri($"/api/data/getstructure/{Symbol}/{DateTime.Today:yyyy-MM-dd}/{MapFlowConfigDrawer.StructureRangeUpd.ToString(CultureInfo.InvariantCulture)}").AbsoluteUri}");
            StructureStorageItem = todayStructure ?? new List<StructureStorageItem>();

        }
        catch (Exception ex)
        {
            Console.WriteLine("LoadData Error: " + ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();

            if (HubClient != null && HubClient._started == false)
            {
                await HubClient.StartConnection();
            }
        }
    }
    private async Task SetMinDistanceStructure(double minDistance)
    {
        var todayStructure = await httpClient.GetFromJsonAsync<List<StructureStorageItem>>($"{Navigation.ToAbsoluteUri($"/api/data/SetStructureDistance/{Symbol}/{MapFlowConfigDrawer.StructureRangeUpd.ToString(CultureInfo.InvariantCulture)}").AbsoluteUri}");
        StructureStorageItem = todayStructure ?? new List<StructureStorageItem>();
    }
}
