        <Button Content="Time and Trade S" Grid.Column="2"  Grid.Row="1" VerticalAlignment="Center" Click="TntS_Click" Margin="0,0,20,0" HorizontalAlignment="Right" Width="365"/>
        <Button Content="C" HorizontalAlignment="Right" Grid.Column="2"  Grid.Row="1" Margin="0,0,0,0" VerticalAlignment="Center" Width="15" Click="Clear_TntS_Click"/>

