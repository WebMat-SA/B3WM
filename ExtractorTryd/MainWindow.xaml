<Window x:Class="ExtractorTryd.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExtractorTryd"
        mc:Ignorable="d"
        Title="MainWindow" Height="470" Width="860">
    <Grid Margin="10,10,15,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Margin="15,0,0,10" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Tryd Data Extractor" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="Out:" TextAlignment="Right" Margin="0,4,76,1" HorizontalAlignment="Right" Width="25" />
            <TextBox x:Name="SymbolTextBox" TextAlignment="Right" Margin="0,0,0,0" Width="75" VerticalAlignment="Center" HorizontalAlignment="Right" Text="{Binding DataContext.Symbol}"/>
            <TextBlock Text="In:" TextAlignment="Right" Margin="0,4,201,1" HorizontalAlignment="Right" Width="25" />
            <TextBox x:Name="TnTTextBox" TextAlignment="Right" Margin="0,0,124,0" VerticalAlignment="Center" Text="{Binding DataContext.TNTSymbol}" HorizontalAlignment="Right" Width="75"/>

            <TextBlock Text="Server: " Grid.Row="1" TextAlignment="Right" Margin="0,3,200,2" HorizontalAlignment="Right" Width="42" />
            <TextBox x:Name="URLTextBox" Grid.Row="1" TextAlignment="Right" Margin="0,0,0,0" Width="200" VerticalAlignment="Center" HorizontalAlignment="Right" Text="{Binding DataContext.Url}"/>
        </Grid>

        <!-- Original Tryd button kept -->
        <!--<Button Content="Times and Trades" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,0"  Click="TimesAndTrades_Click"/>-->
        <Button Content="Times and Trades (Profit)" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,0"  Click="TimesAndTradesProfit_Click"/>
        <!--<Button Content="C" HorizontalAlignment="Right" Grid.Row="1" Grid.Column="0" Margin="0,0,0,0" VerticalAlignment="Center" Width="15" Click="Clear_TnT_Click"/>-->


        <!-- Messages list -->
        <ListBox x:Name="MessagesListBox" Grid.Row="3" Margin="0,0,0,0"  />

        <!-- Status -->
        <TextBlock x:Name="StatusTextBlock" Grid.Row="2" HorizontalAlignment="Left" Margin="0,10,0,0" Width="385" />
        <TextBlock x:Name="StatusTextBlockData" Grid.Row="2" Grid.Column="0" Margin="185,5,0,5" HorizontalAlignment="Right" Width="100" TextAlignment="Right" />



        <!-- Original Tryd button kept -->
        <!--<Button Content="Book" Grid.Column="1"  Grid.Row="1" VerticalAlignment="Center" Click="Book_Click" Margin="0,0,20,0" HorizontalAlignment="Right" Width="365"/>
        <Button Content="C" HorizontalAlignment="Right"  Grid.Row="1" Grid.Column="1" Margin="0,0,0,0" VerticalAlignment="Center" Width="15" Click="Clear_Book_Click"/>

        -->
